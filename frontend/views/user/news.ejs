      <!-- Thumbnail -->
      <div id="modal-img-container" class="mb-6 rounded-2xl overflow-hidden h-64 md:h-80 hidden">
        <img id="modal-image" src="" alt="News Thumbnail" class="w-full h-full object-cover">
      </div>

      <!-- Main Body Text -->
      <div id="modal-content" class="text-slate-600 text-sm md:text-base leading-relaxed whitespace-pre-line prose max-w-none"></div>
    </div>

    <!-- Footer Action -->
    <div class="px-8 py-5 border-t border-slate-100 bg-slate-50 rounded-b-3xl flex items-center justify-end flex-shrink-0">
      <button onclick="closeNewsModal()" class="bg-slate-800 text-white px-6 py-3 rounded-xl font-bold hover:bg-slate-700 transition">
        Đóng lại
