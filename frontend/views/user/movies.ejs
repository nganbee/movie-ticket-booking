<!-- Movie Filter Page -->
<div class="bg-bgSubtle min-h-screen pb-16">

  <!-- Page Header -->
  <div class="bg-white border-b border-borderSubtle pt-24 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 class="text-3xl font-extrabold text-slate-800 flex items-center gap-3">
            <span class="w-1.5 h-8 bg-brand rounded-full"></span>
            Tất Cả Phim
          </h1>
          <p class="text-slate-500 mt-1 ml-5" id="result-count">Đang tải danh sách phim...</p>
        </div>
        <div class="flex items-center gap-2">
          <button id="view-grid" onclick="setView('grid')" class="view-btn p-2.5 rounded-lg bg-brand text-white shadow transition" title="Dạng lưới">
            <i class="fas fa-th-large text-sm"></i>
          </button>
          <button id="view-list" onclick="setView('list')" class="view-btn p-2.5 rounded-lg bg-slate-100 text-slate-500 hover:bg-slate-200 transition" title="Dạng danh sách">
            <i class="fas fa-list text-sm"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row gap-8">

      <!-- ===== SIDEBAR FILTERS ===== -->
      <aside class="lg:w-72 flex-shrink-0">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 sticky top-24">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
              <i class="fas fa-sliders-h text-brand text-sm"></i> Bộ Lọc
            </h2>
            <button onclick="resetFilters()" class="text-xs text-brand hover:text-red-700 font-semibold transition flex items-center gap-1">
              <i class="fas fa-redo text-[10px]"></i> Đặt lại
            </button>
          </div>

          <!-- Search -->
          <div class="mb-6">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Tìm kiếm</label>
            <div class="relative">
              <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i>
              <input
                id="search-input"
                type="text"
                placeholder="Tên phim..."
                oninput="applyFilters()"
                class="w-full border border-slate-200 bg-slate-50 rounded-xl pl-9 pr-4 py-2.5 text-sm text-slate-700 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition"
              >
            </div>
          </div>

          <!-- Genre Filter -->
          <div class="mb-6">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Thể Loại</label>
            <div class="space-y-2" id="genre-filters">
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="all" checked class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition font-medium">Tất cả</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Hành Động" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Hành Động</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Hài Hước" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Hài Hước</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Kinh Dị" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Kinh Dị</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Tâm Lý" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Tâm Lý</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Viễn Tưởng" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Viễn Tưởng</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Hoạt Hình" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Hoạt Hình</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Tình Cảm" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Tình Cảm</span>
              </label>
            </div>
          </div>

          <!-- Format Filter -->
          <div class="mb-6">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Định Dạng</label>
            <div class="flex flex-wrap gap-2" id="format-filters">
              <button onclick="toggleFormat(this, 'all')" data-format="all" class="format-btn active px-3 py-1.5 rounded-lg text-xs font-bold border border-brand bg-brand text-white transition">Tất cả</button>
              <button onclick="toggleFormat(this, '2D')" data-format="2D" class="format-btn px-3 py-1.5 rounded-lg text-xs font-bold border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">2D</button>
              <button onclick="toggleFormat(this, '3D')" data-format="3D" class="format-btn px-3 py-1.5 rounded-lg text-xs font-bold border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">3D</button>
              <button onclick="toggleFormat(this, 'IMAX')" data-format="IMAX" class="format-btn px-3 py-1.5 rounded-lg text-xs font-bold border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">IMAX</button>
            </div>
          </div>

          <!-- Date Filter -->
          <div class="mb-6">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Ngày Chiếu</label>
            <input
              id="date-filter"
              type="date"
              onchange="applyFilters()"
              class="w-full border border-slate-200 bg-slate-50 rounded-xl px-3 py-2.5 text-sm text-slate-700 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition"
            >
          </div>

          <!-- Status Filter -->
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Trạng Thái</label>
            <div class="space-y-2">
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="radio" name="status" value="all" checked onchange="onStatusChange()" class="w-4 h-4 accent-brand">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Tất cả</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="radio" name="status" value="now_showing" onchange="onStatusChange()" class="w-4 h-4 accent-brand">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Đang Chiếu</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="radio" name="status" value="coming_soon" onchange="onStatusChange()" class="w-4 h-4 accent-brand">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Sắp Chiếu</span>
              </label>
            </div>
          </div>
        </div>
      </aside>

      <!-- ===== MOVIE LIST ===== -->
      <div class="flex-1">
        <!-- Movie Grid -->
        <div id="movie-container" class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-5">
          <!-- Populated by JS -->
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="hidden flex flex-col items-center justify-center py-24 text-center">
          <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mb-6">
            <i class="fas fa-film text-4xl text-slate-300"></i>
          </div>
          <h3 class="text-xl font-bold text-slate-700 mb-2">Không tìm thấy phim</h3>
          <p class="text-slate-400 mb-6 max-w-xs">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm để tìm phim phù hợp.</p>
          <button onclick="resetFilters()" class="bg-brand text-white px-6 py-2.5 rounded-xl font-bold hover:bg-red-700 transition shadow-md shadow-brand/20">
            <i class="fas fa-redo mr-2"></i> Đặt lại bộ lọc
          </button>
        </div>

        <!-- Pagination -->
        <div id="pagination-container"></div>
      </div>
    </div>
  </div>
</div>

<script>
  // ========== STATE ==========
  let ALL_MOVIES = [];   // Cache phim của trang hiện tại
  let currentView = 'grid';
  let selectedFormat = 'all';
  let currentPage = 1;
  const PAGE_LIMIT = 12;
  let totalPages = 1;
  let totalMovies = 0;
  let lastStatus = 'all'; // Theo dõi status được gửi lên backend

  // ========== MAP BACKEND → FRONTEND FORMAT ==========
  function mapMovie(m) {
    return {
      id: m.movie_id,
      title: m.title,
      genre: m.genre || 'Khác',
      rating: m.imdb_rating ? m.imdb_rating.toFixed(1) : 'N/A',
      duration: `${m.duration} phút`,
      format: m.format ? m.format : [],
      status: m.status,
      poster: m.poster_url || 'https://via.placeholder.com/500x750?text=No+Poster',
      showtimes: m.showtimes || [],
      releaseDate: m.release_date || '',
      // Gán showDates động cho phim đang chiếu
      showDates: (() => {
        const dates = [];
        if (m.status === 'now_showing') {
          const base = new Date();
          for (let i = -7; i < 21; i++) {
            const d = new Date(base);
            d.setDate(d.getDate() + i);
            dates.push(d.toISOString().split('T')[0]);
          }
        }
        return dates;
      })()
    };
  }

  // ========== LẤY FILTER HIỆN TẠI ==========
  function getCurrentFilters() {
    return {
      search: document.getElementById('search-input').value.toLowerCase().trim(),
      genres: [...document.querySelectorAll('.genre-check:checked')].map(cb => cb.value),
      status: document.querySelector('input[name="status"]:checked').value,
      date: document.getElementById('date-filter').value,
    };
  }

  // ========== FETCH TỪ BACKEND (chỉ khi đổi trang / đổi status) ==========
  async function loadMovies(page = 1) {
    const container = document.getElementById('movie-container');
    const resultCount = document.getElementById('result-count');
    const status = document.querySelector('input[name="status"]:checked').value;

    lastStatus = status;

    // Hiển thị loading spinner
    container.innerHTML = `
      <div class="col-span-full flex flex-col items-center justify-center py-24 text-slate-400">
        <svg class="animate-spin h-10 w-10 mb-4 text-brand" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
        </svg>
        <p class="text-sm">Đang tải danh sách phim...</p>
      </div>`;
    document.getElementById('pagination-container').innerHTML = '';

    try {
      const params = new URLSearchParams({ page, limit: PAGE_LIMIT });
      if (status !== 'all') params.append('status', status);

      const response = await fetch(`/api/movies?${params.toString()}`);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);

      const data = await response.json();
      currentPage = data.page;
      totalPages  = data.total_pages;
      totalMovies = data.total;

      // Lưu cache — genre/search/format/date sẽ lọc trên mảng này
      ALL_MOVIES = data.items.map(mapMovie);

      // Sau khi fetch xong, lọc client-side rồi render
      applyFilters();
    } catch (err) {
      console.error('Lỗi tải phim:', err);
      container.innerHTML = `
        <div class="col-span-full flex flex-col items-center justify-center py-24 text-center">
          <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mb-4">
            <i class="fas fa-exclamation-triangle text-2xl text-red-400"></i>
          </div>
          <h3 class="text-lg font-bold text-slate-700 mb-1">Không thể tải danh sách phim</h3>
          <p class="text-slate-400 text-sm mb-4">Vui lòng kiểm tra kết nối hoặc thử lại sau.</p>
          <button onclick="loadMovies(currentPage)" class="bg-brand text-white px-5 py-2 rounded-xl font-bold hover:bg-red-700 transition">
            <i class="fas fa-redo mr-2"></i>Thử lại
          </button>
        </div>`;
      resultCount.textContent = 'Lỗi tải dữ liệu';
    }
  }


  // ========== LỌC CLIENT-SIDE (search, genre, format, date) ==========
  // Không gọi backend, chỉ lọc trên ALL_MOVIES đã cache
  function clientFilter(movies) {
    const search = document.getElementById('search-input').value.toLowerCase().trim();
    const genres = [...document.querySelectorAll('.genre-check:checked')].map(cb => cb.value);
    const date   = document.getElementById('date-filter').value;

    return movies.filter(m => {
      if (search && !m.title.toLowerCase().includes(search)) return false;
      if (date && (!m.showDates || !m.showDates.includes(date))) return false;
      if (!genres.includes('all') && !genres.some(g => m.genre.includes(g))) return false;
      if (selectedFormat !== 'all' && m.format.length > 0 && !m.format.includes(selectedFormat)) return false;
      return true;
    });
  }

  // ========== RENDER ==========
  function renderMovies(movies) {
    const container = document.getElementById('movie-container');
    const emptyState = document.getElementById('empty-state');
    const resultCount = document.getElementById('result-count');

    if (movies.length === 0) {
      container.innerHTML = '';
      emptyState.classList.remove('hidden');
      resultCount.textContent = 'Không tìm thấy phim nào';
      document.getElementById('pagination-container').innerHTML = '';
      return;
    }

    emptyState.classList.add('hidden');
    resultCount.textContent = `Hiển thị ${movies.length} / ${totalMovies} phim`;

    if (currentView === 'grid') {
      container.className = 'grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-5';
      container.innerHTML = movies.map(m => renderGridCard(m)).join('');
    } else {
      container.className = 'flex flex-col gap-4';
      container.innerHTML = movies.map(m => renderListCard(m)).join('');
    }
  }

  function formatBadge(fmt) {
    const colors = { 'IMAX': 'bg-yellow-100 text-yellow-700 border-yellow-200', '3D': 'bg-blue-100 text-blue-700 border-blue-200', '2D': 'bg-slate-100 text-slate-600 border-slate-200' };
    return `<span class="text-[10px] font-bold px-1.5 py-0.5 rounded border ${colors[fmt] || 'bg-slate-100 text-slate-600'}">${fmt}</span>`;
  }

  function statusBadge(status) {
    return status === 'now_showing'
      ? `<span class="absolute top-3 left-3 bg-brand text-white text-[10px] font-bold px-2 py-0.5 rounded-full shadow">Đang Chiếu</span>`
      : `<span class="absolute top-3 left-3 bg-blue-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-full shadow">Sắp Chiếu</span>`;
  }

  function renderGridCard(m) {
    const showtimesHtml = m.showtimes.length > 0
      ? m.showtimes.slice(0, 3).map(t => `<span class="text-xs border border-slate-200 text-slate-600 px-2 py-0.5 rounded-lg hover:border-brand hover:text-brand cursor-pointer transition">${t}</span>`).join('')
      + (m.showtimes.length > 3 ? `<span class="text-xs text-slate-400">+${m.showtimes.length-3}</span>` : '')
      : `<span class="text-xs text-slate-400 italic">Chưa mở bán</span>`;

    return `
      <a href="/movie/${m.id}" class="group cursor-pointer block bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="relative aspect-[2/3] overflow-hidden">
          <img src="${m.poster}" alt="${m.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out">
          ${statusBadge(m.status)}
          <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-md text-slate-800 text-xs font-bold px-2 py-1 rounded-lg shadow flex items-center gap-1">
            <i class="fas fa-star text-yellow-500 text-[10px]"></i> ${m.rating}
          </div>
          <div class="absolute inset-0 bg-slate-900/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-4">
            <span class="bg-brand text-white text-sm font-bold px-5 py-2 rounded-xl shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Xem chi tiết</span>
          </div>
        </div>
        <div class="p-3">
          <h3 class="font-bold text-sm text-slate-800 truncate group-hover:text-brand transition mb-1">${m.title}</h3>
          <div class="flex items-center gap-1 mb-2 text-slate-400 text-xs">
            <i class="fas fa-tag text-[10px]"></i> ${m.genre}
            <span class="mx-1">•</span>
            <i class="far fa-clock text-[10px]"></i> ${m.duration}
          </div>
          <div class="flex flex-wrap gap-1 mb-2">
            ${m.format.map(formatBadge).join('')}
          </div>
          <div class="flex flex-wrap gap-1 pt-2 border-t border-slate-100">
            ${showtimesHtml}
          </div>
        </div>
      </a>
    `;
  }

  function renderListCard(m) {
    const showtimesHtml = m.showtimes.length > 0
      ? m.showtimes.map(t => `<span class="text-xs border border-slate-200 text-slate-600 px-2 py-1 rounded-lg hover:border-brand hover:text-brand cursor-pointer transition">${t}</span>`).join('')
      : `<span class="text-xs text-slate-400 italic">Chưa mở bán</span>`;

    return `
      <a href="/movie/${m.id}" class="group bg-white rounded-2xl shadow-sm border border-slate-100 p-4 flex gap-4 hover:shadow-lg hover:border-brand/20 transition-all duration-300">
        <div class="relative flex-shrink-0 w-28 rounded-xl overflow-hidden aspect-[2/3]">
          <img src="${m.poster}" alt="${m.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
          ${statusBadge(m.status)}
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-bold text-lg text-slate-800 group-hover:text-brand transition leading-tight">${m.title}</h3>
            <div class="flex-shrink-0 flex items-center gap-1 bg-yellow-50 text-yellow-600 text-xs font-bold px-2 py-1 rounded-lg border border-yellow-200">
              <i class="fas fa-star text-[10px]"></i> ${m.rating}
            </div>
          </div>
          <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500 mb-3">
            <span class="flex items-center gap-1"><i class="fas fa-tag text-slate-300 text-xs"></i> ${m.genre}</span>
            <span class="flex items-center gap-1"><i class="far fa-clock text-slate-300 text-xs"></i> ${m.duration}</span>
          </div>
          <div class="flex flex-wrap gap-1 mb-3">
            ${m.format.map(formatBadge).join('')}
          </div>
          <div class="flex flex-wrap gap-1.5 pt-3 border-t border-slate-100">
            <span class="text-xs text-slate-400 mr-1 self-center">Suất chiếu:</span>
            ${showtimesHtml}
          </div>
        </div>
      </a>
    `;
  }

  // ========== PAGINATION UI ==========
  function renderPagination() {
    const container = document.getElementById('pagination-container');
    if (totalPages <= 1) { container.innerHTML = ''; return; }

    const btnBase = 'w-9 h-9 rounded-lg text-sm font-semibold flex items-center justify-center transition';
    const btnActive = `${btnBase} bg-brand text-white shadow`;
    const btnNormal = `${btnBase} bg-white border border-slate-200 text-slate-600 hover:border-brand hover:text-brand`;
    const btnDisabled = `${btnBase} bg-slate-50 border border-slate-100 text-slate-300 cursor-not-allowed`;

    // Tạo danh sách số trang hiển thị (dạng: 1 ... 4 5 6 ... 10)
    function pageNumbers() {
      const pages = [];
      const delta = 2;
      for (let i = Math.max(2, currentPage - delta); i <= Math.min(totalPages - 1, currentPage + delta); i++) {
        pages.push(i);
      }
      if (pages.length && pages[0] > 2) pages.unshift('...');
      if (pages.length && pages[pages.length - 1] < totalPages - 1) pages.push('...');
      pages.unshift(1);
      if (totalPages > 1) pages.push(totalPages);
      return [...new Set(pages)];
    }

    const pages = pageNumbers();
    let html = `<div class="flex items-center gap-1.5 mt-8 justify-center">`;

    // Nút Prev
    html += currentPage > 1
      ? `<button onclick="goToPage(${currentPage - 1})" class="${btnNormal} px-3"><i class="fas fa-chevron-left text-xs"></i></button>`
      : `<span class="${btnDisabled} px-3"><i class="fas fa-chevron-left text-xs"></i></span>`;

    // Số trang
    pages.forEach(p => {
      if (p === '...') {
        html += `<span class="${btnBase} text-slate-400">...</span>`;
      } else {
        html += `<button onclick="goToPage(${p})" class="${p === currentPage ? btnActive : btnNormal}">${p}</button>`;
      }
    });

    html += currentPage < totalPages
      ? `<button onclick="goToPage(${currentPage + 1})" class="${btnNormal} px-3"><i class="fas fa-chevron-right text-xs"></i></button>`
      : `<span class="${btnDisabled} px-3"><i class="fas fa-chevron-right text-xs"></i></span>`;

    html += `</div>`;
    container.innerHTML = html;
  }

  function goToPage(p) {
    if (p < 1 || p > totalPages || p === currentPage) return;
    window.scrollTo({ top: 0, behavior: 'smooth' });
    loadMovies(p);
  }

  // ========== FILTERS ==========
  // applyFilters: chỉ lọc client-side trên cache, KHÔNG gọi backend
  function applyFilters() {
    const filtered = clientFilter(ALL_MOVIES);
    renderMovies(filtered);
    renderPagination();
  }

  // onStatusChange: status thay đổi → phải fetch lại từ backend
  function onStatusChange() {
    currentPage = 1;
    loadMovies(1);
  }

  function toggleFormat(btn, fmt) {
    document.querySelectorAll('.format-btn').forEach(b => {
      b.classList.remove('active', 'bg-brand', 'text-white', 'border-brand');
      b.classList.add('border-slate-200', 'text-slate-600');
    });
    btn.classList.add('active', 'bg-brand', 'text-white', 'border-brand');
    btn.classList.remove('border-slate-200', 'text-slate-600');
    selectedFormat = fmt;
    applyFilters();
  }

  function resetFilters() {
    document.getElementById('search-input').value = '';
    document.getElementById('date-filter').value = '';
    document.querySelectorAll('.genre-check').forEach(cb => {
      cb.checked = cb.value === 'all';
    });
    document.querySelector('input[name="status"][value="all"]').checked = true;
    document.querySelectorAll('.format-btn').forEach(b => {
      b.classList.remove('active', 'bg-brand', 'text-white', 'border-brand');
      b.classList.add('border-slate-200', 'text-slate-600');
    });
    const allFormatBtn = document.querySelector('.format-btn[data-format="all"]');
    allFormatBtn.classList.add('active', 'bg-brand', 'text-white', 'border-brand');
    allFormatBtn.classList.remove('border-slate-200', 'text-slate-600');
    selectedFormat = 'all';
    // Nếu status vừa reset về 'all' nhưng trước đó là giá trị khác → cần fetch lại
    if (lastStatus !== 'all') {
      currentPage = 1;
      loadMovies(1);
    } else {
      applyFilters();
    }
  }

  function setView(v) {
    currentView = v;
    document.getElementById('view-grid').className = v === 'grid'
      ? 'view-btn p-2.5 rounded-lg bg-brand text-white shadow transition'
      : 'view-btn p-2.5 rounded-lg bg-slate-100 text-slate-500 hover:bg-slate-200 transition';
    document.getElementById('view-list').className = v === 'list'
      ? 'view-btn p-2.5 rounded-lg bg-brand text-white shadow transition'
      : 'view-btn p-2.5 rounded-lg bg-slate-100 text-slate-500 hover:bg-slate-200 transition';
    applyFilters();
  }

  // ========== INIT ==========
  document.addEventListener('DOMContentLoaded', () => {
    // Gắn event cho các checkbox genre
    document.querySelectorAll('.genre-check').forEach(cb => {
      cb.addEventListener('change', (e) => {
        const allCb = document.querySelector('.genre-check[value="all"]');
        if (e.target.value === 'all' && e.target.checked) {
          document.querySelectorAll('.genre-check:not([value="all"])').forEach(other => other.checked = false);
        } else if (e.target.value !== 'all') {
          if (e.target.checked) allCb.checked = false;
          const anyChecked = [...document.querySelectorAll('.genre-check:not([value="all"])')].some(other => other.checked);
          if (!anyChecked) allCb.checked = true;
        }
        applyFilters();
      });
    });

    // Fetch dữ liệu thật từ backend
    loadMovies();
  });
</script>
