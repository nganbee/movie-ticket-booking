      showtimes: ['09:30', '13:00', '17:00'],
      releaseDate: '2024-09-27'
    }
  ];

  let currentView = 'grid';
  let selectedFormat = 'all';

  // ========== RENDER ==========
  function renderMovies(movies) {
    const container = document.getElementById('movie-container');
    const emptyState = document.getElementById('empty-state');
    const resultCount = document.getElementById('result-count');

    if (movies.length === 0) {
      container.innerHTML = '';
      emptyState.classList.remove('hidden');
      resultCount.textContent = 'Không tìm thấy phim nào';
      return;
    }

    emptyState.classList.add('hidden');
    resultCount.textContent = `Tìm thấy ${movies.length} phim`;

    if (currentView === 'grid') {
      container.className = 'grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-5';
      container.innerHTML = movies.map(m => renderGridCard(m)).join('');
    } else {
      container.className = 'flex flex-col gap-4';
      container.innerHTML = movies.map(m => renderListCard(m)).join('');
    }
  }

  function formatBadge(fmt) {
    const colors = { 'IMAX': 'bg-yellow-100 text-yellow-700 border-yellow-200', '3D': 'bg-blue-100 text-blue-700 border-blue-200', '2D': 'bg-slate-100 text-slate-600 border-slate-200' };
    return `<span class="text-[10px] font-bold px-1.5 py-0.5 rounded border ${colors[fmt] || 'bg-slate-100 text-slate-600'}">${fmt}</span>`;
  }

  function statusBadge(status) {
    return status === 'now_showing'
      ? `<span class="absolute top-3 left-3 bg-brand text-white text-[10px] font-bold px-2 py-0.5 rounded-full shadow">Đang Chiếu</span>`
      : `<span class="absolute top-3 left-3 bg-blue-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-full shadow">Sắp Chiếu</span>`;
  }

  function renderGridCard(m) {
    const showtimesHtml = m.showtimes.length > 0
      ? m.showtimes.slice(0, 3).map(t => `<span class="text-xs border border-slate-200 text-slate-600 px-2 py-0.5 rounded-lg hover:border-brand hover:text-brand cursor-pointer transition">${t}</span>`).join('')
      + (m.showtimes.length > 3 ? `<span class="text-xs text-slate-400">+${m.showtimes.length-3}</span>` : '')
      : `<span class="text-xs text-slate-400 italic">Chưa mở bán</span>`;

    return `
      <a href="/movie/${m.id}" class="group cursor-pointer block bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
        <div class="relative aspect-[2/3] overflow-hidden">
          <img src="${m.poster}" alt="${m.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out">
          ${statusBadge(m.status)}
          <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-md text-slate-800 text-xs font-bold px-2 py-1 rounded-lg shadow flex items-center gap-1">
            <i class="fas fa-star text-yellow-500 text-[10px]"></i> ${m.rating}
          </div>
          <div class="absolute inset-0 bg-slate-900/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-4">
            <span class="bg-brand text-white text-sm font-bold px-5 py-2 rounded-xl shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">Xem chi tiết</span>
          </div>
        </div>
        <div class="p-3">
          <h3 class="font-bold text-sm text-slate-800 truncate group-hover:text-brand transition mb-1">${m.title}</h3>
          <div class="flex items-center gap-1 mb-2 text-slate-400 text-xs">
            <i class="fas fa-tag text-[10px]"></i> ${m.genre}
            <span class="mx-1">•</span>
            <i class="far fa-clock text-[10px]"></i> ${m.duration}
          </div>
          <div class="flex flex-wrap gap-1 mb-2">
            ${m.format.map(formatBadge).join('')}
          </div>
          <div class="flex flex-wrap gap-1 pt-2 border-t border-slate-100">
            ${showtimesHtml}
          </div>
        </div>
      </a>
    `;
  }

  function renderListCard(m) {
    const showtimesHtml = m.showtimes.length > 0
      ? m.showtimes.map(t => `<span class="text-xs border border-slate-200 text-slate-600 px-2 py-1 rounded-lg hover:border-brand hover:text-brand cursor-pointer transition">${t}</span>`).join('')
      : `<span class="text-xs text-slate-400 italic">Chưa mở bán</span>`;

    return `
      <a href="/movie/${m.id}" class="group bg-white rounded-2xl shadow-sm border border-slate-100 p-4 flex gap-4 hover:shadow-lg hover:border-brand/20 transition-all duration-300">
        <div class="relative flex-shrink-0 w-28 rounded-xl overflow-hidden aspect-[2/3]">
          <img src="${m.poster}" alt="${m.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
          ${statusBadge(m.status)}
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-bold text-lg text-slate-800 group-hover:text-brand transition leading-tight">${m.title}</h3>
            <div class="flex-shrink-0 flex items-center gap-1 bg-yellow-50 text-yellow-600 text-xs font-bold px-2 py-1 rounded-lg border border-yellow-200">
              <i class="fas fa-star text-[10px]"></i> ${m.rating}
            </div>
          </div>
          <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500 mb-3">
            <span class="flex items-center gap-1"><i class="fas fa-tag text-slate-300 text-xs"></i> ${m.genre}</span>
            <span class="flex items-center gap-1"><i class="far fa-clock text-slate-300 text-xs"></i> ${m.duration}</span>
          </div>
          <div class="flex flex-wrap gap-1 mb-3">
            ${m.format.map(formatBadge).join('')}
          </div>
          <div class="flex flex-wrap gap-1.5 pt-3 border-t border-slate-100">
            <span class="text-xs text-slate-400 mr-1 self-center">Suất chiếu:</span>
            ${showtimesHtml}
          </div>
        </div>
      </a>
    `;
  }

  // ========== FILTERS ==========
  function applyFilters() {
    const search = document.getElementById('search-input').value.toLowerCase().trim();
    const selectedGenres = [...document.querySelectorAll('.genre-check:checked')].map(cb => cb.value);
    const status = document.querySelector('input[name="status"]:checked').value;
    const date = document.getElementById('date-filter').value;

    let filtered = MOCK_MOVIES.filter(m => {
      // Search
      if (search && !m.title.toLowerCase().includes(search)) return false;
      // Date
      if (date) {
        if (!m.showDates || !m.showDates.includes(date)) return false;
      }
      // Genre
      if (!selectedGenres.includes('all')) {
        if (!selectedGenres.some(g => m.genre.includes(g))) return false;
      }
      // Format
      if (selectedFormat !== 'all' && !m.format.includes(selectedFormat)) return false;
      // Status
      if (status !== 'all' && m.status !== status) return false;
      return true;
    });

    renderMovies(filtered);
  }

  function toggleFormat(btn, fmt) {
    document.querySelectorAll('.format-btn').forEach(b => {
      b.classList.remove('active', 'bg-brand', 'text-white', 'border-brand');
      b.classList.add('border-slate-200', 'text-slate-600');
    });
    btn.classList.add('active', 'bg-brand', 'text-white', 'border-brand');
    btn.classList.remove('border-slate-200', 'text-slate-600');
    selectedFormat = fmt;
    applyFilters();
  }

  function resetFilters() {
    document.getElementById('search-input').value = '';
    document.getElementById('date-filter').value = '';
    document.querySelectorAll('.genre-check').forEach(cb => {
      cb.checked = cb.value === 'all';
    });
    document.querySelector('input[name="status"][value="all"]').checked = true;
    document.querySelectorAll('.format-btn').forEach(b => {
      b.classList.remove('active', 'bg-brand', 'text-white', 'border-brand');
      b.classList.add('border-slate-200', 'text-slate-600');
    });
    const allFormatBtn = document.querySelector('.format-btn[data-format="all"]');
    allFormatBtn.classList.add('active', 'bg-brand', 'text-white', 'border-brand');
    allFormatBtn.classList.remove('border-slate-200', 'text-slate-600');
    selectedFormat = 'all';
    applyFilters();
  }

  function setView(v) {
    currentView = v;
    document.getElementById('view-grid').className = v === 'grid'
      ? 'view-btn p-2.5 rounded-lg bg-brand text-white shadow transition'
      : 'view-btn p-2.5 rounded-lg bg-slate-100 text-slate-500 hover:bg-slate-200 transition';
    document.getElementById('view-list').className = v === 'list'
      ? 'view-btn p-2.5 rounded-lg bg-brand text-white shadow transition'
      : 'view-btn p-2.5 rounded-lg bg-slate-100 text-slate-500 hover:bg-slate-200 transition';
    applyFilters();
  }

  // Init
  document.addEventListener('DOMContentLoaded', () => {
    // Generate mock showDates for movies
    const todayStr = new Date().toISOString().split('T')[0];
    const baseDate = new Date();
    MOCK_MOVIES.forEach(m => {
      m.showDates = [];
      if (m.status === 'now_showing') {
        for (let i = -7; i < 21; i++) {
          let d = new Date(baseDate);
          d.setDate(d.getDate() + i);
          m.showDates.push(d.toISOString().split('T')[0]);
        }
      }
    });

    document.querySelectorAll('.genre-check').forEach(cb => {
      cb.addEventListener('change', (e) => {
        const allCb = document.querySelector('.genre-check[value="all"]');
        if (e.target.value === 'all' && e.target.checked) {
          document.querySelectorAll('.genre-check:not([value="all"])').forEach(other => other.checked = false);
        } else if (e.target.value !== 'all') {
          if (e.target.checked) allCb.checked = false;
          // check if no genre is selected
          const anyChecked = [...document.querySelectorAll('.genre-check:not([value="all"])')].some(other => other.checked);
          if (!anyChecked) allCb.checked = true;
        }
        applyFilters();
      });
    });
    applyFilters();
  });
</script>
