<!-- Movie Filter Page -->
<div class="bg-bgSubtle min-h-screen pb-16">

  <!-- Page Header -->
  <div class="bg-white border-b border-borderSubtle pt-24 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 class="text-3xl font-extrabold text-slate-800 flex items-center gap-3">
            <span class="w-1.5 h-8 bg-brand rounded-full"></span>
            Tất Cả Phim
          </h1>
          <p class="text-slate-500 mt-1 ml-5" id="result-count">Đang tải danh sách phim...</p>
        </div>
        <div class="flex items-center gap-2">
          <button id="view-grid" onclick="setView('grid')" class="view-btn p-2.5 rounded-lg bg-brand text-white shadow transition" title="Dạng lưới">
            <i class="fas fa-th-large text-sm"></i>
          </button>
          <button id="view-list" onclick="setView('list')" class="view-btn p-2.5 rounded-lg bg-slate-100 text-slate-500 hover:bg-slate-200 transition" title="Dạng danh sách">
            <i class="fas fa-list text-sm"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row gap-8">

      <!-- ===== SIDEBAR FILTERS ===== -->
      <aside class="lg:w-72 flex-shrink-0">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 sticky top-24">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
              <i class="fas fa-sliders-h text-brand text-sm"></i> Bộ Lọc
            </h2>
            <button onclick="resetFilters()" class="text-xs text-brand hover:text-red-700 font-semibold transition flex items-center gap-1">
              <i class="fas fa-redo text-[10px]"></i> Đặt lại
            </button>
          </div>

          <!-- Search -->
          <div class="mb-6">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Tìm kiếm</label>
            <div class="relative">
              <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i>
              <input
                id="search-input"
                type="text"
                placeholder="Tên phim..."
                oninput="applyFilters()"
                class="w-full border border-slate-200 bg-slate-50 rounded-xl pl-9 pr-4 py-2.5 text-sm text-slate-700 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition"
              >
            </div>
          </div>

          <!-- Genre Filter -->
          <div class="mb-6">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Thể Loại</label>
            <div class="space-y-2" id="genre-filters">
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="all" checked class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition font-medium">Tất cả</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Hành Động" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Hành Động</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Hài Hước" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Hài Hước</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Kinh Dị" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Kinh Dị</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Tâm Lý" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Tâm Lý</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Viễn Tưởng" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Viễn Tưởng</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Hoạt Hình" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Hoạt Hình</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="checkbox" value="Tình Cảm" class="genre-check w-4 h-4 accent-brand rounded">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Tình Cảm</span>
              </label>
            </div>
          </div>

          <!-- Format Filter -->
          <div class="mb-6">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Định Dạng</label>
            <div class="flex flex-wrap gap-2" id="format-filters">
              <button onclick="toggleFormat(this, 'all')" data-format="all" class="format-btn active px-3 py-1.5 rounded-lg text-xs font-bold border border-brand bg-brand text-white transition">Tất cả</button>
              <button onclick="toggleFormat(this, '2D')" data-format="2D" class="format-btn px-3 py-1.5 rounded-lg text-xs font-bold border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">2D</button>
              <button onclick="toggleFormat(this, '3D')" data-format="3D" class="format-btn px-3 py-1.5 rounded-lg text-xs font-bold border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">3D</button>
              <button onclick="toggleFormat(this, 'IMAX')" data-format="IMAX" class="format-btn px-3 py-1.5 rounded-lg text-xs font-bold border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">IMAX</button>
            </div>
          </div>

          <!-- Date Filter -->
          <div class="mb-6">
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Ngày Chiếu</label>
            <input
              id="date-filter"
              type="date"
              onchange="applyFilters()"
              class="w-full border border-slate-200 bg-slate-50 rounded-xl px-3 py-2.5 text-sm text-slate-700 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition"
            >
          </div>

          <!-- Status Filter -->
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Trạng Thái</label>
            <div class="space-y-2">
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="radio" name="status" value="all" checked onchange="applyFilters()" class="w-4 h-4 accent-brand">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Tất cả</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="radio" name="status" value="now_showing" onchange="applyFilters()" class="w-4 h-4 accent-brand">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Đang Chiếu</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer group">
                <input type="radio" name="status" value="coming_soon" onchange="applyFilters()" class="w-4 h-4 accent-brand">
                <span class="text-sm text-slate-600 group-hover:text-brand transition">Sắp Chiếu</span>
              </label>
            </div>
          </div>
        </div>
      </aside>

      <!-- ===== MOVIE LIST ===== -->
      <div class="flex-1">
        <!-- Movie Grid -->
        <div id="movie-container" class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-5">
          <!-- Populated by JS -->
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="hidden flex flex-col items-center justify-center py-24 text-center">
          <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mb-6">
            <i class="fas fa-film text-4xl text-slate-300"></i>
          </div>
          <h3 class="text-xl font-bold text-slate-700 mb-2">Không tìm thấy phim</h3>
          <p class="text-slate-400 mb-6 max-w-xs">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm để tìm phim phù hợp.</p>
          <button onclick="resetFilters()" class="bg-brand text-white px-6 py-2.5 rounded-xl font-bold hover:bg-red-700 transition shadow-md shadow-brand/20">
            <i class="fas fa-redo mr-2"></i> Đặt lại bộ lọc
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

