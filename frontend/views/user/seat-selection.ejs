<script>
(function () {
  const PRICE_NORMAL = 70000;
  const PRICE_VIP = 100000;
  const TOTAL_SECONDS = 10 * 60; // 10 minutes

  /* ── State ── */
  let selectedSeats = new Set();
  let secondsLeft = TOTAL_SECONDS;
  let timerInterval = null;
  let expired = false;

  /* ── DOM refs ── */
  const timerDisplay  = document.getElementById('timer-display');
  const timerBadge    = document.getElementById('timer-badge');
  const chipsContainer= document.getElementById('selected-chips');
  const noSeatsMsg    = document.getElementById('no-seats-msg');
  const totalPriceEl  = document.getElementById('total-price');
  const confirmBtn    = document.getElementById('confirm-btn');
  const overlay       = document.getElementById('timeout-overlay');
  const backBtn       = document.getElementById('timeout-back-btn');

  /* ─────────────────────────────────────────
     COUNTDOWN TIMER
  ───────────────────────────────────────── */
  function formatTime(secs) {
    const m = String(Math.floor(secs / 60)).padStart(2, '0');
    const s = String(secs % 60).padStart(2, '0');
    return m + ':' + s;
  }

  function updateTimerDisplay() {
    timerDisplay.textContent = formatTime(secondsLeft);

    // Turn badge more urgent in final 60 s
    if (secondsLeft <= 60) {
      timerBadge.classList.add('timer-urgent');
    }
  }

  function onExpire() {
    clearInterval(timerInterval);
    expired = true;

    // Lock all available seats
    document.querySelectorAll('.seat-available, .seat-selected, .seat-vip-available').forEach(btn => {
      btn.disabled = true;
      btn.style.cursor = 'not-allowed';
    });

    confirmBtn.disabled = true;
    overlay.classList.add('show');
  }

  timerInterval = setInterval(() => {
    secondsLeft--;
    updateTimerDisplay();
    if (secondsLeft <= 0) onExpire();
  }, 1000);

  updateTimerDisplay(); // immediate render

  /* ─────────────────────────────────────────
     SEAT TOGGLE LOGIC
  ───────────────────────────────────────── */
  function getSeatId(btn) {
    return btn.dataset.row + btn.dataset.col;
  }

  function getSeatLabel(btn) {
    return btn.dataset.row + btn.dataset.col;
  }

  function selectSeat(btn) {
    btn.classList.remove('seat-available', 'seat-vip-available');
    btn.classList.add('seat-selected');
    // Insert check icon SVG
    if (!btn.querySelector('svg')) {
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="seat-check" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
        style="display:block;width:14px;height:14px;color:#fff;position:absolute;inset:0;margin:auto;pointer-events:none;">
        <path d="M20 6 9 17l-5-5"/>
      </svg>`;
    }
  }

  function deselectSeat(btn) {
    btn.classList.remove('seat-selected');
    if (btn.dataset.type === 'vip') {
      btn.classList.add('seat-vip-available');
    } else {
      btn.classList.add('seat-available');
    }
    btn.innerHTML = '';
  }

  function toggleSeat(btn) {
    if (expired) return;
    if (btn.disabled) return;

    const id = getSeatId(btn);
    const limitWarning = document.getElementById('limit-warning');
    if (btn.classList.contains('seat-selected')) {
      deselectSeat(btn);
      selectedSeats.delete(id);
      if (limitWarning) {
        limitWarning.classList.add('hidden');
      }
    } else {
      // Check selection limit constraint (maximum 10 seats)
      if (selectedSeats.size >= 10) {
        if (limitWarning) {
          limitWarning.classList.remove('hidden');
        }
        return;
      }
      selectSeat(btn);
      selectedSeats.add(id);
      if (limitWarning) {
        limitWarning.classList.add('hidden');
      }
    }
    updateBottomBar();
  }

  /* ─────────────────────────────────────────
     BOTTOM BAR UPDATE
  ───────────────────────────────────────── */
  function updateBottomBar() {
    // Chips
    chipsContainer.innerHTML = '';

    if (selectedSeats.size === 0) {
      chipsContainer.appendChild(noSeatsMsg);
      noSeatsMsg.style.display = 'inline';
    } else {
      noSeatsMsg.style.display = 'none';
      // Sort seats alphabetically
      const sorted = Array.from(selectedSeats).sort();
      sorted.forEach(id => {
        const row = id.charAt(0);
        const col = id.substring(1);
        const btn = document.querySelector(`.seat[data-row="${row}"][data-col="${col}"]`);
        const type = btn ? btn.dataset.type : 'normal';

        const chip = document.createElement('div');
        chip.className = 'seat-chip';
        chip.textContent = id;
        if (type === 'vip') {
          chip.style.backgroundColor = '#fef3c7'; // amber-100
          chip.style.color = '#b45309'; // amber-700
          chip.style.border = '1px solid #f59e0b'; // amber-500
        } else {
          chip.style.backgroundColor = '#ffffff'; // white
          chip.style.color = '#27272a'; // zinc-800
          chip.style.border = '1px solid #a1a1aa'; // zinc-400
        }
        chipsContainer.appendChild(chip);
      });
    }

    // Pricing breakdown & total
    const pricingBreakdownEl = document.getElementById('pricing-breakdown');
    pricingBreakdownEl.innerHTML = '';

    let total = 0;
    
    if (selectedSeats.size > 0) {
      pricingBreakdownEl.classList.remove('hidden');
      
      const vipSeats = [];
      const normalSeats = [];
      
      selectedSeats.forEach(id => {
        const row = id.charAt(0);
        const col = id.substring(1);
        const btn = document.querySelector(`.seat[data-row="${row}"][data-col="${col}"]`);
        if (btn) {
          const lowerId = id.toLowerCase();
          if (btn.dataset.type === 'vip') {
            vipSeats.push(lowerId);
          } else {
            normalSeats.push(lowerId);
          }
        }
      });
      
      if (vipSeats.length > 0) {
        const vipCount = vipSeats.length;
        const vipTotal = vipCount * PRICE_VIP;
        total += vipTotal;
        
        const rowDiv = document.createElement('div');
        rowDiv.className = 'flex items-center justify-between py-1 font-medium';
        rowDiv.style.color = '#4b5563';
        
        // Left container (Badge + Count)
        const leftDiv = document.createElement('div');
        leftDiv.className = 'flex items-center gap-2';
        
        // VIP Badge Box
        const badge = document.createElement('span');
        badge.className = 'px-2 py-0.5 rounded text-[10px] font-bold border flex-shrink-0';
        badge.style.backgroundColor = '#fef3c7';
        badge.style.color = '#92400e';
        badge.style.borderColor = '#fcd34d';
        badge.textContent = 'VIP seat';
        
        // Count
        const countSpan = document.createElement('span');
        countSpan.textContent = `x${vipCount}`;
        
        leftDiv.appendChild(badge);
        leftDiv.appendChild(countSpan);
        
        // Right price (right aligned)
        const priceSpan = document.createElement('span');
        priceSpan.className = 'font-semibold text-right';
        priceSpan.textContent = `${vipTotal.toLocaleString('vi-VN')} đ`;
        
        rowDiv.appendChild(leftDiv);
        rowDiv.appendChild(priceSpan);
        
        pricingBreakdownEl.appendChild(rowDiv);
      }
      
      if (normalSeats.length > 0) {
        const normalCount = normalSeats.length;
        const normalTotal = normalCount * PRICE_NORMAL;
        total += normalTotal;
        
        const rowDiv = document.createElement('div');
        rowDiv.className = 'flex items-center justify-between py-1 font-medium';
        rowDiv.style.color = '#4b5563';
        
        // Left container (Badge + Count)
        const leftDiv = document.createElement('div');
        leftDiv.className = 'flex items-center gap-2';
        
        // Normal Badge Box
        const badge = document.createElement('span');
        badge.className = 'px-2 py-0.5 rounded text-[10px] font-bold border flex-shrink-0';
        badge.style.backgroundColor = '#f4f4f5';
        badge.style.color = '#27272a';
        badge.style.borderColor = '#e4e4e7';
        badge.textContent = 'Normal seat';
        
        // Count
        const countSpan = document.createElement('span');
        countSpan.textContent = `x${normalCount}`;
        
        leftDiv.appendChild(badge);
        leftDiv.appendChild(countSpan);
        
        // Right price (right aligned)
        const priceSpan = document.createElement('span');
        priceSpan.className = 'font-semibold text-right';
        priceSpan.textContent = `${normalTotal.toLocaleString('vi-VN')} đ`;
        
        rowDiv.appendChild(leftDiv);
        rowDiv.appendChild(priceSpan);
        
        pricingBreakdownEl.appendChild(rowDiv);
      }
    } else {
      pricingBreakdownEl.classList.add('hidden');
    }

    // Price
    totalPriceEl.textContent = total.toLocaleString('vi-VN') + 'đ';

    // Confirm button
    confirmBtn.disabled = selectedSeats.size === 0;
  }

  /* ─────────────────────────────────────────
     ATTACH SEAT CLICK LISTENERS
  ───────────────────────────────────────── */
  document.querySelectorAll('.seat').forEach(btn => {
    // Only available seats get the listener (sold seats have disabled attr)
    if (!btn.disabled) {
      btn.addEventListener('click', () => toggleSeat(btn));
    }
  });

  /* ─────────────────────────────────────────
     TIMEOUT MODAL — BACK BUTTON
  ───────────────────────────────────────── */
  backBtn.addEventListener('click', () => {
    window.location.href = '/';
  });

  /* ─────────────────────────────────────────
     CONFIRM BUTTON — show loading screen
  ───────────────────────────────────────── */
  const loadingOverlay = document.getElementById('loading-overlay');

  confirmBtn.addEventListener('click', () => {
    if (selectedSeats.size === 0 || selectedSeats.size > 10 || expired) return;

    // Stop the booking timer so it doesn't fire while loading
    clearInterval(timerInterval);

    // Lock seats and button to prevent double-clicks
    confirmBtn.disabled = true;
    document.querySelectorAll('.seat').forEach(b => b.disabled = true);

    // Show the loading overlay
    loadingOverlay.classList.add('show');

    // Calculate total price
    let total = 0;
    selectedSeats.forEach(id => {
      const row = id.charAt(0);
      const col = id.substring(1);
      const btn = document.querySelector(`.seat[data-row="${row}"][data-col="${col}"]`);
      if (btn) {
        if (btn.dataset.type === 'vip') {
          total += PRICE_VIP;
        } else {
          total += PRICE_NORMAL;
        }
      }
    });

    // Simulate redirect after ~3 s to checkout with dynamic parameters
    setTimeout(() => {
      const seats = Array.from(selectedSeats).sort().join(',');
      const bookingId = 'BK-' + Math.floor(Math.random() * 1000000);
      // Let's assume the user is booking "Kung Fu Panda 4" (you can parameterize this as well if needed)
      window.location.href = `/checkout/${bookingId}?seats=${encodeURIComponent(seats)}&price=${total}&title=Kung+Fu+Panda+4`;
    }, 3000);
  });

  /* ─────────────────────────────────────────
     BACK BUTTON PROTECTION (pageshow handler)
     ───────────────────────────────────────── */
  window.addEventListener('pageshow', (event) => {
    // Hide the loading overlay and restore confirm button & seats state
    loadingOverlay.classList.remove('show');
    confirmBtn.disabled = selectedSeats.size === 0;
    document.querySelectorAll('.seat').forEach(b => {
      if (!b.classList.contains('seat-sold')) {
        b.disabled = false;
        b.style.cursor = '';
      }
    });
    // Restart timer interval if it was stopped
    if (!expired && !timerInterval) {
      timerInterval = setInterval(() => {
        secondsLeft--;
        updateTimerDisplay();
        if (secondsLeft <= 0) onExpire();
      }, 1000);
    }
  });
})();
</script>
