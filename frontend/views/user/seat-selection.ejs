    <div class="progress-fill"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════
     MAIN LAYOUT
═══════════════════════════════════════════ -->
<div class="size-full bg-zinc-50 text-zinc-900 flex flex-col overflow-hidden min-h-screen pt-20">

  <!-- Header -->
  <div class="px-5 py-4 bg-white border-b border-zinc-200 sticky top-20 z-40">
    <div class="flex items-center justify-between">
      <h2 class="font-semibold text-lg text-zinc-900">Chọn Ghế Ngồi</h2>
      <!-- Timer badge -->
      <div id="timer-badge" class="flex items-center gap-2 px-3 py-1.5 bg-red-50 border border-red-200 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="text-red-600">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <span id="timer-display" class="text-sm font-mono text-red-600">10:00</span>
      </div>
    </div>
  </div>

  <!-- Scrollable content -->
  <div class="flex-1 overflow-y-auto px-5 py-6 pb-44">

    <!-- Screen graphic -->
    <div class="mb-8 max-w-md mx-auto">
      <div class="relative h-3 bg-gradient-to-b from-zinc-300 to-zinc-400 rounded-t-[100%] shadow-[0_5px_30px_rgba(0,0,0,0.15)]"></div>
      <div class="text-center mt-2 text-xs text-zinc-500 uppercase tracking-widest">Màn hình</div>
    </div>

    <!-- Legend -->
    <div class="flex items-center justify-center flex-wrap gap-4 sm:gap-6 mb-6">
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 seat-available rounded"></div>
        <span class="text-xs text-zinc-600 font-semibold">Ghế thường</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 seat-vip-available rounded"></div>
        <span class="text-xs text-zinc-600 font-semibold">Ghế VIP</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 seat-selected rounded text-white flex items-center justify-center text-[10px]">
          <i class="fas fa-check"></i>
        </div>
        <span class="text-xs text-zinc-600 font-semibold">Đang chọn</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 seat-sold rounded"></div>
        <span class="text-xs text-zinc-600 font-semibold">Đã bán</span>
      </div>
    </div>

    <!-- Seat grid (Dynamic) -->
    <div id="seat-grid" class="max-w-md mx-auto space-y-2">
      <div class="text-center text-sm text-zinc-500 py-10" id="seat-loading">Đang tải sơ đồ ghế...</div>
    </div><!-- /seat-grid -->
  </div>

  <!-- ── Bottom booking bar ── -->
  <div class="absolute bottom-0 left-0 right-0 bg-white border-t border-zinc-200 shadow-[0_-10px_40px_rgba(0,0,0,0.1)] z-50">
    <div class="px-5 py-4 max-w-md mx-auto">
      <!-- Warning message row -->
      <div id="limit-warning" class="hidden mb-3 text-xs font-semibold text-red-600 bg-red-50 border border-red-200 rounded-lg p-2.5 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span>Bạn chỉ được phép chọn tối đa 10 ghế cho mỗi lần đặt vé.</span>
      </div>
      <div class="mb-3">
        <div class="text-xs text-zinc-500 mb-1">Ghế đã chọn</div>
        <div id="selected-chips" class="flex flex-wrap gap-2 min-h-[28px]">
          <span id="no-seats-msg" class="text-xs text-zinc-400 italic">Chưa có ghế nào được chọn</span>
        </div>
      </div>
      <!-- Pricing Breakdown Panel -->
      <div id="pricing-breakdown" class="mb-3 text-xs space-y-1 hidden font-medium" style="color: #4b5563;"></div>
      <div class="flex items-center gap-3">
        <div class="flex-1">
          <div class="text-xs text-zinc-500">Tổng tiền</div>
          <div id="total-price" class="text-2xl font-semibold text-zinc-900">0đ</div>
        </div>
        <button id="confirm-btn"
          class="px-8 py-3.5 bg-blue-600 hover:bg-blue-500 active:scale-95 rounded-lg font-semibold text-white transition-all disabled:opacity-40 disabled:cursor-not-allowed disabled:scale-100"
          disabled>
          Xác nhận đặt vé
        </button>
      </div>
    </div>
  </div>

</div><!-- /main layout -->

<script>
(function () {
  const showtimeId = parseInt('<%= showtimeId %>');
  const API_BASE_URL = 'http://localhost:8000';
  
  const PRICE_NORMAL = 70000;
  const PRICE_VIP = 100000;
  const TOTAL_SECONDS = 10 * 60; // 10 minutes

  /* ── State ── */
  let selectedSeats = new Map(); // seat_id -> {label, type, element}
  let secondsLeft = TOTAL_SECONDS;
  let timerInterval = null;
  let expired = false;

  /* ── DOM refs ── */
  const timerDisplay  = document.getElementById('timer-display');
  const timerBadge    = document.getElementById('timer-badge');
  const chipsContainer= document.getElementById('selected-chips');
  const noSeatsMsg    = document.getElementById('no-seats-msg');
  const totalPriceEl  = document.getElementById('total-price');
  const confirmBtn    = document.getElementById('confirm-btn');
  const overlay       = document.getElementById('timeout-overlay');
  const backBtn       = document.getElementById('timeout-back-btn');
  const gridEl        = document.getElementById('seat-grid');

  /* ─────────────────────────────────────────
     FETCH SEATS FROM BACKEND
  ───────────────────────────────────────── */
  async function loadSeats() {
    try {
      const res = await fetch(`${API_BASE_URL}/seats/${showtimeId}`);
      if (!res.ok) throw new Error('Cannot fetch seats');
      const seats = await res.json();
      renderSeats(seats);
    } catch (err) {
      console.error(err);
      gridEl.innerHTML = '<div class="text-center text-red-500 py-10">Lỗi tải sơ đồ ghế.</div>';
    }
  }

  function renderSeats(seats) {
    gridEl.innerHTML = '';
    
    // Group by row
    const rows = {};
    seats.forEach(s => {
      if (!rows[s.seat_row]) rows[s.seat_row] = [];
      rows[s.seat_row].push(s);
    });
    
    // Sort rows (A to H)
    const sortedRowKeys = Object.keys(rows).sort();
    
    sortedRowKeys.forEach(rowKey => {
      const rowSeats = rows[rowKey].sort((a,b) => a.seat_num - b.seat_num);
      
      const rowDiv = document.createElement('div');
      rowDiv.className = 'flex items-center gap-2';
      
      const rowLabel = document.createElement('div');
      rowLabel.className = 'w-6 text-center text-xs text-zinc-500 font-medium';
      rowLabel.textContent = rowKey;
      rowDiv.appendChild(rowLabel);
      
      const flexDiv = document.createElement('div');
      flexDiv.className = 'flex-1 flex justify-center gap-1.5';
      
      rowSeats.forEach(s => {
        const btn = document.createElement('button');
        btn.dataset.id = s.seat_id;
        btn.dataset.label = s.seat_row + s.seat_num;
        btn.dataset.type = s.seat_type.toLowerCase() === 'vip' ? 'vip' : 'normal';
        
        let statusClass = '';
        if (s.status !== 'Available') {
          statusClass = 'seat-sold';
          btn.disabled = true;
        } else {
          statusClass = btn.dataset.type === 'vip' ? 'seat-vip-available' : 'seat-available';
          btn.addEventListener('click', () => toggleSeat(btn));
        }
        
        btn.className = `seat w-7 h-7 rounded ${statusClass}`;
        flexDiv.appendChild(btn);
      });
      
      rowDiv.appendChild(flexDiv);
      
      const rightSpacer = document.createElement('div');
      rightSpacer.className = 'w-6';
      rowDiv.appendChild(rightSpacer);
      
      gridEl.appendChild(rowDiv);
    });
  }

  /* ─────────────────────────────────────────
     COUNTDOWN TIMER
  ───────────────────────────────────────── */
  function formatTime(secs) {
    const m = String(Math.floor(secs / 60)).padStart(2, '0');
    const s = String(secs % 60).padStart(2, '0');
    return m + ':' + s;
  }

  function updateTimerDisplay() {
    timerDisplay.textContent = formatTime(secondsLeft);
    if (secondsLeft <= 60) {
      timerBadge.classList.add('timer-urgent');
    }
  }

  function onExpire() {
    clearInterval(timerInterval);
    expired = true;
    document.querySelectorAll('.seat-available, .seat-selected, .seat-vip-available').forEach(btn => {
      btn.disabled = true;
      btn.style.cursor = 'not-allowed';
    });
    confirmBtn.disabled = true;
    overlay.classList.add('show');
  }

  timerInterval = setInterval(() => {
    secondsLeft--;
    updateTimerDisplay();
    if (secondsLeft <= 0) onExpire();
  }, 1000);

  updateTimerDisplay();

  /* ─────────────────────────────────────────
     SEAT TOGGLE LOGIC
  ───────────────────────────────────────── */
  function selectSeat(btn) {
    btn.classList.remove('seat-available', 'seat-vip-available');
    btn.classList.add('seat-selected');
    if (!btn.querySelector('svg')) {
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="seat-check" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
        style="display:block;width:14px;height:14px;color:#fff;position:absolute;inset:0;margin:auto;pointer-events:none;">
        <path d="M20 6 9 17l-5-5"/>
      </svg>`;
    }
  }

  function deselectSeat(btn) {
    btn.classList.remove('seat-selected');
    if (btn.dataset.type === 'vip') {
      btn.classList.add('seat-vip-available');
    } else {
      btn.classList.add('seat-available');
    }
    btn.innerHTML = '';
  }

  function toggleSeat(btn) {
    if (expired || btn.disabled) return;

    const id = parseInt(btn.dataset.id);
    const limitWarning = document.getElementById('limit-warning');
    
    if (btn.classList.contains('seat-selected')) {
      deselectSeat(btn);
      selectedSeats.delete(id);
      if (limitWarning) limitWarning.classList.add('hidden');
    } else {
      if (selectedSeats.size >= 10) {
        if (limitWarning) limitWarning.classList.remove('hidden');
        return;
      }
      selectSeat(btn);
      selectedSeats.set(id, {
        label: btn.dataset.label,
        type: btn.dataset.type
      });
      if (limitWarning) limitWarning.classList.add('hidden');
    }
    updateBottomBar();
  }

  /* ─────────────────────────────────────────
     BOTTOM BAR UPDATE
  ───────────────────────────────────────── */
  function updateBottomBar() {
    chipsContainer.innerHTML = '';

    if (selectedSeats.size === 0) {
      chipsContainer.appendChild(noSeatsMsg);
      noSeatsMsg.style.display = 'inline';
    } else {
      noSeatsMsg.style.display = 'none';
      const sorted = Array.from(selectedSeats.values()).sort((a,b) => a.label.localeCompare(b.label));
      sorted.forEach(seat => {
        const chip = document.createElement('div');
        chip.className = 'seat-chip';
        chip.textContent = seat.label;
        if (seat.type === 'vip') {
          chip.style.backgroundColor = '#fef3c7';
          chip.style.color = '#b45309';
          chip.style.border = '1px solid #f59e0b';
        } else {
          chip.style.backgroundColor = '#ffffff';
          chip.style.color = '#27272a';
          chip.style.border = '1px solid #a1a1aa';
        }
        chipsContainer.appendChild(chip);
      });
    }

    const pricingBreakdownEl = document.getElementById('pricing-breakdown');
    pricingBreakdownEl.innerHTML = '';

    let total = 0;
    
    if (selectedSeats.size > 0) {
      pricingBreakdownEl.classList.remove('hidden');
      
      let vipCount = 0;
      let normalCount = 0;
      
      selectedSeats.forEach(seat => {
        if (seat.type === 'vip') vipCount++;
        else normalCount++;
      });
      
      if (vipCount > 0) {
        const vipTotal = vipCount * PRICE_VIP;
        total += vipTotal;
        
        const rowDiv = document.createElement('div');
        rowDiv.className = 'flex items-center justify-between py-1 font-medium';
        rowDiv.style.color = '#4b5563';
        
        const leftDiv = document.createElement('div');
        leftDiv.className = 'flex items-center gap-2';
        
        const badge = document.createElement('span');
        badge.className = 'px-2 py-0.5 rounded text-[10px] font-bold border flex-shrink-0';
        badge.style.backgroundColor = '#fef3c7';
        badge.style.color = '#92400e';
        badge.style.borderColor = '#fcd34d';
        badge.textContent = 'VIP seat';
        
        const countSpan = document.createElement('span');
        countSpan.textContent = `x${vipCount}`;
        
        leftDiv.appendChild(badge);
        leftDiv.appendChild(countSpan);
        
        const priceSpan = document.createElement('span');
        priceSpan.className = 'font-semibold text-right';
        priceSpan.textContent = `${vipTotal.toLocaleString('vi-VN')} đ`;
        
        rowDiv.appendChild(leftDiv);
        rowDiv.appendChild(priceSpan);
        pricingBreakdownEl.appendChild(rowDiv);
      }
      
      if (normalCount > 0) {
        const normalTotal = normalCount * PRICE_NORMAL;
        total += normalTotal;
        
        const rowDiv = document.createElement('div');
        rowDiv.className = 'flex items-center justify-between py-1 font-medium';
        rowDiv.style.color = '#4b5563';
        
        const leftDiv = document.createElement('div');
        leftDiv.className = 'flex items-center gap-2';
        
        const badge = document.createElement('span');
        badge.className = 'px-2 py-0.5 rounded text-[10px] font-bold border flex-shrink-0';
        badge.style.backgroundColor = '#f4f4f5';
        badge.style.color = '#27272a';
        badge.style.borderColor = '#e4e4e7';
        badge.textContent = 'Normal seat';
        
        const countSpan = document.createElement('span');
        countSpan.textContent = `x${normalCount}`;
        
        leftDiv.appendChild(badge);
        leftDiv.appendChild(countSpan);
        
        const priceSpan = document.createElement('span');
        priceSpan.className = 'font-semibold text-right';
        priceSpan.textContent = `${normalTotal.toLocaleString('vi-VN')} đ`;
        
        rowDiv.appendChild(leftDiv);
        rowDiv.appendChild(priceSpan);
        pricingBreakdownEl.appendChild(rowDiv);
      }
    } else {
      pricingBreakdownEl.classList.add('hidden');
    }

    totalPriceEl.textContent = total.toLocaleString('vi-VN') + 'đ';
    confirmBtn.disabled = selectedSeats.size === 0;
  }

  backBtn.addEventListener('click', () => {
    window.location.href = '/';
  });

  const loadingOverlay = document.getElementById('loading-overlay');

  confirmBtn.addEventListener('click', async () => {
    if (selectedSeats.size === 0 || selectedSeats.size > 10 || expired) return;
    
    const token = localStorage.getItem('access_token');
    if (!token) {
        alert("Vui lòng đăng nhập để đặt vé!");
        // Simulate clicking the login button on navbar if it exists
        const loginBtn = document.querySelector('[data-modal-target="authModal"]');
        if (loginBtn) loginBtn.click();
        return;
    }

    clearInterval(timerInterval);
    confirmBtn.disabled = true;
    document.querySelectorAll('.seat').forEach(b => b.disabled = true);
    loadingOverlay.classList.add('show');

    try {
        const seatIds = Array.from(selectedSeats.keys());
        
        // 1. Hold seats
        const holdRes = await fetch(`${API_BASE_URL}/seats/hold`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
                showtime_id: showtimeId,
                seat_ids: seatIds
            })
        });
        
        if (!holdRes.ok) {
            const data = await holdRes.json();
            throw new Error(data.detail || 'Không thể giữ ghế, vui lòng thử lại.');
        }

        // 2. Reserve booking
        const reserveRes = await fetch(`${API_BASE_URL}/bookings/reserve`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
                showtime_id: showtimeId,
                seat_ids: seatIds
            })
        });
        
        if (!reserveRes.ok) {
            const data = await reserveRes.json();
            throw new Error(data.detail || 'Lỗi khi tạo đơn hàng.');
        }
        
        const bookingData = await reserveRes.json();
        
        // Redirect to checkout
        setTimeout(() => {
            window.location.href = `/checkout/${bookingData.booking_id}`;
        }, 1000);
        
    } catch (err) {
        loadingOverlay.classList.remove('show');
        confirmBtn.disabled = false;
        document.querySelectorAll('.seat').forEach(b => {
          if (!b.classList.contains('seat-sold')) b.disabled = false;
        });
        alert(err.message);
        
        // Restart timer
        timerInterval = setInterval(() => {
            secondsLeft--;
            updateTimerDisplay();
            if (secondsLeft <= 0) onExpire();
        }, 1000);
    }
  });

  window.addEventListener('pageshow', () => {
    loadingOverlay.classList.remove('show');
    confirmBtn.disabled = selectedSeats.size === 0;
    if (!expired && !timerInterval) {
      timerInterval = setInterval(() => {
        secondsLeft--;
        updateTimerDisplay();
        if (secondsLeft <= 0) onExpire();
      }, 1000);
    }
  });

  // Init
  loadSeats();
})();
</script>
