<style>
  /* ── Seat states ── */
  .seat-available {
    background: #fff;
    border: 2px solid #a1a1aa;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .seat-available:hover {
    border-color: #3b82f6;
    background: #eff6ff;
    transform: scale(1.1);
  }
  .seat-vip-available {
    background: #fef3c7; /* amber-100 */
    border: 2px solid #f59e0b; /* amber-500 */
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .seat-vip-available:hover {
    border-color: #d97706; /* amber-600 */
    background: #fffbeb; /* amber-50 */
    transform: scale(1.1);
  }
  .seat-selected {
    background: #2563eb;
    border: 2px solid #1d4ed8;
    cursor: pointer;
    position: relative;
    transition: all 0.15s ease;
  }
  .seat-selected:hover {
    background: #1d4ed8;
    transform: scale(1.1);
  }
  .seat-sold {
    background: #d4d4d8;
    border: 2px solid transparent;
    cursor: not-allowed;
    opacity: 0.5;
  }

  /* ── Timer urgency pulse ── */
  @keyframes pulse-red {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  .timer-urgent {
    animation: pulse-red 0.8s ease-in-out infinite;
  }

  /* ── Timeout modal ── */
  #timeout-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    z-index: 999;
    align-items: center;
    justify-content: center;
  }
  #timeout-overlay.show {
    display: flex;
  }
  #timeout-box {
    background: #fff;
    border-radius: 1.25rem;
    padding: 2rem 2.5rem;
    max-width: 340px;
    width: 90%;
    text-align: center;
    box-shadow: 0 25px 60px rgba(0,0,0,0.25);
    animation: pop-in 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes pop-in {
    from { transform: scale(0.7); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }

  /* ── Selected seat chip ── */
  .seat-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 10px;
    background: #e4e4e7;
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #18181b;
  }

  /* ── Check icon inside seat ── */
  .seat-check {
    display: none;
    position: absolute;
    inset: 0;
    margin: auto;
    width: 14px;
    height: 14px;
    color: #fff;
    pointer-events: none;
  }
  .seat-selected .seat-check {
    display: block;
  }

  /* ── Loading overlay ── */
  #loading-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 15, 30, 0.75);
    backdrop-filter: blur(8px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1.5rem;
  }
  #loading-overlay.show {
    display: flex;
    animation: fade-in 0.3s ease both;
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Spinning ring */
  .spinner {
    width: 64px;
    height: 64px;
    border: 4px solid rgba(255,255,255,0.15);
    border-top-color: #3b82f6;
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Animated dots after text */
  .loading-dots::after {
    content: '';
    animation: dots 1.4s steps(4, end) infinite;
  }
  @keyframes dots {
    0%   { content: ''; }
    25%  { content: '.'; }
    50%  { content: '..'; }
    75%  { content: '...'; }
    100% { content: ''; }
  }

  /* Shimmer progress bar */
  .progress-track {
    width: 220px;
    height: 4px;
    background: rgba(255,255,255,0.12);
    border-radius: 99px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #3b82f6, #60a5fa);
    border-radius: 99px;
    animation: fill-bar 2.8s cubic-bezier(0.4,0,0.2,1) forwards;
  }
  @keyframes fill-bar {
    0%   { width: 0%; }
    60%  { width: 75%; }
    85%  { width: 88%; }
    100% { width: 95%; }
  }
</style>

