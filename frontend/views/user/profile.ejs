<style>
  /* Spinner Ring */
  .spinner {
    width: 64px;
    height: 64px;
    border: 4px solid rgba(255, 255, 255, 0.15);
    border-top-color: #3b82f6; /* premium blue color */
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Animated loading ellipsis dots */
  .loading-dots::after {
    content: '';
    animation: dots 1.4s steps(4, end) infinite;
  }
  @keyframes dots {
    0%   { content: ''; }
    25%  { content: '.'; }
    50%  { content: '..'; }
    75%  { content: '...'; }
    100% { content: ''; }
  }

  /* Shimmer progress bar track */
  .progress-track {
    width: 220px;
    height: 4px;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 99px;
    overflow: hidden;
  }
  
  /* Shimmer fill animation on confirm redirect */
  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #3b82f6, #60a5fa);
    border-radius: 99px;
  }
  .progress-fill.active {
    animation: fill-bar 2.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes fill-bar {
    0%   { width: 0%; }
    60%  { width: 75%; }
    85%  { width: 88%; }
    100% { width: 100%; }
  }

  /* Toast Show Class */
  .toast-visible {
    transform: translateY(0) !important;
    opacity: 1 !important;
  }

  /* Profile update pulse transition */
  .profile-fade {
    animation: pulse-update 0.5s ease-out;
  }
  @keyframes pulse-update {
    0% { opacity: 0.5; transform: scale(0.97); }
    100% { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  /* ─────────────────────────────────────────
     QR DETAIL MODAL HANDLERS
     ───────────────────────────────────────── */
  const qrModal = document.getElementById('qrModal');
  const qrModalContent = document.getElementById('qrModalContent');

  function openQrModal() {
    qrModal.classList.remove('hidden');
    qrModal.classList.add('flex');
    
    // Smooth fade & scale pop-in
    setTimeout(() => {
      qrModalContent.classList.remove('scale-95', 'opacity-0');
      qrModalContent.classList.add('scale-100', 'opacity-100');
    }, 10);
  }

  function closeQrModal() {
    qrModalContent.classList.remove('scale-100', 'opacity-100');
    qrModalContent.classList.add('scale-95', 'opacity-0');
    
    setTimeout(() => {
      qrModal.classList.add('hidden');
      qrModal.classList.remove('flex');
    }, 300);
  }

  /* ─────────────────────────────────────────
     PAYMENT LOADING TRANSITION
     ───────────────────────────────────────── */
  const payNowBtn = document.getElementById('pay-now-btn');
  const loadingOverlay = document.getElementById('loading-overlay');
  const progressFill = document.querySelector('.progress-fill');

  payNowBtn.addEventListener('click', function() {
    // 1. Show the beautiful loading overlay
    loadingOverlay.classList.remove('hidden');
    loadingOverlay.classList.add('flex');
    
    // 2. Start progress bar fill animation
    progressFill.classList.add('active');

    // 3. Disable button to prevent double submits
    payNowBtn.disabled = true;

    // 4. Simulate a premium payment route transition delay (~2.8s)
    setTimeout(() => {
      // Dynamic booking params mapping to seat selection / checkout setup
      const bookingId = 'BK-164592';
      const seats = 'F5,F10';
      const price = '170000';
      const title = 'Kung Fu Panda 4';
      
      // Redirect directly to the checkout route as done in seat-selection.ejs
      window.location.href = `/checkout/${bookingId}?seats=${encodeURIComponent(seats)}&price=${price}&title=${encodeURIComponent(title)}`;
    }, 2800);
  });

  /* ─────────────────────────────────────────
     BACK BUTTON PROTECTION (pageshow handler)
     ───────────────────────────────────────── */
  // Resets the loading state if the user returns via browser Back button
  window.addEventListener('pageshow', function(event) {
    loadingOverlay.classList.add('hidden');
    loadingOverlay.classList.remove('flex');
    progressFill.classList.remove('active');
    payNowBtn.disabled = false;
  });

  /* ─────────────────────────────────────────
     PROFILE EDIT MODAL HANDLERS
     ───────────────────────────────────────── */
  const editModal = document.getElementById('editProfileModal');
  const editModalContent = document.getElementById('editModalContent');
  const editForm = document.getElementById('editProfileForm');
  
  const profileName = document.getElementById('profile-name');
  const profilePhone = document.getElementById('profile-phone');
  const profileEmail = document.getElementById('profile-email');

  const editFullnameInput = document.getElementById('edit-fullname');
  const editPhoneInput = document.getElementById('edit-phone');
  const editEmailInput = document.getElementById('edit-email');

  const errFullname = document.getElementById('error-fullname');
  const errPhone = document.getElementById('error-phone');
  const errEmail = document.getElementById('error-email');

  // Load stored profile data on page load
  document.addEventListener('DOMContentLoaded', async () => {
    const token = localStorage.getItem('access_token');
    if (!token) {
      // Redirect to home if not logged in
      window.location.href = '/';
      return;
    }

    try {
      const response = await fetch('http://localhost:8000/user/profile', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (response.ok) {
        const data = await response.json();
        profileName.textContent = data.full_name;
        profilePhone.textContent = data.phone || 'Chưa cập nhật';
        profileEmail.textContent = data.email;
        // Save back to localStorage for consistency
        localStorage.setItem('user', JSON.stringify(data));
      } else {
        // Token might be expired or invalid
        localStorage.removeItem('access_token');
        localStorage.removeItem('user');
        window.location.href = '/';
      }
    } catch (error) {
      console.error('Lỗi khi tải profile:', error);
    }
  });

  function openEditModal() {
    // 1. Pre-fill input fields with current text content
    editFullnameInput.value = profileName.textContent.trim();
    editPhoneInput.value = profilePhone.textContent.trim();
    editEmailInput.value = profileEmail.textContent.trim();

    // 2. Reset previous error states
    hideError(editFullnameInput, errFullname);
    hideError(editPhoneInput, errPhone);
    hideError(editEmailInput, errEmail);

    // 3. Show Modal
    editModal.classList.remove('hidden');
    editModal.classList.add('flex');

    // 4. Smooth scale and fade in
    setTimeout(() => {
      editModalContent.classList.remove('scale-95', 'opacity-0');
      editModalContent.classList.add('scale-100', 'opacity-100');
    }, 10);
  }

  function closeEditModal() {
    // 1. Smooth fade out and scale down
    editModalContent.classList.remove('scale-100', 'opacity-100');
    editModalContent.classList.add('scale-95', 'opacity-0');

    // 2. Hide container completely after animation duration
    setTimeout(() => {
      editModal.classList.add('hidden');
      editModal.classList.remove('flex');
    }, 300);
  }

  function showError(input, errorEl, message) {
    input.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
    input.classList.remove('border-zinc-200', 'focus:border-brand', 'focus:ring-brand');
    errorEl.textContent = message;
    errorEl.classList.remove('hidden');
  }

  function hideError(input, errorEl) {
    input.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
    input.classList.add('border-zinc-200', 'focus:border-brand', 'focus:ring-brand');
    errorEl.classList.add('hidden');
    errorEl.textContent = '';
  }

  async function saveProfile(event) {
    event.preventDefault();

    const nameVal = editFullnameInput.value.trim();
    const phoneVal = editPhoneInput.value.trim();
    
    let hasError = false;

    // 1. Validation: Fullname
    if (!nameVal) {
      showError(editFullnameInput, errFullname, 'Họ và tên không được để trống.');
      hasError = true;
    } else {
      hideError(editFullnameInput, errFullname);
    }

    // 2. Validation: Phone
    const phoneRegex = /^[0-9+() .\s-x]{9,20}$/;
    if (phoneVal && !phoneRegex.test(phoneVal)) {
      showError(editPhoneInput, errPhone, 'Số điện thoại không hợp lệ.');
      hasError = true;
    } else {
      hideError(editPhoneInput, errPhone);
    }

    if (hasError) return;

    // 3. Save to Backend
    const token = localStorage.getItem('access_token');
    try {
      const response = await fetch('http://localhost:8000/user/profile', {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
          full_name: nameVal,
          phone: phoneVal || null
        })
      });

      if (response.ok) {
        const data = await response.json();
        
        // Update UI with fade animation
        const fieldsToAnimate = [profileName, profilePhone];
        fieldsToAnimate.forEach(el => el.classList.add('profile-fade'));

        profileName.textContent = data.full_name;
        profilePhone.textContent = data.phone || 'Chưa cập nhật';
        localStorage.setItem('user', JSON.stringify(data));

        // Clean up animation class
        setTimeout(() => {
          fieldsToAnimate.forEach(el => el.classList.remove('profile-fade'));
        }, 500);

        // 6. Close Modal
        closeEditModal();

        // 7. Show Toast Alert
        showToast('Cập nhật hồ sơ cá nhân thành công!');
      } else {
        const err = await response.json();
        showToast(err.detail || 'Lỗi khi cập nhật hồ sơ');
      }
    } catch (error) {
      console.error('Lỗi khi cập nhật:', error);
      showToast('Lỗi kết nối máy chủ');
    }
  }

  function showToast(message) {
    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toast-message');
    
    toastMsg.textContent = message;
    toast.classList.add('toast-visible');
    
    setTimeout(() => {
      toast.classList.remove('toast-visible');
    }, 3000);
  }
</script>
