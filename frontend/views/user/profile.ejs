<!-- ═══════════════════════════════════════════
     TOAST NOTIFICATION
     ═══════════════════════════════════════════ -->
<div id="toast" class="fixed top-6 right-6 z-[1100] transform translate-y-[-100px] opacity-0 transition-all duration-300 pointer-events-none flex items-center gap-3 bg-zinc-900 text-white px-5 py-4 rounded-2xl shadow-xl border border-zinc-800">
  <div class="w-8 h-8 bg-green-500/25 border border-green-500/30 rounded-full flex items-center justify-center text-green-400 flex-shrink-0">
    <i class="fas fa-check text-sm"></i>
  </div>
  <div>
    <p class="font-bold text-sm text-white">Thành công</p>
    <p class="text-xs text-zinc-400" id="toast-message">Cập nhật hồ sơ cá nhân thành công!</p>
  </div>
</div>

<style>
  /* Spinner Ring */
  .spinner {
    width: 64px;
    height: 64px;
    border: 4px solid rgba(255, 255, 255, 0.15);
    border-top-color: #3b82f6; /* premium blue color */
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Animated loading ellipsis dots */
  .loading-dots::after {
    content: '';
    animation: dots 1.4s steps(4, end) infinite;
  }
  @keyframes dots {
    0%   { content: ''; }
    25%  { content: '.'; }
    50%  { content: '..'; }
    75%  { content: '...'; }
    100% { content: ''; }
  }

  /* Shimmer progress bar track */
  .progress-track {
    width: 220px;
    height: 4px;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 99px;
    overflow: hidden;
  }
  
  /* Shimmer fill animation on confirm redirect */
  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #3b82f6, #60a5fa);
    border-radius: 99px;
  }
  .progress-fill.active {
    animation: fill-bar 2.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes fill-bar {
    0%   { width: 0%; }
    60%  { width: 75%; }
    85%  { width: 88%; }
    100% { width: 100%; }
  }

  /* Toast Show Class */
  .toast-visible {
    transform: translateY(0) !important;
    opacity: 1 !important;
  }

  /* Profile update pulse transition */
  .profile-fade {
    animation: pulse-update 0.5s ease-out;
  }
  @keyframes pulse-update {
    0% { opacity: 0.5; transform: scale(0.97); }
    100% { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  /* ─────────────────────────────────────────
     QR DETAIL MODAL HANDLERS
     ───────────────────────────────────────── */
  const qrModal = document.getElementById('qrModal');
  const qrModalContent = document.getElementById('qrModalContent');

  function openQrModal(bookingId) {
    const bk = (window.bookingDataMap || {})[bookingId];
    if (!bk) return;

    const d = new Date(bk.showtime_start);
    const timeStr = d.toLocaleTimeString('vi-VN', {hour:'2-digit', minute:'2-digit'}) + ' | ' + d.toLocaleDateString('vi-VN');

    // Fill modal metadata
    document.getElementById('modal-movie').textContent = bk.movie_title;
    document.getElementById('modal-room').textContent = bk.room_name;
    document.getElementById('modal-time').textContent = timeStr;

    // Seats badges
    const seatsEl = document.getElementById('modal-seats');
    seatsEl.innerHTML = bk.seats.map(s => {
      const row = s.charAt(0); const col = parseInt(s.substring(1));
      const isVip = ['D','E','F','G'].includes(row) && [3,4,5,6].includes(col);
      const bg = isVip ? '#fef3c7' : '#ffffff';
      const color = isVip ? '#b45309' : '#27272a';
      const border = isVip ? '#f59e0b' : '#a1a1aa';
      return `<span class="px-2.5 py-0.5 text-xs font-semibold rounded border" style="background-color:${bg};color:${color};border-color:${border};">${s}</span>`;
    }).join('');

    // QR code slides
    const slidesEl = document.getElementById('qr-slides');
    const qrCodes = bk.qr_codes || [];
    if (qrCodes.length > 0) {
      slidesEl.innerHTML = qrCodes.map((qr, i) => {
        const qrImgUrl = `https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=${encodeURIComponent(qr)}`;
        return `<div class="flex flex-col items-center">
          <span class="text-[10px] text-zinc-400 font-bold uppercase tracking-widest mb-2">Ghế ${bk.seats[i] || (i+1)}</span>
          <img src="${qrImgUrl}" alt="QR Code Vé ${i+1}" class="w-44 h-44 rounded-xl border border-zinc-200 shadow-inner" />
          <span class="text-[10px] font-mono text-zinc-400 mt-1">${qr.substring(0,16)}...</span>
        </div>`;
      }).join('');
    } else {
      slidesEl.innerHTML = '<p class="text-zinc-400 text-xs">Vé chưa được phát hành.</p>';
    }

    qrModal.classList.remove('hidden');
    qrModal.classList.add('flex');
    setTimeout(() => {
      qrModalContent.classList.remove('scale-95', 'opacity-0');
      qrModalContent.classList.add('scale-100', 'opacity-100');
    }, 10);
  }

  function closeQrModal() {
    qrModalContent.classList.remove('scale-100', 'opacity-100');
    qrModalContent.classList.add('scale-95', 'opacity-0');
    
    setTimeout(() => {
      qrModal.classList.add('hidden');
      qrModal.classList.remove('flex');
    }, 300);
  }

  /* ─────────────────────────────────────────
     BACK BUTTON PROTECTION (pageshow handler)
     ───────────────────────────────────────── */
  window.addEventListener('pageshow', function() {
    const overlay = document.getElementById('loading-overlay');
    if (overlay) { overlay.classList.add('hidden'); overlay.classList.remove('flex'); }
  });

  /* ─────────────────────────────────────────
     PROFILE EDIT MODAL HANDLERS
     ───────────────────────────────────────── */
  const editModal = document.getElementById('editProfileModal');
  const editModalContent = document.getElementById('editModalContent');
  const editForm = document.getElementById('editProfileForm');
  
  const profileName = document.getElementById('profile-name');
  const profilePhone = document.getElementById('profile-phone');
  const profileEmail = document.getElementById('profile-email');

  const editFullnameInput = document.getElementById('edit-fullname');
  const editPhoneInput = document.getElementById('edit-phone');
  const editEmailInput = document.getElementById('edit-email');

  const errFullname = document.getElementById('error-fullname');
  const errPhone = document.getElementById('error-phone');
  const errEmail = document.getElementById('error-email');

  // Load stored profile data on page load
  document.addEventListener('DOMContentLoaded', async () => {
    const token = localStorage.getItem('access_token');
    if (!token) {
      // Redirect to home if not logged in
      window.location.href = '/';
      return;
    }

    try {
      const response = await fetch('http://localhost:8000/user/profile', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (response.ok) {
        const data = await response.json();
        profileName.textContent = data.full_name;
        profilePhone.textContent = data.phone || 'Chưa cập nhật';
        profileEmail.textContent = data.email;
        // Save back to localStorage for consistency
        localStorage.setItem('user', JSON.stringify(data));
      } else {
        // Token might be expired or invalid
        localStorage.removeItem('access_token');
        localStorage.removeItem('user');
        window.location.href = '/';
      }
      // Fetch user booking history
      const histRes = await fetch('http://localhost:8000/user/history', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (histRes.ok) {
        const bookings = await histRes.json();
        renderBookings(bookings);
      }

    } catch (error) {
      console.error('Lỗi khi tải profile:', error);
    }
  });


  function renderBookings(bookings) {
    const container = document.getElementById('bookings-container');
    container.innerHTML = '';
    if (bookings.length === 0) {
      container.innerHTML = '<p class="text-zinc-500 text-sm py-4 col-span-2">Bạn chưa có giao dịch nào.</p>';
      return;
    }
    bookings.forEach(bk => {
      const isPaid = bk.status === 'paid';
      const isCancelled = bk.status === 'cancelled';
      
      let statusBadge = '';
      if (isPaid) {
          statusBadge = `<span class="bg-green-50 text-green-700 border border-green-200 px-3 py-1 rounded-full text-xs font-semibold flex-shrink-0">Đã thanh toán</span>`;
      } else if (isCancelled) {
          statusBadge = `<span class="bg-zinc-100 text-zinc-500 border border-zinc-300 px-3 py-1 rounded-full text-xs font-semibold flex-shrink-0">Đã huỷ</span>`;
      } else {
          statusBadge = `<span class="bg-red-50 text-red-600 border border-red-200 px-3 py-1 rounded-full text-xs font-semibold flex-shrink-0">Chưa thanh toán</span>`;
      }
      
      const d = new Date(bk.showtime_start);
      const timeStr = d.toLocaleTimeString('vi-VN', {hour:'2-digit', minute:'2-digit'}) + ' | ' + d.toLocaleDateString('vi-VN');
      const seatsHtml = bk.seats.map(s => {
        const row = s.charAt(0);
        const col = parseInt(s.substring(1));
        const isVip = ['D','E','F','G'].includes(row) && [3,4,5,6].includes(col);
        const bg = isVip ? '#fef3c7' : '#ffffff';
        const color = isVip ? '#b45309' : '#27272a';
        const border = isVip ? '#f59e0b' : '#a1a1aa';
        return `<span class="px-2.5 py-0.5 text-xs font-semibold rounded border" style="background-color:${bg};color:${color};border-color:${border};">${s}</span>`;
      }).join('');
      const qrDataAttr = JSON.stringify(bk.qr_codes || []).replace(/'/g, '&#39;');
      const seatsDataAttr = JSON.stringify(bk.seats || []).replace(/'/g, '&#39;');
      // Store booking data in global map to avoid JSON/quote conflict in onclick
      window.bookingDataMap = window.bookingDataMap || {};
      window.bookingDataMap[bk.booking_id] = bk;
      
      let actionBtn = '';
      if (isPaid) {
          actionBtn = `<button onclick="openQrModal(${bk.booking_id})" class="w-full bg-white hover:bg-zinc-50 text-zinc-700 border border-zinc-200 hover:border-zinc-300 py-3 rounded-xl text-sm font-semibold transition flex items-center justify-center gap-2 shadow-sm">
             <i class="fas fa-qrcode text-base"></i> Xem mã QR vé
           </button>`;
      } else if (isCancelled) {
          actionBtn = `<button class="w-full bg-zinc-100 text-zinc-400 py-3.5 rounded-xl text-sm font-bold transition flex items-center justify-center gap-2 cursor-not-allowed" disabled>
             <i class="fas fa-ban text-base"></i> Hết hạn thanh toán
           </button>`;
      } else {
          actionBtn = `<button onclick="window.location.href='/checkout/${bk.booking_id}'" class="w-full bg-brand hover:bg-brandHover text-white py-3.5 rounded-xl text-sm font-bold shadow-lg shadow-brand/20 transition flex items-center justify-center gap-2 active:scale-[0.99]">
             <i class="fas fa-credit-card text-base"></i> Thanh toán ngay
           </button>`;
      }
      container.insertAdjacentHTML('beforeend', `
        <div class="bg-white rounded-2xl border border-zinc-200 shadow-sm overflow-hidden flex flex-col justify-between hover:shadow-md transition duration-300">
          <div class="p-6 space-y-5">
            <div class="flex justify-between items-start gap-4">
              <h3 class="font-bold text-zinc-900 text-lg leading-tight">${bk.movie_title}</h3>
              ${statusBadge}
            </div>
            <div class="space-y-3.5 text-sm">
              <div class="flex items-center gap-3">
                <i class="far fa-calendar-alt text-zinc-400 w-5 text-center"></i>
                <span>Suất chiếu: <strong>${timeStr}</strong></span>
              </div>
              <div class="flex items-center gap-3">
                <i class="fas fa-map-marker-alt text-zinc-400 w-5 text-center"></i>
                <span>Phòng: ${bk.room_name}</span>
              </div>
              <div class="flex items-center gap-3">
                <i class="fas fa-ticket-alt text-zinc-400 w-5 text-center"></i>
                <div class="flex items-center gap-1.5 flex-wrap">
                  <span class="text-zinc-700">Ghế:</span>${seatsHtml}
                </div>
              </div>
            </div>
          </div>
          <div class="px-6 pb-6 pt-2 border-t border-zinc-100 bg-zinc-50">${actionBtn}</div>
        </div>`);
    });
  }

  function openEditModal() {
    // 1. Pre-fill input fields with current text content
    editFullnameInput.value = profileName.textContent.trim();
    editPhoneInput.value = profilePhone.textContent.trim();
    editEmailInput.value = profileEmail.textContent.trim();

    // 2. Reset previous error states
    hideError(editFullnameInput, errFullname);
    hideError(editPhoneInput, errPhone);
    hideError(editEmailInput, errEmail);

    // 3. Show Modal
    editModal.classList.remove('hidden');
    editModal.classList.add('flex');

    // 4. Smooth scale and fade in
    setTimeout(() => {
      editModalContent.classList.remove('scale-95', 'opacity-0');
      editModalContent.classList.add('scale-100', 'opacity-100');
    }, 10);
  }

  function closeEditModal() {
    // 1. Smooth fade out and scale down
    editModalContent.classList.remove('scale-100', 'opacity-100');
    editModalContent.classList.add('scale-95', 'opacity-0');

    // 2. Hide container completely after animation duration
    setTimeout(() => {
      editModal.classList.add('hidden');
      editModal.classList.remove('flex');
    }, 300);
  }

  function showError(input, errorEl, message) {
    input.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
    input.classList.remove('border-zinc-200', 'focus:border-brand', 'focus:ring-brand');
    errorEl.textContent = message;
    errorEl.classList.remove('hidden');
  }

  function hideError(input, errorEl) {
    input.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
    input.classList.add('border-zinc-200', 'focus:border-brand', 'focus:ring-brand');
    errorEl.classList.add('hidden');
    errorEl.textContent = '';
  }

  async function saveProfile(event) {
    event.preventDefault();

    const nameVal = editFullnameInput.value.trim();
    const phoneVal = editPhoneInput.value.trim();
    
    let hasError = false;

    // 1. Validation: Fullname
    if (!nameVal) {
      showError(editFullnameInput, errFullname, 'Họ và tên không được để trống.');
      hasError = true;
    } else {
      hideError(editFullnameInput, errFullname);
    }

    // 2. Validation: Phone
    const phoneRegex = /^[0-9+() .\s-x]{9,20}$/;
    if (phoneVal && !phoneRegex.test(phoneVal)) {
      showError(editPhoneInput, errPhone, 'Số điện thoại không hợp lệ.');
      hasError = true;
    } else {
      hideError(editPhoneInput, errPhone);
    }

    if (hasError) return;

    // 3. Save to Backend
    const token = localStorage.getItem('access_token');
    try {
      const response = await fetch('http://localhost:8000/user/profile', {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
          full_name: nameVal,
          phone: phoneVal || null
        })
      });

      if (response.ok) {
        const data = await response.json();
        
        // Update UI with fade animation
        const fieldsToAnimate = [profileName, profilePhone];
        fieldsToAnimate.forEach(el => el.classList.add('profile-fade'));

        profileName.textContent = data.full_name;
        profilePhone.textContent = data.phone || 'Chưa cập nhật';
        localStorage.setItem('user', JSON.stringify(data));

        // Clean up animation class
        setTimeout(() => {
          fieldsToAnimate.forEach(el => el.classList.remove('profile-fade'));
        }, 500);

        // 6. Close Modal
        closeEditModal();

        // 7. Show Toast Alert
        showToast('Cập nhật hồ sơ cá nhân thành công!');
      } else {
        const err = await response.json();
        showToast(err.detail || 'Lỗi khi cập nhật hồ sơ');
      }
    } catch (error) {
      console.error('Lỗi khi cập nhật:', error);
      showToast('Lỗi kết nối máy chủ');
    }
  }

  function showToast(message) {
    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toast-message');
    
    toastMsg.textContent = message;
    toast.classList.add('toast-visible');
    
    setTimeout(() => {
      toast.classList.remove('toast-visible');
    }, 3000);
  }
</script>
