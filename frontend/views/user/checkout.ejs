<div class="min-h-screen bg-zinc-50 pt-28 pb-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    
    <div class="mb-8 border-b border-zinc-200 pb-5">
      <h1 class="text-3xl font-bold tracking-tight text-zinc-900">Thanh toán</h1>
      <p class="mt-2 text-sm text-zinc-500">Vui lòng kiểm tra lại đơn hàng và chọn phương thức thanh toán để hoàn thành đặt vé.</p>
    </div>

    <div class="flex flex-col gap-8 lg:flex-row lg:items-start">
      
      <div class="flex-1 w-full lg:w-3/5 space-y-6">
        
        <div class="bg-white rounded-xl border border-zinc-200 shadow-sm overflow-hidden">
          <div class="p-6">
            <h2 class="text-lg font-medium text-zinc-900 mb-4">Phương thức thanh toán</h2>
            
            <div class="flex flex-col items-center justify-center p-6 bg-zinc-50 rounded-lg border border-dashed border-zinc-300">
              <div class="w-48 h-48 bg-white border border-zinc-200 rounded-md flex items-center justify-center shadow-inner mb-4">
                <span class="text-xs text-zinc-400 font-mono">[ Quét mã QR ]</span>
              </div>
              <p class="text-sm font-medium text-zinc-700">Quét mã để thanh toán bằng ứng dụng ngân hàng của bạn</p>
              <p class="text-xs text-zinc-400 mt-1">Hỗ trợ mọi giao thức giao dịch ngân hàng an toàn</p>
            </div>
            
          </div>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 flex items-start gap-3 shadow-sm">
          <svg class="w-5 h-5 text-amber-600 animate-spin flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <div>
            <p class="font-medium text-amber-900 text-sm">Đang chờ xác nhận thanh toán</p>
            <p class="text-xs text-amber-700 mt-0.5">Vui lòng hoàn tất thanh toán để xác nhận đơn đặt vé của bạn.</p>
          </div>
        </div>

        <button id="success-btn" class="w-full bg-zinc-900 hover:bg-zinc-800 text-white py-3 px-4 rounded-xl text-sm font-semibold shadow transition-all active:scale-[0.99]">
          Giả lập Thanh toán Thành công (Demo)
        </button>

      </div>

      <div class="w-full lg:w-2/5 lg:sticky lg:top-24 space-y-6">
        
        <div class="bg-white rounded-xl border border-zinc-200 shadow-sm overflow-hidden">
          <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-200">
            <h3 class="font-semibold text-zinc-900">Tóm tắt Đơn đặt vé</h3>
          </div>
          
          <div class="p-6 space-y-4">
            <div class="flex justify-between items-start border-b border-zinc-100 pb-4">
              <div>
                <h4 id="summary-title" class="font-medium text-zinc-900 text-base">The Matrix</h4>
                <p class="text-xs text-zinc-500 mt-0.5">Phòng chiếu Standard • Màn hình 2</p>
              </div>
              <span id="summary-tickets-count" class="px-2.5 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded">x1 Vé</span>
            </div>

            <div class="space-y-1.5">
              <span class="text-xs text-zinc-400 block">Ghế đã chọn</span>
              <div id="summary-seats" class="flex flex-wrap gap-1.5">
                <span class="px-2.5 py-0.5 bg-zinc-100 text-zinc-800 text-xs font-medium rounded border border-zinc-200">B3</span>
              </div>
            </div>

            <div class="pt-4 border-t border-zinc-100 space-y-2">
              <div class="flex justify-between text-sm text-zinc-600">
                <span>Tạm tính vé</span>
                <span id="summary-subtotal">0đ</span>
              </div>
              <div class="flex justify-between text-sm text-zinc-600">
                <span>Phí dịch vụ</span>
                <span>0đ</span>
              </div>
              <div class="flex justify-between text-base font-semibold text-zinc-900 pt-2 border-t border-zinc-100">
                <span>Tổng cộng</span>
                <span id="summary-total">0đ</span>
              </div>
            </div>
          </div>

          <div class="px-6 py-3.5 bg-zinc-50 border-t border-zinc-200">
            <p class="text-[11px] text-center text-zinc-400">Đơn đặt vé của bạn sẽ được xác nhận tự động ngay sau khi nhận được thanh toán.</p>
          </div>
        </div>

      </div>

    </div>

  </div>
</div>

<script>
  // Simple interactions for demo
  document.getElementById('success-btn').addEventListener('click', function() {
    // Get booking ID from path or generate new one
    const pathParts = window.location.pathname.split('/');
    const bookingId = pathParts[pathParts.length - 1] || 'BK-' + Math.floor(Math.random() * 1000000);
    
    // Forward the current query parameters (seats, price, title) to the receipt page
    window.location.href = `/receipt/${bookingId}${window.location.search}`;
  });

  // Pull optional URL search params to make summary interactive if available
  const urlParams = new URLSearchParams(window.location.search);
  const seats = urlParams.get('seats');
  const price = urlParams.get('price');
  const title = urlParams.get('title');

  if (title) {
    document.getElementById('summary-title').textContent = title;
  }
  if (seats) {
    const seatsList = seats.split(',');
    const seatsContainer = document.getElementById('summary-seats');
    seatsContainer.innerHTML = '';
    seatsList.forEach(seat => {
      const span = document.createElement('span');
      span.textContent = seat.trim();
      
      const seatUpper = seat.trim().toUpperCase();
      const row = seatUpper.charAt(0);
      const col = parseInt(seatUpper.substring(1), 10);
      const isVip = ['D', 'E', 'F', 'G'].includes(row) && [3, 4, 5, 6].includes(col);

      if (isVip) {
        span.className = 'px-2.5 py-0.5 text-xs font-semibold rounded border';
        span.style.backgroundColor = '#fef3c7';
        span.style.color = '#b45309';
        span.style.borderColor = '#f59e0b';
      } else {
        span.className = 'px-2.5 py-0.5 text-xs font-semibold rounded border';
        span.style.backgroundColor = '#ffffff';
        span.style.color = '#27272a';
        span.style.borderColor = '#a1a1aa';
      }
      seatsContainer.appendChild(span);
    });
    document.getElementById('summary-tickets-count').textContent = `x${seatsList.length} Vé`;
  }
  if (price) {
    const parsedPrice = parseFloat(price);
    let formattedPrice = '';
    if (!isNaN(parsedPrice)) {
      if (parsedPrice < 100) {
        formattedPrice = '$' + parsedPrice.toFixed(2);
      } else {
        formattedPrice = parsedPrice.toLocaleString('vi-VN') + ' VND';
      }
    } else {
      formattedPrice = price;
    }
    document.getElementById('summary-subtotal').textContent = formattedPrice;
    document.getElementById('summary-total').textContent = formattedPrice;
  }
</script>
