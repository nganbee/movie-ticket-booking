<div class="bg-bgSubtle min-h-screen pb-16">
    <!-- Top Section containing Backdrop AND Poster/Info -->
    <div class="relative w-full pt-32 pb-16">
        <!-- Backdrop Banner -->
        <div class="absolute inset-0 z-0 bg-slate-900 overflow-hidden">
            <img src="<%= movie.poster %>" alt="<%= movie.title %> Backdrop" class="w-full h-full object-cover object-top opacity-20 blur-xl scale-110" />
            <!-- Gradient fade to match the background of the page -->
            <div class="absolute inset-0 bg-gradient-to-t from-bgSubtle via-bgSubtle/60 to-transparent"></div>
        </div>

        <!-- Movie Details Content -->
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="flex flex-col md:flex-row gap-10">
                <!-- Poster -->
                <div class="w-full md:w-1/3 lg:w-1/4 flex-shrink-0">
                    <img src="<%= movie.poster %>" alt="<%= movie.title %>" class="w-full rounded-2xl shadow-2xl border-4 border-white">
                </div>
                
                <!-- Info -->
                <div class="w-full md:w-2/3 lg:w-3/4 pt-4 md:pt-8">
                    <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 mb-4 tracking-tight"><%= movie.title %></h1>
                    
                    <div class="flex flex-wrap items-center gap-4 text-sm font-medium text-slate-700 mb-6">
                        <span class="flex items-center bg-yellow-50 text-yellow-600 px-3 py-1 rounded-md border border-yellow-200">
                            <i class="fas fa-star mr-1.5"></i> <%= movie.rating %>
                        </span>
                        <span class="flex items-center"><i class="far fa-clock mr-2 text-slate-500"></i> <%= movie.duration || 'N/A' %></span>
                        <span class="flex items-center"><i class="fas fa-film mr-2 text-slate-500"></i> <%= movie.genre %></span>
                    </div>
                    
                    <p class="text-slate-600 text-lg leading-relaxed mb-8 max-w-3xl">
                        <%= movie.description || 'Chưa có thông tin mô tả cho bộ phim này.' %>
                    </p>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8 max-w-2xl">
                        <div>
                            <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-1">Đạo Diễn</h4>
                            <p class="text-slate-800 font-medium"><%= movie.director || 'Đang cập nhật' %></p>
                        </div>
                        <div>
                            <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-1">Diễn Viên</h4>
                            <p class="text-slate-800 font-medium"><%= movie.cast || 'Đang cập nhật' %></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Showtime Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 relative z-10">
        <div class="mt-16 bg-white rounded-3xl p-8 shadow-xl shadow-slate-200/50 border border-slate-100">
            <h2 class="text-2xl font-bold text-slate-800 mb-6 flex items-center">
                <span class="w-1.5 h-6 bg-brand rounded-full mr-3"></span> Lịch Chiếu Phim
            </h2>
            
            <!-- Date Tabs -->
            <div class="flex space-x-4 mb-8 overflow-x-auto pb-2" id="date-selector">
                <button class="date-btn selected flex-shrink-0 bg-brand text-white px-6 py-3 rounded-xl font-bold text-center min-w-[100px] shadow-md shadow-brand/20 border border-brand transition">
                    <span class="block text-xs uppercase opacity-80 mb-1">Hôm nay</span>
                    <span class="block text-xl">18/05</span>
                </button>
                <button class="date-btn flex-shrink-0 bg-slate-50 text-slate-600 hover:bg-slate-100 px-6 py-3 rounded-xl font-bold text-center min-w-[100px] border border-slate-200 transition">
                    <span class="block text-xs uppercase opacity-80 mb-1">Ngày mai</span>
                    <span class="block text-xl">19/05</span>
                </button>
                <button class="date-btn flex-shrink-0 bg-slate-50 text-slate-600 hover:bg-slate-100 px-6 py-3 rounded-xl font-bold text-center min-w-[100px] border border-slate-200 transition">
                    <span class="block text-xs uppercase opacity-80 mb-1">Thứ Hai</span>
                    <span class="block text-xl">20/05</span>
                </button>
            </div>

            <!-- Theaters & Times -->
            <div class="space-y-6">
                <!-- Theater 1 -->
                <div class="border-b border-slate-100 pb-6">
                    <h3 class="text-lg font-bold text-slate-800 mb-4">CineBook Nguyễn Du</h3>
                    <div class="flex flex-wrap gap-3">
                        <button data-time="09:30" class="showtime-btn available border border-slate-300 text-slate-700 hover:border-brand hover:text-brand px-4 py-2 rounded-lg font-medium transition">09:30</button>
                        <button data-time="12:15" class="showtime-btn available border border-slate-300 text-slate-700 hover:border-brand hover:text-brand px-4 py-2 rounded-lg font-medium transition">12:15</button>
                        <button data-time="15:00" class="showtime-btn sold-out border border-slate-200 bg-slate-50 text-slate-400 px-4 py-2 rounded-lg font-medium cursor-not-allowed line-through">15:00</button>
                        <button data-time="18:45" class="showtime-btn available border border-slate-300 text-slate-700 hover:border-brand hover:text-brand px-4 py-2 rounded-lg font-medium transition">18:45</button>
                        <button data-time="21:30" class="showtime-btn available border border-slate-300 text-slate-700 hover:border-brand hover:text-brand px-4 py-2 rounded-lg font-medium transition">21:30</button>
                    </div>
                </div>
                
                <!-- Theater 2 -->
                <div>
                    <h3 class="text-lg font-bold text-slate-800 mb-4">CineBook Landmark 81</h3>
                    <div class="flex flex-wrap gap-3">
                        <button data-time="10:00" class="showtime-btn available border border-slate-300 text-slate-700 hover:border-brand hover:text-brand px-4 py-2 rounded-lg font-medium transition">10:00</button>
                        <button data-time="14:20" class="showtime-btn sold-out border border-slate-200 bg-slate-50 text-slate-400 px-4 py-2 rounded-lg font-medium cursor-not-allowed line-through">14:20</button>
                        <button data-time="19:10" class="showtime-btn available border border-slate-300 text-slate-700 hover:border-brand hover:text-brand px-4 py-2 rounded-lg font-medium transition">19:10</button>
                        <button data-time="22:00" class="showtime-btn available border border-slate-300 text-slate-700 hover:border-brand hover:text-brand px-4 py-2 rounded-lg font-medium transition">22:00</button>
                    </div>
                </div>
            </div>
            
            <div class="mt-8 flex justify-end">
                <button id="continue-btn" disabled class="bg-slate-300 text-slate-500 cursor-not-allowed px-8 py-4 rounded-xl font-bold transition duration-300 shadow-sm">
                    Tiếp tục chọn ghế <i class="fas fa-arrow-right ml-2"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Showtime Selection Logic
    const showtimeBtns = document.querySelectorAll('.showtime-btn.available');
    const continueBtn = document.getElementById('continue-btn');
    let selectedShowtime = null;

    showtimeBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            // Remove selection from all
            showtimeBtns.forEach(b => {
                b.classList.remove('bg-brand/10', 'border-brand', 'text-brand', 'font-bold', 'shadow-sm', 'selected');
                b.classList.add('border-slate-300', 'text-slate-700');
            });

            // Add selection to clicked
            this.classList.remove('border-slate-300', 'text-slate-700');
            this.classList.add('bg-brand/10', 'border-brand', 'text-brand', 'font-bold', 'shadow-sm', 'selected');
            
            selectedShowtime = this.getAttribute('data-time');

            // Enable Continue button
            continueBtn.disabled = false;
            continueBtn.className = 'bg-brand text-white px-8 py-4 rounded-xl font-bold hover:bg-brandHover transition duration-300 shadow-lg shadow-brand/30 cursor-pointer';
        });
    });

    continueBtn.addEventListener('click', function() {
        if(selectedShowtime) {
            // Get selected date
            const selectedDateBtn = document.querySelector('.date-btn.selected');
            const dateText = selectedDateBtn ? selectedDateBtn.querySelector('.text-xl').innerText.replace('/', '') : '1805';
            
            // Replace spaces/colons to make a safe mock URL ID
            const showtimeId = dateText + '-' + selectedShowtime.replace(':', '') + '-' + Math.floor(Math.random() * 1000);
            window.location.href = `/booking/ST${showtimeId}`;
        }
    });

    // Date Selection Logic
    const dateBtns = document.querySelectorAll('.date-btn');
    dateBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            // Reset all date buttons to inactive state
            dateBtns.forEach(b => {
                b.className = 'date-btn flex-shrink-0 bg-slate-50 text-slate-600 hover:bg-slate-100 px-6 py-3 rounded-xl font-bold text-center min-w-[100px] border border-slate-200 transition';
            });
            // Set clicked button to active state
            this.className = 'date-btn selected flex-shrink-0 bg-brand text-white px-6 py-3 rounded-xl font-bold text-center min-w-[100px] shadow-md shadow-brand/20 border border-brand transition';
            
            // Note: In a real app, clicking a date would also fetch new showtimes for that date.
            // For now, we just reset the showtime selection visually:
            showtimeBtns.forEach(b => {
                b.classList.remove('bg-brand/10', 'border-brand', 'text-brand', 'font-bold', 'shadow-sm', 'selected');
                b.classList.add('border-slate-300', 'text-slate-700');
            });
            selectedShowtime = null;
            continueBtn.disabled = true;
            continueBtn.className = 'bg-slate-300 text-slate-500 cursor-not-allowed px-8 py-4 rounded-xl font-bold transition duration-300 shadow-sm';
        });
    });
});
</script>

