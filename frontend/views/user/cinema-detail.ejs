<div class="bg-bgSubtle min-h-screen pb-16">
    <!-- Hero Section -->
    <div class="relative w-full pt-32 pb-16" id="theater-hero">
        <div class="text-center py-10">
            <i class="fas fa-spinner fa-spin text-4xl text-brand mb-4"></i>
            <p class="text-slate-400">Đang tải thông tin rạp...</p>
        </div>
    </div>

    <!-- Showtime Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 relative z-10">
        <div class="bg-white rounded-3xl p-8 shadow-xl shadow-slate-200/50 border border-slate-100">
            <h2 class="text-2xl font-bold text-slate-800 mb-6 flex items-center">
                <span class="w-1.5 h-6 bg-brand rounded-full mr-3"></span> Lịch Chiếu Phim
            </h2>
            
            <!-- Date Tabs (Generated by JS) -->
            <div class="flex space-x-4 mb-8 overflow-x-auto pb-2" id="date-selector">
                <!-- Nội dung sẽ được tạo bởi JavaScript -->
            </div>

            <!-- Movies & Times -->
            <div class="space-y-8" id="movies-container">
                <!-- Nội dung sẽ được tạo bởi JavaScript -->
            </div>
            
            <div class="mt-8 flex justify-end">
                <button id="continue-btn" disabled class="bg-slate-300 text-slate-500 cursor-not-allowed px-8 py-4 rounded-xl font-bold transition duration-300 shadow-sm">
                    Tiếp tục chọn ghế <i class="fas fa-arrow-right ml-2"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', async function() {
    const API_BASE_URL = 'http://localhost:8000';
    const theaterId = parseInt('<%= theaterId %>');
    
    const moviesContainer = document.getElementById('movies-container');
    const dateSelector = document.getElementById('date-selector');
    const continueBtn = document.getElementById('continue-btn');
    
    let selectedShowtimeId = null;
    let ALL_MOVIES = [];

    // --- Load Theater Info ---
    async function loadTheater() {
        try {
            const res = await fetch(`${API_BASE_URL}/theaters/`);
            if (res.ok) {
                const theaters = await res.json();
                const theater = theaters.find(t => t.id === theaterId);
                if (theater) {
                    renderHero(theater);
                } else {
                    // Fallback to mock data if not found
                    const mockTheater = {
                        name: theaterId === 1 ? 'CineBook Nguyễn Du' : 'CineBook Landmark 81',
                        address: theaterId === 1 ? '116 Nguyễn Du, Quận 1, TP. HCM' : 'Tòa nhà Landmark 81, Bình Thạnh, TP. HCM',
                        image_url: 'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=1200'
                    };
                    renderHero(mockTheater);
                }
            }
        } catch (error) {
            console.error('Error loading theater info:', error);
        }
    }

    function renderHero(theater) {
        const hero = document.getElementById('theater-hero');
        const img = theater.image_url || 'https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=1200';
        hero.innerHTML = `
            <div class="absolute inset-0 z-0 bg-slate-900 overflow-hidden">
                <img src="${img}" class="w-full h-full object-cover object-top opacity-20 blur-xl scale-110" />
                <div class="absolute inset-0 bg-gradient-to-t from-bgSubtle via-bgSubtle/60 to-transparent"></div>
            </div>
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center pt-8">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand/10 border border-brand/20 text-brand text-xs font-bold uppercase tracking-widest mb-4 shadow-sm backdrop-blur-md">
                    <i class="fas fa-map-marker-alt"></i> Hệ Thống Rạp
                </span>
                <h1 class="text-4xl md:text-6xl font-extrabold mb-4 tracking-tight drop-shadow-lg text-slate-800">${theater.name}</h1>
                <p class="text-slate-600 text-lg md:text-xl font-medium flex justify-center items-center gap-2">
                    <i class="fas fa-map-pin text-brand"></i> ${theater.address}
                </p>
            </div>
        `;
    }

    // --- Tạo các Tab Ngày động (7 ngày) ---
    const DAY_NAMES_VI = ['Chủ nhật', 'Thứ hai', 'Thứ ba', 'Thứ tư', 'Thứ năm', 'Thứ sáu', 'Thứ bảy'];
    const today = new Date();
    
    for (let i = 0; i < 7; i++) {
        const d = new Date(today);
        d.setDate(today.getDate() + i);
        
        const dd = String(d.getDate()).padStart(2, '0');
        const mm = String(d.getMonth() + 1).padStart(2, '0');
        const yyyy = d.getFullYear();
        const dateLabel = `${dd}/${mm}`;
        const isoDate = `${yyyy}-${mm}-${dd}`; // YYYY-MM-DD
        const dayLabel = i === 0 ? 'Hôm nay' : i === 1 ? 'Ngày mai' : DAY_NAMES_VI[d.getDay()];
        
        const btn = document.createElement('button');
        btn.className = i === 0
            ? 'date-btn selected flex-shrink-0 bg-brand text-white px-6 py-3 rounded-xl font-bold text-center min-w-[100px] shadow-md shadow-brand/20 border border-brand transition'
            : 'date-btn flex-shrink-0 bg-slate-50 text-slate-600 hover:bg-slate-100 px-6 py-3 rounded-xl font-bold text-center min-w-[100px] border border-slate-200 transition';
        btn.dataset.isoDate = isoDate;
        btn.innerHTML = `
            <span class="block text-xs uppercase opacity-80 mb-1">${dayLabel}</span>
            <span class="block text-xl">${dateLabel}</span>
        `;
        dateSelector.appendChild(btn);
    }

    const dateBtns = document.querySelectorAll('.date-btn');
    
    // --- Lấy dữ liệu phim và suất chiếu ---
    async function fetchShowtimes(isoDate) {
        moviesContainer.innerHTML = '<p class="text-center text-slate-500 my-8">Đang tải lịch chiếu...</p>';
        continueBtn.disabled = true;
        continueBtn.className = 'bg-slate-300 text-slate-500 cursor-not-allowed px-8 py-4 rounded-xl font-bold transition duration-300 shadow-sm';
        
        try {
            // Load danh sách phim nếu chưa có
            if (ALL_MOVIES.length === 0) {
                const mRes = await fetch(`${API_BASE_URL}/movies/?limit=100`);
                if (mRes.ok) {
                    const mData = await mRes.json();
                    ALL_MOVIES = mData.items || mData;
                }
            }

            // Fetch tất cả lịch chiếu của ngày
            const res = await fetch(`${API_BASE_URL}/showtimes/?date=${isoDate}`);
            if (!res.ok) throw new Error('Lỗi khi tải lịch chiếu');
            
            const showtimes = await res.json();
            
            // Lọc các suất chiếu đã qua trong ngày hôm nay
            const now = new Date();
            const validShowtimes = showtimes.filter(st => {
                const startTime = new Date(st.start_time);
                return startTime > now;
            });
            
            // Lọc các suất chiếu thuộc về rạp hiện tại
            const theaterShowtimes = validShowtimes.filter(st => 
                st.room && (st.room.theater_id === theaterId || (st.room.theater && (st.room.theater.theater_id === theaterId || st.room.theater.id === theaterId)))
            );
            
            renderMovies(theaterShowtimes);
        } catch (error) {
            console.error(error);
            moviesContainer.innerHTML = '<p class="text-center text-red-500 my-8">Lỗi tải dữ liệu. Vui lòng thử lại sau.</p>';
        }
    }

    // --- Hiển thị danh sách phim và suất chiếu ---
    function renderMovies(showtimes) {
        if (!showtimes || showtimes.length === 0) {
            moviesContainer.innerHTML = '<p class="text-center text-slate-500 my-8">Không có suất chiếu nào cho ngày này tại rạp.</p>';
            return;
        }

        // Gom nhóm theo movie_id và Format
        const movieMap = {};
        showtimes.forEach(st => {
            const mId = st.movie_id;
            const formatName = st.format || '2D';
            
            if (!movieMap[mId]) {
                movieMap[mId] = {};
            }
            if (!movieMap[mId][formatName]) {
                movieMap[mId][formatName] = [];
            }
            movieMap[mId][formatName].push(st);
        });

        // Tạo HTML
        moviesContainer.innerHTML = '';
        for (const [mId, formats] of Object.entries(movieMap)) {
            const movie = ALL_MOVIES.find(m => m.movie_id == mId);
            if (!movie) continue;

            let formatsHtml = '';
            for (const [format, times] of Object.entries(formats)) {
                let buttonsHtml = times.map(st => {
                    const startTime = new Date(st.start_time);
                    const timeStr = startTime.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                    return `<button data-id="${st.showtime_id}" class="showtime-btn available border border-slate-300 text-slate-700 hover:border-brand hover:text-brand px-4 py-2 rounded-lg font-medium transition flex flex-col items-center">
                               <span>${timeStr}</span>
                            </button>`;
                }).join('');
                
                let badgeColor = 'bg-slate-100 text-slate-600';
                if (format === '3D') badgeColor = 'bg-blue-100 text-blue-700';
                if (format === 'IMAX') badgeColor = 'bg-amber-100 text-amber-700';

                formatsHtml += `
                    <div class="mb-4 last:mb-0 flex gap-4">
                        <div class="w-16 flex-shrink-0 pt-1">
                            <span class="px-2 py-1 rounded-md text-xs font-bold ${badgeColor}">${format}</span>
                        </div>
                        <div class="flex flex-wrap gap-3 flex-1">
                            ${buttonsHtml}
                        </div>
                    </div>
                `;
            }

            moviesContainer.innerHTML += `
                <div class="flex flex-col md:flex-row gap-6 border-b border-slate-100 pb-8 last:border-b-0">
                    <div class="w-full md:w-48 flex-shrink-0">
                        <a href="/movie/${movie.movie_id}"><img src="${movie.poster_url}" class="w-full rounded-xl shadow-md border border-slate-200 hover:scale-105 transition-transform"></a>
                    </div>
                    <div class="flex-1">
                        <a href="/movie/${movie.movie_id}"><h3 class="text-xl font-bold text-slate-800 mb-2 hover:text-brand transition">${movie.title}</h3></a>
                        <div class="flex items-center gap-3 text-xs font-bold text-slate-500 mb-4">
                            <span class="text-yellow-500 border border-yellow-200 bg-yellow-50 px-2 py-0.5 rounded-md"><i class="fas fa-star mr-1"></i> ${movie.imdb_rating ? movie.imdb_rating.toFixed(1) : 'N/A'}</span>
                            <span class="border border-slate-200 bg-slate-50 px-2 py-0.5 rounded-md"><i class="far fa-clock mr-1"></i> ${movie.duration} phút</span>
                            <span class="border border-slate-200 bg-slate-50 px-2 py-0.5 rounded-md"><i class="fas fa-film mr-1"></i> ${movie.genre}</span>
                        </div>
                        <div>
                            ${formatsHtml}
                        </div>
                    </div>
                </div>
            `;
        }

        // Gắn sự kiện click cho các nút suất chiếu mới
        attachShowtimeEvents();
    }

    function attachShowtimeEvents() {
        const showtimeBtns = document.querySelectorAll('.showtime-btn.available');
        showtimeBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                // Xóa trạng thái active của tất cả
                showtimeBtns.forEach(b => {
                    b.classList.remove('bg-brand/10', 'border-brand', 'text-brand', 'font-bold', 'shadow-sm', 'selected');
                    b.classList.add('border-slate-300', 'text-slate-700');
                });

                // Set active cho nút được click
                this.classList.remove('border-slate-300', 'text-slate-700');
                this.classList.add('bg-brand/10', 'border-brand', 'text-brand', 'font-bold', 'shadow-sm', 'selected');
                
                selectedShowtimeId = this.getAttribute('data-id');

                // Bật nút Tiếp tục
                continueBtn.disabled = false;
                continueBtn.className = 'bg-brand text-white px-8 py-4 rounded-xl font-bold hover:bg-brandHover transition duration-300 shadow-lg shadow-brand/30 cursor-pointer';
            });
        });
    }

    // Sự kiện chuyển sang trang chọn ghế
    continueBtn.addEventListener('click', function() {
        if (selectedShowtimeId) {
            window.location.href = `/booking/${selectedShowtimeId}`;
        }
    });

    // Sự kiện chuyển đổi ngày
    dateBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            // Đổi UI Tab
            dateBtns.forEach(b => {
                b.className = 'date-btn flex-shrink-0 bg-slate-50 text-slate-600 hover:bg-slate-100 px-6 py-3 rounded-xl font-bold text-center min-w-[100px] border border-slate-200 transition';
            });
            this.className = 'date-btn selected flex-shrink-0 bg-brand text-white px-6 py-3 rounded-xl font-bold text-center min-w-[100px] shadow-md shadow-brand/20 border border-brand transition';
            
            // Gọi API theo ngày mới
            selectedShowtimeId = null;
            fetchShowtimes(this.dataset.isoDate);
        });
    });

    // Khởi chạy
    loadTheater();
    const firstBtn = document.querySelector('.date-btn.selected');
    fetchShowtimes(firstBtn.dataset.isoDate);
});
</script>
