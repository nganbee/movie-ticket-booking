<script>
  // Pull dynamic parameters
  const urlParams = new URLSearchParams(window.location.search);
  const seats = urlParams.get('seats');
  const price = urlParams.get('price');
  const title = urlParams.get('title');

  // Booking ID from pathname
  const pathParts = window.location.pathname.split('/');
  const bookingId = pathParts[pathParts.length - 1];

  /* ─────────────────────────────────────────
     POPULATE TICKET VALUES (On-screen + Hidden capture stub)
  ───────────────────────────────────────── */
  if (bookingId) {
    document.getElementById('receipt-booking-id').textContent = bookingId;
    document.getElementById('capture-booking-id').textContent = bookingId;
    
    // Generate simple deterministic Transaction ID based on Booking ID digits
    const digits = bookingId.replace(/\D/g, '');
    if (digits) {
      const txn = 'TXN' + digits.padEnd(8, '0');
      document.getElementById('receipt-txn-id').textContent = txn;
      document.getElementById('capture-txn-id').textContent = txn;
    }
  }
  
  if (title) {
    const decodedTitle = decodeURIComponent(title);
    document.getElementById('receipt-title').textContent = decodedTitle;
    document.getElementById('capture-title').textContent = decodedTitle;
  }
  
  if (seats) {
    const seatsList = seats.split(',');
    
    // Populate screen seats
    const seatsContainer = document.getElementById('receipt-seats');
    seatsContainer.innerHTML = '';
    
    // Populate hidden capture card seats
    const captureSeatsContainer = document.getElementById('capture-seats');
    captureSeatsContainer.innerHTML = '';

    seatsList.forEach(seat => {
      const seatUpper = seat.trim().toUpperCase();
      const row = seatUpper.charAt(0);
      const col = parseInt(seatUpper.substring(1), 10);
      const isVip = ['D', 'E', 'F', 'G'].includes(row) && [3, 4, 5, 6].includes(col);

      // Screen badge
      const span = document.createElement('span');
      span.textContent = seat.trim();
      if (isVip) {
        span.className = 'px-3 py-1.5 text-xs font-extrabold rounded-lg shadow-sm border';
        span.style.backgroundColor = '#fef3c7';
        span.style.color = '#b45309';
        span.style.borderColor = '#f59e0b';
      } else {
        span.className = 'px-3 py-1.5 text-xs font-extrabold rounded-lg shadow-sm border';
        span.style.backgroundColor = '#ffffff';
        span.style.color = '#27272a';
        span.style.borderColor = '#a1a1aa';
      }
      seatsContainer.appendChild(span);

      // Capture badge
      const capSpan = document.createElement('span');
      capSpan.textContent = seat.trim();
      if (isVip) {
        capSpan.className = 'px-2.5 py-1 text-[10px] font-extrabold rounded shadow-sm border';
        capSpan.style.backgroundColor = '#fef3c7';
        capSpan.style.color = '#b45309';
        capSpan.style.borderColor = '#f59e0b';
      } else {
        capSpan.className = 'px-2.5 py-1 text-[10px] font-extrabold rounded shadow-sm border';
        capSpan.style.backgroundColor = '#ffffff';
        capSpan.style.color = '#27272a';
        capSpan.style.borderColor = '#a1a1aa';
      }
      captureSeatsContainer.appendChild(capSpan);
    });
  }
  
  if (price) {
    const parsedPrice = parseFloat(price);
    if (!isNaN(parsedPrice)) {
      let finalPrice = '';
      if (parsedPrice < 100) {
        finalPrice = '$' + parsedPrice.toFixed(2);
      } else {
        finalPrice = parsedPrice.toLocaleString('vi-VN') + ' đ';
      }
      document.getElementById('receipt-total').textContent = finalPrice;
      document.getElementById('capture-total').textContent = finalPrice;
    } else {
      let rawPrice = price.trim();
      if (rawPrice.toLowerCase().endsWith('vnd')) {
        rawPrice = rawPrice.slice(0, -3).trim() + ' đ';
      }
      document.getElementById('receipt-total').textContent = rawPrice;
      document.getElementById('capture-total').textContent = rawPrice;
    }
  }

  /* ─────────────────────────────────────────
     PIXEL-PERFECT PNG IMAGE DOWNLOAD HANDLER
  ───────────────────────────────────────── */
  document.getElementById('download-btn').addEventListener('click', function() {
    const btn = this;
    const originalText = btn.innerHTML;
    
    // Toggle loading spinner inside button
    btn.disabled = true;
    btn.innerHTML = `<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg> Đang tải...`;

    // Wait a brief frame to guarantee script execution
    setTimeout(() => {
      const container = document.getElementById('capture-container');
      
      // Render the hidden vertical card as a crisp high-res image
      html2canvas(container, {
        scale: 2.0, // Crisp 2x Retina quality
        useCORS: true,
        allowTaint: false, // Explicitly false to prevent tainting for toDataURL export
        backgroundColor: '#f4f4f5' // Light zinc-100 background outer bleed
      }).then(canvas => {
        const link = document.createElement('a');
        link.download = `CineBook-Ve-${bookingId || 'HoaDon'}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
        
        // Revert button state back to original
        btn.disabled = false;
        btn.innerHTML = originalText;
      }).catch(err => {
        console.error('Error generating image ticket:', err);
        alert('Không thể tải ảnh hóa đơn. Vui lòng thử lại hoặc kiểm tra quyền truy cập của trình duyệt.');
        btn.disabled = false;
        btn.innerHTML = originalText;
      });
    }, 150);
  });
</script>
