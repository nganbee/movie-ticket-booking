    button,
    a,
    .fixed,
    header,
    aside {
      display: none !important;
    }

    /* Reset body background for pristine printing */
    body {
      background: #ffffff !important;
      color: #000000 !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    /* Reset min-h-screen padding to print perfectly */
    .min-h-screen {
      min-height: auto !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      background: none !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
    }

    /* Enforce vertical card stub shape for printed paper output */
    .max-w-4xl {
      max-width: 26rem !important;
      display: flex !important;
      flex-direction: column !important; /* Force portrait layout stack */
      border: 1px solid #e4e4e7 !important;
      box-shadow: none !important;
      margin: 0 auto !important;
      border-radius: 16px !important;
      overflow: hidden !important;
      page-break-inside: avoid !important;
    }

    /* Hide the horizontal vertical line separator */
    .md\:block.w-px {
      display: none !important;
    }

    /* Convert the barcode right panel into a bottom receipt section with a horizontal dashed tear line */
    .w-full.md\:w-80 {
      width: 100% !important;
      border-left: none !important;
      border-top: 2px dashed #d4d4d8 !important;
      background: #fafafa !important;
      padding: 1.5rem !important;
    }

    /* Force background colors/gradients to render precisely */
    * {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
  }
</style>

