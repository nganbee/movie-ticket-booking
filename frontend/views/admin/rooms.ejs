<script>
let BRANCH_DATA = [];
let ROOMS_DATA = [];
let currentActiveBranchId = null;
let currentActiveRoomId = null;
let currentPaintTool = 'Standard';
let isDragMode = true; // Default drag selector mode
let isMousedown = false; // Mouse down state tracker

const API_URL = 'http://localhost:8000/theaters/';
function getAuthHeader() {
  const token = localStorage.getItem('access_token');
  return token ? { 'Authorization': `Bearer ${token}` } : {};
}

document.addEventListener('DOMContentLoaded', async () => {
  await loadTheaters();

  // Mouse selection event listeners
  document.addEventListener('mouseup', (e) => {
    endSelection(e);
  });
  document.addEventListener('mousemove', (e) => {
    updateSelection(e);
  });

  const canvas = document.getElementById('grid-canvas');
  canvas.addEventListener('mousedown', (e) => {
    startSelection(e);
  });
});

async function loadTheaters() {
  try {
    const res = await fetch(API_URL, {
      headers: getAuthHeader()
    });
    if (!res.ok) throw new Error('Failed to fetch theaters');
    
    BRANCH_DATA = await res.json();
    
    ROOMS_DATA = [];
    BRANCH_DATA.forEach(b => {
      if (b.rooms) {
        b.rooms.forEach(r => {
          // Normalize legacy seat types from database
          if (r.layout) {
            Object.keys(r.layout).forEach(key => {
              if (r.layout[key] === 'vip') r.layout[key] = 'VIP';
              if (r.layout[key] === 'normal') r.layout[key] = 'Standard';
            });
          }
          ROOMS_DATA.push(r);
        });
      }
    });

    if (BRANCH_DATA.length > 0) {
      if (!currentActiveBranchId || !BRANCH_DATA.find(b => b.id === currentActiveBranchId)) {
        currentActiveBranchId = BRANCH_DATA[0].id;
      }
      
      const branchRooms = ROOMS_DATA.filter(r => r.branchId === currentActiveBranchId);
      if (branchRooms.length > 0 && !branchRooms.find(r => r.id === currentActiveRoomId)) {
        currentActiveRoomId = branchRooms[0].id;
      } else if (branchRooms.length === 0) {
        currentActiveRoomId = null;
      }
    } else {
      currentActiveBranchId = null;
      currentActiveRoomId = null;
    }

    populateBranchSelect();
    renderRoomList();
    renderGridEditor();
  } catch (err) {
    console.error(err);
    alert('Không thể tải dữ liệu rạp từ máy chủ.');
  }
}



// Selection Box State
let selectionBox = null;
let startX = 0;
let startY = 0;
let dragActive = false;

function startSelection(e) {
  if (!isDragMode) {
    // Single click mode
    const seat = e.target.closest('button[data-key]');
    if (seat) {
      applyPaint(seat);
    }
    return;
  }
  
  if (e.button !== 0) return; // Only left click
  
  isMousedown = true;
  dragActive = false;
  startX = e.clientX;
  startY = e.clientY;
  
  if (selectionBox) selectionBox.remove();
  
  selectionBox = document.createElement('div');
  selectionBox.style.position = 'fixed';
  selectionBox.style.border = '1.5px solid #3b82f6';
  selectionBox.style.background = 'rgba(59, 130, 246, 0.15)';
  selectionBox.style.pointerEvents = 'none';
  selectionBox.style.zIndex = '9999';
  selectionBox.style.left = startX + 'px';
  selectionBox.style.top = startY + 'px';
  selectionBox.style.width = '0px';
  selectionBox.style.height = '0px';
  selectionBox.style.borderRadius = '3px';
  document.body.appendChild(selectionBox);
}

function updateSelection(e) {
  if (!isMousedown || !selectionBox) return;
  
  const currentX = e.clientX;
  const currentY = e.clientY;
  
  const width = Math.abs(startX - currentX);
  const height = Math.abs(startY - currentY);
  
  // Exceed 4px threshold to start drawing selection rectangle
  if (width > 4 || height > 4) {
    dragActive = true;
    const left = Math.min(startX, currentX);
    const top = Math.min(startY, currentY);
    
    selectionBox.style.left = left + 'px';
    selectionBox.style.top = top + 'px';
    selectionBox.style.width = width + 'px';
    selectionBox.style.height = height + 'px';
  }
}

function endSelection(e) {
  if (!isMousedown) return;
  isMousedown = false;
  
  if (selectionBox) {
    if (dragActive) {
      const boxRect = selectionBox.getBoundingClientRect();
      const seats = document.querySelectorAll('#editor-grid button[data-key]');
      
      seats.forEach(btn => {
        const btnRect = btn.getBoundingClientRect();
        const isIntersecting = !(btnRect.right < boxRect.left || 
                                 btnRect.left > boxRect.right || 
                                 btnRect.bottom < boxRect.top || 
                                 btnRect.top > boxRect.bottom);
        if (isIntersecting) {
          applyPaint(btn);
        }
      });
    } else {
      // Small/no movement means single click on a target
      const seat = e.target.closest('button[data-key]');
      if (seat) {
        applyPaint(seat);
      }
    }
    
    selectionBox.remove();
    selectionBox = null;
  }
  dragActive = false;
}

// Setup branch selector dropdown
function populateBranchSelect() {
  const select = document.getElementById('branch-select');
  select.innerHTML = BRANCH_DATA.map(b => `
    <option value="${b.id}" ${b.id === currentActiveBranchId ? 'selected' : ''}>📍 ${b.name}</option>
  `).join('');
}

function onBranchChange() {
  const select = document.getElementById('branch-select');
  currentActiveBranchId = parseInt(select.value);
  
  // Set first room of this branch active
  const branchRooms = ROOMS_DATA.filter(r => r.branchId === currentActiveBranchId);
  if (branchRooms.length > 0) {
    currentActiveRoomId = branchRooms[0].id;
  } else {
    currentActiveRoomId = null;
  }

  renderRoomList();
  renderGridEditor();
}

// Render sidebar rooms for current branch
function renderRoomList() {
  const list = document.getElementById('room-list');
  const branchRooms = ROOMS_DATA.filter(r => r.branchId === currentActiveBranchId);

  if (branchRooms.length === 0) {
    list.innerHTML = '<p class="text-xs text-slate-400 italic text-center py-4">Chưa có phòng chiếu nào ở cơ sở này.</p>';
    return;
  }

  list.innerHTML = branchRooms.map(room => {
    const isActive = room.id === currentActiveRoomId;
    return `
      <div class="flex items-center justify-between group rounded-xl p-1.5 ${
        isActive ? 'bg-brand/10 border-l-4 border-brand' : 'hover:bg-slate-50 border-l-4 border-transparent'
      }">
        <button onclick="setActiveRoom(${room.id})" class="flex-1 text-left px-2 py-1.5 text-xs font-bold text-slate-700 truncate ${
          isActive ? 'text-brand' : ''
        }">
          <i class="fas fa-couch mr-2 ${isActive ? 'text-brand' : 'text-slate-400'}"></i> ${room.name}
        </button>
        <button onclick="deleteRoom(event, ${room.id})" class="text-slate-300 hover:text-brand px-2 py-1 transition flex-shrink-0 opacity-0 group-hover:opacity-100" title="Xóa phòng này">
          <i class="fas fa-trash-alt text-xs"></i>
        </button>
      </div>
    `;
  }).join('');
}

function setActiveRoom(id) {
  currentActiveRoomId = id;
  renderRoomList();
  renderGridEditor();
}

// Drag select mode toggler
function toggleDragMode() {
  const toggle = document.getElementById('drag-mode-toggle');
  toggle.checked = !toggle.checked;
  isDragMode = toggle.checked;

  const helper = document.getElementById('drag-helper-text');
  if (isDragMode) {
    helper.classList.remove('hidden');
  } else {
    helper.classList.add('hidden');
  }
}

function stopDragDrawing() {
  isMousedown = false;
}

// Selecting color paint tool
function selectPaintTool(tool, btn) {
  currentPaintTool = tool;
  document.querySelectorAll('.paint-tool').forEach(b => {
    b.className = 'paint-tool border border-slate-200 px-3 py-1.5 rounded-lg flex items-center gap-1.5 bg-white transition hover:bg-slate-50';
  });
  
  let borderClass = 'border-brand';
  if(tool === 'VIP') borderClass = 'border-amber-500';
  if(tool === 'sold') borderClass = 'border-slate-500';
  if(tool === 'empty') borderClass = 'border-slate-300';
  
  btn.className = `paint-tool active border-2 ${borderClass} bg-white text-slate-800 px-3 py-1.5 rounded-lg flex items-center gap-1.5 transition font-bold`;
}

// Render grid editor canvas
function renderGridEditor() {
  const room = ROOMS_DATA.find(r => r.id === currentActiveRoomId);
  const branch = BRANCH_DATA.find(b => b.id === currentActiveBranchId);
  const grid = document.getElementById('editor-grid');
  
  if (!room || !branch) {
    document.getElementById('editor-room-title').textContent = "Không tìm thấy phòng";
    document.getElementById('editor-room-desc').textContent = "";
    document.getElementById('editor-branch-badge').classList.add('hidden');
    grid.innerHTML = '<div class="text-slate-400 py-10 font-bold text-center">Hãy thêm hoặc chọn một phòng chiếu để thiết kế sơ đồ ghế.</div>';
    updateStats(null);
    return;
  }

  document.getElementById('editor-room-title').textContent = room.name;
  const badge = document.getElementById('editor-branch-badge');
  badge.textContent = branch.name;
  badge.classList.remove('hidden');
  
  document.getElementById('editor-room-desc').textContent = `Cấu hình lưới: ${room.rows} hàng x ${room.cols} cột`;

  grid.innerHTML = '';
  
  // Headers (Column numbers)
  const headerDiv = document.createElement('div');
  headerDiv.className = 'flex items-center gap-2 mb-1';
  const labelSpacer = document.createElement('div');
  labelSpacer.className = 'w-6 text-center';
  headerDiv.appendChild(labelSpacer);

  const colContainer = document.createElement('div');
  colContainer.className = 'flex-1 flex justify-center gap-1.5';
  for (let c = 1; c <= room.cols; c++) {
    const colNum = document.createElement('div');
    colNum.className = 'w-7 text-center text-[10px] text-slate-400 font-bold font-mono';
    colNum.textContent = c;
    colContainer.appendChild(colNum);
  }
  headerDiv.appendChild(colContainer);
  const rightSpacer = document.createElement('div');
  rightSpacer.className = 'w-6';
  headerDiv.appendChild(rightSpacer);
  grid.appendChild(headerDiv);

  // Render rows
  for (let r = 0; r < room.rows; r++) {
    const rowChar = String.fromCharCode(65 + r);
    
    const rowDiv = document.createElement('div');
    rowDiv.className = 'flex items-center gap-2';
    
    // Row label (Left)
    const rowLabel = document.createElement('div');
    rowLabel.className = 'w-6 text-center text-xs text-slate-500 font-bold font-mono';
    rowLabel.textContent = rowChar;
    rowDiv.appendChild(rowLabel);
    
    // Seats container
    const seatsFlex = document.createElement('div');
    seatsFlex.className = 'flex-1 flex justify-center gap-1.5';
    
    for (let c = 1; c <= room.cols; c++) {
      const key = `${rowChar}:${c}`;
      const seatType = room.layout[key] || 'Standard';
      
      const seatBtn = document.createElement('button');
      seatBtn.dataset.key = key;
      seatBtn.dataset.type = seatType;
      
      let seatClass = 'seat-available';
      if (seatType === 'VIP' || seatType === 'vip') seatClass = 'seat-vip-available';
      else if (seatType === 'sold') seatClass = 'seat-sold';
      else if (seatType === 'empty') seatClass = 'seat-empty';
      
      seatBtn.className = `w-7 h-7 rounded text-[9px] font-bold font-mono flex items-center justify-center transition-all duration-150 ${seatClass}`;
      
      if (seatType !== 'empty') {
        seatBtn.textContent = `${rowChar}${c}`;
      } else {
        seatBtn.innerHTML = '<i class="fas fa-times text-slate-300 text-[8px]"></i>';
      }

      // Prevent HTML drag behaviors
      seatBtn.addEventListener('dragstart', (e) => e.preventDefault());

      // Bind interactions
      seatBtn.addEventListener('mousedown', (e) => {
        isMousedown = true;
        applyPaint(seatBtn);
      });

      seatBtn.addEventListener('mouseenter', () => {
        if (isDragMode && isMousedown) {
          applyPaint(seatBtn);
        }
      });

      seatsFlex.appendChild(seatBtn);
    }
    rowDiv.appendChild(seatsFlex);
    
    // Row label (Right)
    const rowLabelRight = document.createElement('div');
    rowLabelRight.className = 'w-6 text-center text-xs text-slate-500 font-bold font-mono';
    rowLabelRight.textContent = rowChar;
    rowDiv.appendChild(rowLabelRight);
    
    grid.appendChild(rowDiv);
  }

  updateStats(room);
}

// Paint logic execution
function applyPaint(btn) {
  const key = btn.dataset.key;
  const nextType = currentPaintTool;
  
  if (btn.dataset.type === nextType) return; // Skip if same type

  btn.classList.remove('seat-available', 'seat-vip-available', 'seat-sold', 'seat-empty');
  btn.dataset.type = nextType;
  btn.innerHTML = '';
  
  let newClass = 'seat-available';
  if (nextType === 'VIP') newClass = 'seat-vip-available';
  if (nextType === 'sold') newClass = 'seat-sold';
  if (nextType === 'empty') newClass = 'seat-empty';
  
  btn.className = `w-7 h-7 rounded text-[9px] font-bold font-mono flex items-center justify-center transition-all duration-150 ${newClass}`;
  
  const keyParts = key.split(':');
  if (nextType !== 'empty') {
    btn.textContent = `${keyParts[0]}${keyParts[1]}`;
  } else {
    btn.innerHTML = '<i class="fas fa-times text-slate-300 text-[8px]"></i>';
  }

  // Save to temporary memory layout
  const room = ROOMS_DATA.find(r => r.id === currentActiveRoomId);
  if (room) {
    room.layout[key] = nextType;
    updateStats(room);
  }
}

// Stats calculator
function updateStats(room) {
  const statsTotal = document.getElementById('stats-total');
  const statsNormal = document.getElementById('stats-normal');
  const statsVip = document.getElementById('stats-vip');
  const statsSold = document.getElementById('stats-sold');
  const statsEmpty = document.getElementById('stats-empty');

  if (!room) {
    statsTotal.textContent = 0;
    statsNormal.textContent = 0;
    statsVip.textContent = 0;
    statsSold.textContent = 0;
    statsEmpty.textContent = 0;
    return;
  }

  let total = 0, normal = 0, vip = 0, sold = 0, empty = 0;
  
  for (let r = 0; r < room.rows; r++) {
    const rowChar = String.fromCharCode(65 + r);
    for (let c = 1; c <= room.cols; c++) {
      const key = `${rowChar}:${c}`;
      const type = room.layout[key] || 'Standard';
      
      if (type === 'Standard') { total++; normal++; }
      else if (type === 'VIP') { total++; vip++; }
      else if (type === 'sold') { total++; sold++; }
      else if (type === 'empty') { empty++; }
    }
  }

  statsTotal.textContent = total;
  statsNormal.textContent = normal;
  statsVip.textContent = vip;
  statsSold.textContent = sold;
  statsEmpty.textContent = empty;
}

// Add branch modal open/close
function openAddBranchModal() {
  document.getElementById('new-branch-name').value = '';
  document.getElementById('add-branch-error').classList.add('hidden');
  document.getElementById('add-branch-modal').classList.remove('hidden');
}

function closeAddBranchModal() {
  document.getElementById('add-branch-modal').classList.add('hidden');
}

// Action: Create Branch
async function createBranch(e) {
  e.preventDefault();
  const name = document.getElementById('new-branch-name').value.trim();
  
  if (!name) return;

  // Assume address is same as name for simplicity, or hardcoded for now since UI doesn't have address input
  try {
    const res = await fetch(API_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        ...getAuthHeader()
      },
      body: JSON.stringify({ name, address: name })
    });
    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.detail || 'Lỗi khi tạo cơ sở');
    }
    
    showToast(`Đã thêm cơ sở: ${name}`);
    closeAddBranchModal();
    await loadTheaters(); // Reload to get new branch
  } catch (err) {
    document.getElementById('add-branch-error-msg').textContent = err.message;
    document.getElementById('add-branch-error').classList.remove('hidden');
  }
}

// Room management modal open/close
function openAddRoomModal() {
  // Suggest the next room number
  const branchRooms = ROOMS_DATA.filter(r => r.branchId === currentActiveBranchId);
  let nextNum = 1;
  if (branchRooms.length > 0) {
    // Attempt to extract numbers from names like "Phòng chiếu 3"
    const nums = branchRooms.map(r => {
      const match = r.name.match(/\d+/);
      return match ? parseInt(match[0]) : 0;
    });
    nextNum = Math.max(...nums) + 1;
  }

  document.getElementById('new-room-number').value = nextNum;
  document.getElementById('add-room-error').classList.add('hidden');
  document.getElementById('add-room-modal').classList.remove('hidden');
}

function closeAddRoomModal() {
  document.getElementById('add-room-modal').classList.add('hidden');
}

// Action: Create new room
async function createRoom(e) {
  e.preventDefault();
  const roomNum = parseInt(document.getElementById('new-room-number').value);
  const rows = parseInt(document.getElementById('new-room-rows').value);
  const cols = parseInt(document.getElementById('new-room-cols').value);
  
  if (!roomNum) return;

  const roomName = `Cinema ${roomNum}`;

  // Seed default seats (Center rows are VIP)
  const layout = {};
  for (let r = 0; r < rows; r++) {
    const rowChar = String.fromCharCode(65 + r);
    for (let c = 1; c <= cols; c++) {
      const key = `${rowChar}:${c}`;
      if (rows > 5 && r >= Math.floor(rows/2 - 1) && r <= Math.floor(rows/2 + 1)) {
        layout[key] = 'VIP';
      } else {
        layout[key] = 'Standard';
      }
    }
  }

  try {
    const res = await fetch(`${API_URL}${currentActiveBranchId}/rooms`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        ...getAuthHeader()
      },
      body: JSON.stringify({ name: roomName, rows, cols, layout })
    });
    
    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.detail || 'Lỗi khi tạo phòng');
    }
    
    showToast(`Tạo thành công ${roomName}!`);
    closeAddRoomModal();
    await loadTheaters();
  } catch (err) {
    document.getElementById('add-room-error-msg').textContent = err.message;
    document.getElementById('add-room-error').classList.remove('hidden');
  }
}

// Action: Delete room
async function deleteRoom(e, id) {
  e.stopPropagation();
  if (confirm("Bạn có chắc chắn muốn xóa phòng chiếu này vĩnh viễn?")) {
    try {
      const res = await fetch(`${API_URL}rooms/${id}`, {
        method: 'DELETE',
        headers: getAuthHeader()
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || 'Không thể xoá phòng');
      }
      showToast("Đã xóa phòng chiếu!");
      await loadTheaters();
    } catch (err) {
      alert(err.message);
    }
  }
}

// Action: Resize modal open
function openResizeModal() {
  const room = ROOMS_DATA.find(r => r.id === currentActiveRoomId);
  if (!room) return;

  document.getElementById('resize-rows').value = room.rows;
  document.getElementById('resize-cols').value = room.cols;
  document.getElementById('resize-modal').classList.remove('hidden');
}

function closeResizeModal() {
  document.getElementById('resize-modal').classList.add('hidden');
}

// Action: Resize layout
function resizeCurrentRoom(e) {
  e.preventDefault();
  const room = ROOMS_DATA.find(r => r.id === currentActiveRoomId);
  if (!room) return;

  const newRows = parseInt(document.getElementById('resize-rows').value);
  const newCols = parseInt(document.getElementById('resize-cols').value);

  if (newRows > 15 || newCols > 20) {
    alert("Kích thước quá lớn. Giới hạn: tối đa 15 hàng x 20 cột.");
    return;
  }

  const newLayout = {};
  for (let r = 0; r < newRows; r++) {
    const rowChar = String.fromCharCode(65 + r);
    for (let c = 1; c <= newCols; c++) {
      const key = `${rowChar}:${c}`;
      if (room.layout[key]) {
        newLayout[key] = room.layout[key];
      } else {
        newLayout[key] = (r >= 3 && r <= 5) ? 'VIP' : 'Standard';
      }
    }
  }

  room.rows = newRows;
  room.cols = newCols;
  room.layout = newLayout;
  
  showToast("Thay đổi kích thước thành công!");
  closeResizeModal();
  renderGridEditor();
}

// Save layout configuration
async function saveLayout() {
  const room = ROOMS_DATA.find(r => r.id === currentActiveRoomId);
  if (!room) return;

  try {
    const res = await fetch(`${API_URL}rooms/${room.id}/layout`, {
      method: 'PUT',
      headers: {
        'Content-Type': 'application/json',
        ...getAuthHeader()
      },
      body: JSON.stringify({ rows: room.rows, cols: room.cols, layout: room.layout })
    });
    
    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.detail || 'Lỗi lưu sơ đồ');
    }
    
    showToast("Đã lưu sơ đồ ghế thành công!");
    await loadTheaters();
  } catch(err) {
    alert(err.message);
  }
}

function showToast(text) {
  const toast = document.getElementById('toast');
  document.getElementById('toast-text').textContent = text;
  
  toast.classList.remove('opacity-0', 'translate-y-[-20px]', 'pointer-events-none');
  toast.classList.add('opacity-100', 'translate-y-0');
  
  setTimeout(() => {
    toast.classList.remove('opacity-100', 'translate-y-0');
    toast.classList.add('opacity-0', 'translate-y-[-20px]', 'pointer-events-none');
  }, 2500);
}
</script>
