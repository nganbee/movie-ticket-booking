<!-- Transaction Management Page -->
<div>
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h2 class="text-2xl font-extrabold text-slate-800">Quản lý Giao dịch</h2>
      <p class="text-slate-400 text-sm mt-1">Theo dõi danh sách các đơn đặt vé xem phim, trạng thái thanh toán và thông tin giao dịch.</p>
    </div>
    <div class="flex gap-2">
      <button onclick="exportTransactions()" class="px-4 py-2 border border-slate-200 bg-white hover:bg-slate-50 text-slate-700 rounded-xl text-xs font-bold transition flex items-center gap-1.5">
        <i class="fas fa-file-export"></i> Xuất báo cáo Excel
      </button>
    </div>
  </div>

  <!-- Filter & Search Controls -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-4 mb-6 flex flex-col md:flex-row gap-4 items-stretch md:items-center">
    <!-- Search -->
    <div class="relative flex-1">
      <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i>
      <input id="trans-search" type="text" placeholder="Tìm theo Mã giao dịch, Tên khách hàng, Tên phim..." oninput="renderTransactions()"
        class="w-full border border-slate-200 bg-slate-50 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition">
    </div>

    <!-- Status filter tabs -->
    <div class="flex flex-wrap gap-2 items-center">
      <label class="text-xs font-bold text-slate-500 uppercase whitespace-nowrap">Bộ lọc:</label>
      <button onclick="setStatusFilter('all', this)" class="trans-filter-btn active text-xs font-bold px-3.5 py-2 rounded-xl border border-brand bg-brand text-white transition">Tất cả</button>
      <button onclick="setStatusFilter('Paid', this)" class="trans-filter-btn text-xs font-bold px-3.5 py-2 rounded-xl border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">🟢 Đã thanh toán</button>
      <button onclick="setStatusFilter('Cancelled', this)" class="trans-filter-btn text-xs font-bold px-3.5 py-2 rounded-xl border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">🔴 Đã hủy</button>
      <button onclick="setStatusFilter('Pending', this)" class="trans-filter-btn text-xs font-bold px-3.5 py-2 rounded-xl border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">🟡 Chờ thanh toán</button>
    </div>
  </div>

  <!-- Data Table Panel -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-100 text-xs font-bold text-slate-500 uppercase tracking-wider">
            <th class="px-6 py-4">Mã giao dịch</th>
            <th class="px-6 py-4">Khách hàng</th>
            <th class="px-6 py-4">Bộ phim / Suất chiếu</th>
            <th class="px-6 py-4 text-center">Ghế ngồi</th>
            <th class="px-6 py-4 text-right">Tổng tiền</th>
            <th class="px-6 py-4">Trạng thái</th>
            <th class="px-6 py-4 text-center">Hành động</th>
          </tr>
        </thead>
        <tbody id="trans-tbody" class="divide-y divide-slate-100 text-sm text-slate-700 font-medium">
          <!-- Rows will be injected here -->
        </tbody>
      </table>
    </div>

    <!-- Empty State -->
    <div id="trans-empty" class="hidden py-24 text-center">
      <i class="fas fa-history text-5xl text-slate-200 mb-4"></i>
      <p class="text-slate-400 font-medium">Không tìm thấy giao dịch nào</p>
    </div>

    <!-- Pagination Footer -->
    <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between text-xs text-slate-400 font-medium flex-wrap gap-2">
      <span id="trans-summary-text">Hiển thị 0 đơn hàng</span>
      <div class="flex items-center gap-1">
        <button class="w-8 h-8 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-500 flex items-center justify-center transition disabled:opacity-40" disabled><i class="fas fa-chevron-left text-[10px]"></i></button>
        <button class="w-8 h-8 rounded-lg bg-brand text-white font-bold flex items-center justify-center">1</button>
        <button class="w-8 h-8 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-500 flex items-center justify-center transition disabled:opacity-40" disabled><i class="fas fa-chevron-right text-[10px]"></i></button>
      </div>
    </div>
  </div>
</div>

<!-- ===================================================================
     MODAL: CHI TIẾT ĐƠN HÀNG (RECEIPT VIEWER)
=================================================================== -->
<div id="receipt-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeReceiptModal()"></div>
  
  <div class="relative bg-white rounded-3xl shadow-2xl w-full max-w-md z-10 overflow-hidden flex flex-col">
    <!-- Receipt graphic border -->
    <div class="h-2 bg-gradient-to-r from-emerald-400 to-teal-500"></div>

    <!-- Header -->
    <div class="p-6 border-b border-slate-100 flex items-center justify-between flex-shrink-0">
      <div>
        <h3 class="font-extrabold text-slate-800 text-base flex items-center gap-2">
          <i class="fas fa-ticket-alt text-brand"></i> Chi Tiết Hóa Đơn
        </h3>
        <p id="receipt-id-title" class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">MÃ GD: CB-921820</p>
      </div>
      <button onclick="closeReceiptModal()" class="text-slate-400 hover:text-slate-600 transition w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-100">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <!-- Scrollable content -->
    <div class="p-6 overflow-y-auto flex-1 space-y-5 text-sm">
      <!-- Status Box -->
      <div id="receipt-status-banner" class="rounded-xl px-4 py-3 flex items-center gap-3">
        <i id="receipt-status-icon" class="fas text-lg"></i>
        <div>
          <p id="receipt-status-label" class="font-bold text-xs uppercase tracking-wider">Đã Thanh Toán</p>
          <p id="receipt-time" class="text-[10px] text-slate-500 font-medium">10:24 - 04/06/2026</p>
        </div>
      </div>

      <!-- Movie Card Info -->
      <div class="flex gap-4 bg-slate-50 p-4 rounded-xl border border-slate-100">
        <div class="w-16 h-24 rounded-lg overflow-hidden border border-slate-200 flex-shrink-0 bg-slate-200">
          <img id="receipt-movie-poster" src="" alt="Movie Poster" class="w-full h-full object-cover">
        </div>
        <div class="flex-1">
          <h4 id="receipt-movie-title" class="font-extrabold text-slate-800 text-sm line-clamp-2">Lật Mặt 7: Một Điều Ước</h4>
          <span id="receipt-movie-genre" class="inline-block text-[9px] font-bold text-slate-400 bg-white border border-slate-200 px-2 py-0.5 rounded mt-1">GIA ĐÌNH, KỊCH TÍNH</span>
          
          <div class="mt-3 text-xs space-y-0.5 font-semibold text-slate-600">
            <p><i class="far fa-clock mr-1.5 text-slate-400"></i><span id="receipt-showtime">09:30 - Thứ 5, 04/06/2026</span></p>
            <p><i class="fas fa-couch mr-1.5 text-slate-400"></i><span id="receipt-room">Phòng Chiếu 1</span></p>
          </div>
        </div>
      </div>

      <!-- Customer detail rows -->
      <div class="border-t border-slate-100 pt-4 space-y-2.5 font-semibold text-slate-600 text-xs">
        <div class="flex justify-between">
          <span class="text-slate-400">Khách hàng:</span>
          <span id="receipt-cust-name" class="text-slate-800 font-bold">Nguyễn Văn A</span>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-400">Email liên hệ:</span>
          <span id="receipt-cust-email" class="text-slate-800 font-bold">customer@gmail.com</span>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-400">Ghế đã chọn:</span>
          <span id="receipt-seats" class="text-brand font-bold text-sm">E5, E6</span>
        </div>
        <div class="flex justify-between border-b border-dashed border-slate-100 pb-3">
          <span class="text-slate-400">Phương thức thanh toán:</span>
          <span id="receipt-method" class="text-slate-800 font-bold flex items-center gap-1"><i class="fas fa-credit-card text-emerald-500"></i> VNPAY (Thẻ nội địa)</span>
        </div>
      </div>

      <!-- Financial Sums -->
      <div class="space-y-1.5 text-xs font-semibold text-slate-600">
        <div class="flex justify-between">
          <span>Tiền vé:</span>
          <span id="receipt-ticket-subtotal">190.000đ</span>
        </div>
        <div class="flex justify-between">
          <span>Phụ phí / Dịch vụ:</span>
          <span>0đ</span>
        </div>
        <div class="flex justify-between text-sm pt-2 border-t border-slate-200">
          <span class="text-slate-800 font-bold">Tổng thanh toán:</span>
          <span id="receipt-total" class="text-brand font-extrabold text-lg">190.000đ</span>
        </div>
      </div>
    </div>

    <!-- Footer buttons -->
    <div class="px-6 py-4 border-t border-slate-100 flex justify-end gap-3 bg-slate-50 rounded-b-3xl">
      <button onclick="closeReceiptModal()" class="w-full py-2.5 bg-slate-800 hover:bg-slate-900 text-white rounded-xl text-xs font-bold transition shadow-md">
        Đóng hóa đơn
      </button>
    </div>
  </div>
</div>

<script>
let TRANSACTION_DATA = [];
let currentFilterStatus = 'all';

// Seed Transaction Data
const SEED_TRANSACTIONS = [
  {
    id: "CB-773829",
    customerName: "Nguyễn Hoàng Nam",
    customerEmail: "nam.nguyen@gmail.com",
    movieTitle: "Lật Mặt 7: Một Điều Ước",
    movieGenre: "Gia đình, Kịch tính",
    poster: "https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=500&auto=format&fit=crop&q=80",
    showtime: "09:30 - Thứ 5, 04/06/2026",
    room: "Phòng Chiếu 1 (Standard)",
    seats: "D6, D7",
    amount: 190000,
    status: "Paid", // 'Paid', 'Cancelled', 'Pending'
    time: "10:24 - 04/06/2026",
    method: "VNPAY (Thẻ nội địa)"
  },
  {
    id: "CB-129847",
    customerName: "Trần Thị Lan",
    customerEmail: "lan.tran@yahoo.com",
    movieTitle: "Mai",
    movieGenre: "Tâm lý, Tình cảm",
    poster: "https://images.unsplash.com/photo-1485846234645-a62644f84728?w=500&auto=format&fit=crop&q=80",
    showtime: "15:30 - Thứ 5, 04/06/2026",
    room: "Phòng Chiếu 2 (IMAX)",
    seats: "F4",
    amount: 120000,
    status: "Paid",
    time: "08:15 - 04/06/2026",
    method: "VNPAY (Thẻ nội địa)"
  },
  {
    id: "CB-449301",
    customerName: "Phạm Minh Quân",
    customerEmail: "quan.pm@gmail.com",
    movieTitle: "Dune: Phần Hai",
    movieGenre: "Khoa học viễn tưởng, Hành động",
    poster: "https://images.unsplash.com/photo-1536440136628-849c177e76a1?w=500&auto=format&fit=crop&q=80",
    showtime: "20:00 - Thứ 6, 05/06/2026",
    room: "Phòng Chiếu 3 (Gold Class)",
    seats: "C3, C4",
    amount: 320000,
    status: "Cancelled",
    time: "11:05 - 04/06/2026",
    method: "Đã hết hạn phiên giao dịch"
  },
  {
    id: "CB-902174",
    customerName: "Lê Thu Thảo",
    customerEmail: "thao.le98@hotmail.com",
    movieTitle: "Lật Mặt 7: Một Điều Ước",
    movieGenre: "Gia đình, Kịch tính",
    poster: "https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=500&auto=format&fit=crop&q=80",
    showtime: "12:15 - Thứ 5, 04/06/2026",
    room: "Phòng Chiếu 1 (Standard)",
    seats: "E8, E9, E10",
    amount: 300000,
    status: "Pending",
    time: "12:11 - 04/06/2026",
    method: "Đang chờ VNPAY phản hồi..."
  }
];

document.addEventListener('DOMContentLoaded', () => {
  const stored = localStorage.getItem('cinebook_transactions');
  if (stored) {
    TRANSACTION_DATA = JSON.parse(stored);
  } else {
    TRANSACTION_DATA = SEED_TRANSACTIONS;
    localStorage.setItem('cinebook_transactions', JSON.stringify(TRANSACTION_DATA));
  }
  
  renderTransactions();
});

// Render table
function renderTransactions() {
  const search = document.getElementById('trans-search').value.toLowerCase();
  
  const filtered = TRANSACTION_DATA.filter(t => {
    const matchSearch = t.id.toLowerCase().includes(search) ||
                        t.customerName.toLowerCase().includes(search) ||
                        t.movieTitle.toLowerCase().includes(search);
    const matchStatus = currentFilterStatus === 'all' || t.status === currentFilterStatus;
    
    return matchSearch && matchStatus;
  });

  const tbody = document.getElementById('trans-tbody');
  const empty = document.getElementById('trans-empty');
  const summary = document.getElementById('trans-summary-text');

  summary.textContent = `Hiển thị ${filtered.length} đơn hàng trong danh sách`;

  if (filtered.length === 0) {
    tbody.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  tbody.innerHTML = filtered.map(t => {
    let statusClass = 'bg-slate-100 text-slate-600';
    let statusLabel = 'Không rõ';
    
    if (t.status === 'Paid') {
      statusClass = 'bg-emerald-50 text-emerald-600 border border-emerald-200';
      statusLabel = 'Đã thanh toán';
    } else if (t.status === 'Cancelled') {
      statusClass = 'bg-rose-50 text-rose-600 border border-rose-200';
      statusLabel = 'Đã hủy';
    } else if (t.status === 'Pending') {
      statusClass = 'bg-amber-50 text-amber-600 border border-amber-200';
      statusLabel = 'Chờ thanh toán';
    }

    return `
      <tr class="hover:bg-slate-50 transition-colors">
        <td class="px-6 py-4 font-mono font-bold text-xs text-slate-800">${t.id}</td>
        <td class="px-6 py-4">
          <p class="font-bold text-slate-800 text-xs">${t.customerName}</p>
          <p class="text-[10px] text-slate-400 mt-0.5">${t.customerEmail}</p>
        </td>
        <td class="px-6 py-4">
          <p class="font-bold text-slate-800 text-xs">${t.movieTitle}</p>
          <p class="text-[10px] text-slate-400 mt-0.5">${t.showtime}</p>
        </td>
        <td class="px-6 py-4 text-center font-bold text-xs text-brand">${t.seats}</td>
        <td class="px-6 py-4 text-right font-extrabold text-slate-800 text-xs">${new Intl.NumberFormat('vi-VN').format(t.amount)}đ</td>
        <td class="px-6 py-4">
          <span class="text-[10px] font-extrabold uppercase px-2.5 py-1 rounded-full ${statusClass}">${statusLabel}</span>
        </td>
        <td class="px-6 py-4 text-center">
          <button onclick="openReceiptModal('${t.id}')" class="text-xs font-bold text-brand hover:text-red-700 transition flex items-center gap-1 justify-center mx-auto">
            <i class="fas fa-receipt text-[10px]"></i> Xem hóa đơn
          </button>
        </td>
      </tr>
    `;
  }).join('');
}

// Filter configuration
function setStatusFilter(status, btn) {
  currentFilterStatus = status;
  document.querySelectorAll('.trans-filter-btn').forEach(b => {
    b.className = 'trans-filter-btn text-xs font-bold px-3.5 py-2 rounded-xl border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition';
  });
  btn.className = 'trans-filter-btn active text-xs font-bold px-3.5 py-2 rounded-xl border border-brand bg-brand text-white transition';
  renderTransactions();
}

// Receipt Modal Controls
function openReceiptModal(id) {
  const t = TRANSACTION_DATA.find(x => x.id === id);
  if (!t) return;

  document.getElementById('receipt-id-title').textContent = `MÃ GD: ${t.id}`;
  document.getElementById('receipt-time').textContent = t.time;
  document.getElementById('receipt-movie-poster').src = t.poster;
  document.getElementById('receipt-movie-title').textContent = t.movieTitle;
  document.getElementById('receipt-movie-genre').textContent = t.movieGenre.toUpperCase();
  document.getElementById('receipt-showtime').textContent = t.showtime;
  document.getElementById('receipt-room').textContent = t.room;
  document.getElementById('receipt-cust-name').textContent = t.customerName;
  document.getElementById('receipt-cust-email').textContent = t.customerEmail;
  document.getElementById('receipt-seats').textContent = t.seats;
  document.getElementById('receipt-method').innerHTML = t.status === 'Cancelled'
    ? `<i class="fas fa-ban text-rose-500"></i> ${t.method}`
    : `<i class="fas fa-credit-card text-emerald-500"></i> ${t.method}`;
  
  const formattedAmount = new Intl.NumberFormat('vi-VN').format(t.amount) + 'đ';
  document.getElementById('receipt-ticket-subtotal').textContent = formattedAmount;
  document.getElementById('receipt-total').textContent = formattedAmount;

  // Build status banner style
  const banner = document.getElementById('receipt-status-banner');
  const icon = document.getElementById('receipt-status-icon');
  const label = document.getElementById('receipt-status-label');

  banner.className = 'rounded-xl px-4 py-3 flex items-center gap-3';
  icon.className = 'fas text-lg';

  if (t.status === 'Paid') {
    banner.classList.add('bg-emerald-50', 'text-emerald-800', 'border', 'border-emerald-100');
    icon.classList.add('fa-check-circle', 'text-emerald-500');
    label.textContent = "Đã Thanh Toán";
  } else if (t.status === 'Cancelled') {
    banner.classList.add('bg-rose-50', 'text-rose-800', 'border', 'border-rose-100');
    icon.classList.add('fa-times-circle', 'text-rose-500');
    label.textContent = "Đã Hủy Giao Dịch";
  } else if (t.status === 'Pending') {
    banner.classList.add('bg-amber-50', 'text-amber-800', 'border', 'border-amber-100');
    icon.classList.add('fa-clock', 'text-amber-500');
    label.textContent = "Chờ Thanh Toán";
  }

  document.getElementById('receipt-modal').classList.remove('hidden');
}

function closeReceiptModal() {
  document.getElementById('receipt-modal').classList.add('hidden');
}

// Export excel simulation
function exportTransactions() {
  alert("🟢 Đã khởi tạo và tải xuống báo cáo giao dịch (dạng Excel/CSV) thành công!");
}
</script>
