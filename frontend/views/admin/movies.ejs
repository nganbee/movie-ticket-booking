     MODAL: XÁC NHẬN XÓA PHIM
=================================================================== -->
<div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeDeleteModal()"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm z-10 p-6 text-center">
    <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4">
      <i class="fas fa-trash-alt text-2xl text-brand"></i>
    </div>
    <h3 class="text-lg font-bold text-slate-800 mb-2">Xóa bộ phim này?</h3>
    <p class="text-sm text-slate-400 mb-6 leading-relaxed">Thông tin phim sẽ bị xóa vĩnh viễn khỏi danh sách và không thể khôi phục lại.</p>
    <div class="flex gap-3">
      <button onclick="closeDeleteModal()" class="flex-1 px-4 py-2.5 rounded-xl text-sm font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 transition">Hủy</button>
      <button onclick="confirmDelete()" class="flex-1 px-4 py-2.5 rounded-xl text-sm font-bold text-white bg-brand hover:bg-brandHover transition">Xóa ngay</button>
    </div>
  </div>
</div>

<!-- Notification Toast -->
<div id="toast" class="fixed top-24 right-8 bg-slate-900 text-white px-5 py-3 rounded-xl shadow-2xl flex items-center gap-3 transition-all duration-300 opacity-0 translate-y-[-20px] pointer-events-none z-50">
  <i id="toast-icon" class="fas fa-check-circle text-emerald-400"></i>
  <span id="toast-text" class="text-xs font-bold">Lưu phim thành công!</span>
</div>

<script>
let MOVIE_DATA = [];
let deleteTargetId = null;

// API Helpers
const API_URL = 'http://localhost:8000/movies';
function getAuthHeader() {
  const token = localStorage.getItem('access_token');
  return token ? { 'Authorization': `Bearer ${token}` } : {};
}

document.addEventListener('DOMContentLoaded', async () => {
  await loadMovies();
  initDragAndDrop('poster');
  initDragAndDrop('backdrop');
});

async function loadMovies() {
  try {
    const res = await fetch(`${API_URL}/?limit=100`);
    if (!res.ok) throw new Error('Failed to load movies');
    const data = await res.json();
    // Assuming data is { items: [...], total: ... }
    MOVIE_DATA = data.items.map(m => ({
      id: m.movie_id,
      title: m.title,
      genre: m.genre,
      rating: m.imdb_rating,
      duration: m.duration,
      director: m.director,
      cast: 'Đang cập nhật...', // Tạm thời
      description: m.description,
      trailer: 'https://youtube.com', // Tạm thời
      poster: m.poster_url,
      backdrop: m.backdrop_url || m.poster_url,
      status: m.status,
      language: m.language,
      release_date: m.release_date
    }));
    renderMovies();
  } catch (err) {
    console.error(err);
    showFormError('Không thể tải dữ liệu từ máy chủ.');
  }
}


// Drag and drop setup helper
function initDragAndDrop(type) {
  const dropzone = document.getElementById(`${type}-dropzone`);
  const fileInput = document.getElementById(`${type}-file`);

  dropzone.addEventListener('click', () => fileInput.click());

  dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('border-brand', 'bg-slate-50');
  });

  dropzone.addEventListener('dragleave', () => {
    dropzone.classList.remove('border-brand', 'bg-slate-50');
  });

  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-brand', 'bg-slate-50');
    if (e.dataTransfer.files.length) {
      handleFile(e.dataTransfer.files[0], type);
    }
  });

  fileInput.addEventListener('change', (e) => {
    if (e.target.files.length) {
      handleFile(e.target.files[0], type);
    }
  });
}

function handleFile(file, type) {
  if (!file.type.startsWith('image/')) {
    showFormError(`Chỉ được tải lên file ảnh cho ${type}!`);
    return;
  }
  
  const reader = new FileReader();
  reader.onload = function(e) {
    const dataUrl = e.target.result;
    document.getElementById(`form-${type}-url`).value = dataUrl;
    document.getElementById(`${type}-preview`).src = dataUrl;
    document.getElementById(`${type}-preview-container`).classList.remove('hidden');
    document.getElementById(`${type}-upload-icon`).classList.add('hidden');
  };
  reader.readAsDataURL(file);
}

function removePoster(e) {
  e.stopPropagation();
  document.getElementById('form-poster-url').value = '';
  document.getElementById('poster-preview').src = '';
  document.getElementById('poster-preview-container').classList.add('hidden');
  document.getElementById('poster-upload-icon').classList.remove('hidden');
}

function removeBackdrop(e) {
  e.stopPropagation();
  document.getElementById('form-backdrop-url').value = '';
  document.getElementById('backdrop-preview').src = '';
  document.getElementById('backdrop-preview-container').classList.add('hidden');
  document.getElementById('backdrop-upload-icon').classList.remove('hidden');
}

// Render grid
function renderMovies() {
  const search = document.getElementById('movie-search').value.toLowerCase();
  const status = document.getElementById('status-filter').value;

  const filtered = MOVIE_DATA.filter(m => {
    const matchSearch = m.title.toLowerCase().includes(search) || 
                        m.director.toLowerCase().includes(search) || 
                        m.genre.toLowerCase().includes(search);
    const matchStatus = status === 'all' || m.status === status;
    return matchSearch && matchStatus;
  });

  const grid = document.getElementById('movie-grid');
  const empty = document.getElementById('movie-empty');
  const count = document.getElementById('movie-count');

  count.textContent = `Tổng cộng: ${filtered.length} bộ phim`;

  if (filtered.length === 0) {
    grid.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  grid.innerHTML = filtered.map(m => `
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col group hover:shadow-lg transition-all duration-300">
      <!-- Media section -->
      <div class="relative h-48 bg-slate-900 overflow-hidden flex-shrink-0">
        <img src="${m.backdrop || m.poster}" alt="backdrop" class="w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-500">
        <!-- Floating overlay tags -->
        <span class="absolute top-4 left-4 text-xs font-bold px-3 py-1.5 rounded-xl ${
          m.status === 'now_showing' ? 'bg-emerald-500 text-white' : 'bg-blue-500 text-white'
        }">
          ${m.status === 'now_showing' ? '🎬 Đang chiếu' : '📅 Sắp chiếu'}
        </span>
        <span class="absolute top-4 right-4 text-xs font-bold bg-slate-900/80 text-yellow-400 border border-yellow-400/30 px-2 py-1 rounded-lg flex items-center gap-1">
          <i class="fas fa-star text-[10px]"></i> ${m.rating}
        </span>
      </div>

      <!-- Info content -->
      <div class="p-5 flex-grow flex flex-col relative">
        <!-- Float mini poster -->
        <div class="absolute -top-16 left-5 w-20 h-28 rounded-lg overflow-hidden border-2 border-white shadow-md bg-slate-100 z-10">
          <img src="${m.poster}" alt="poster" class="w-full h-full object-cover">
        </div>

        <div class="pl-24 min-h-[72px] mb-4">
          <h3 class="font-extrabold text-slate-800 text-base leading-snug group-hover:text-brand transition-colors line-clamp-2">${m.title}</h3>
          <p class="text-[11px] font-bold text-slate-400 uppercase tracking-wide mt-1">${m.genre}</p>
        </div>

        <div class="space-y-2 border-t border-slate-100 pt-4 flex-grow">
          <div class="flex justify-between text-xs">
            <span class="text-slate-400">Thời lượng:</span>
            <span class="font-semibold text-slate-700">${m.duration} phút</span>
          </div>
          <div class="flex justify-between text-xs">
            <span class="text-slate-400">Đạo diễn:</span>
            <span class="font-semibold text-slate-700">${m.director}</span>
          </div>
          <div class="flex flex-col gap-1 text-xs">
            <span class="text-slate-400">Diễn viên chính:</span>
            <span class="font-semibold text-slate-700 line-clamp-1">${m.cast}</span>
          </div>
          <div class="flex flex-col gap-1 text-xs">
            <span class="text-slate-400">Mô tả tóm tắt:</span>
            <span class="text-slate-500 line-clamp-3 leading-relaxed">${m.description}</span>
          </div>
        </div>

        <!-- Action panel -->
        <div class="flex items-center justify-between border-t border-slate-100 mt-4 pt-3 flex-shrink-0">
          <a href="${m.trailer}" target="_blank" class="text-xs font-bold text-slate-500 hover:text-brand flex items-center gap-1 transition">
            <i class="fab fa-youtube text-red-500"></i> Xem Trailer
          </a>
          <div class="flex gap-1">
            <button onclick="openEditModal(${m.id})" class="p-2 text-slate-400 hover:text-blue-500 hover:bg-blue-50 rounded-lg transition" title="Chỉnh sửa">
              <i class="fas fa-edit text-xs"></i>
            </button>
            <button onclick="openDeleteModal(${m.id})" class="p-2 text-slate-400 hover:text-brand hover:bg-red-50 rounded-lg transition" title="Xóa">
              <i class="fas fa-trash-alt text-xs"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  `).join('');
}

// Modals
function openAddModal() {
  document.getElementById('modal-title').textContent = '🎬 Thêm Phim Mới';
  document.getElementById('form-id').value = '';
  document.getElementById('movie-form').reset();
  
  // Clear file upload previews
  removePoster(new Event('click'));
  removeBackdrop(new Event('click'));
  
  document.getElementById('form-error').classList.add('hidden');
  document.getElementById('movie-modal').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}

function openEditModal(id) {
  const m = MOVIE_DATA.find(x => x.id === id);
  if (!m) return;

  document.getElementById('modal-title').textContent = '🎬 Chỉnh Sửa Phim';
  document.getElementById('form-id').value = m.id;
  document.getElementById('form-title').value = m.title;
  document.getElementById('form-genre').value = m.genre;
  document.getElementById('form-rating').value = m.rating;
  document.getElementById('form-duration').value = m.duration;
  document.getElementById('form-director').value = m.director;
  document.getElementById('form-cast').value = m.cast;
  document.getElementById('form-description').value = m.description;
  document.getElementById('form-trailer').value = m.trailer;
  document.getElementById('form-status').value = m.status;
  document.getElementById('form-language').value = m.language || 'EN';
  document.getElementById('form-release-date').value = m.release_date || '';

  // Set file urls & previews
  if (m.poster) {
    document.getElementById('form-poster-url').value = m.poster;
    document.getElementById('poster-preview').src = m.poster;
    document.getElementById('poster-preview-container').classList.remove('hidden');
    document.getElementById('poster-upload-icon').classList.add('hidden');
  } else {
    removePoster(new Event('click'));
  }

  if (m.backdrop) {
    document.getElementById('form-backdrop-url').value = m.backdrop;
    document.getElementById('backdrop-preview').src = m.backdrop;
    document.getElementById('backdrop-preview-container').classList.remove('hidden');
    document.getElementById('backdrop-upload-icon').classList.add('hidden');
  } else {
    removeBackdrop(new Event('click'));
  }

  document.getElementById('form-error').classList.add('hidden');
  document.getElementById('movie-modal').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('movie-modal').classList.add('hidden');
  document.body.style.overflow = '';
}

function showFormError(msg) {
  const errEl = document.getElementById('form-error');
  document.getElementById('form-error-msg').textContent = msg;
  errEl.classList.remove('hidden');
  document.getElementById('movie-form').scrollTop = document.getElementById('movie-form').scrollHeight;
}

async function syncMovieData() {
  const title = document.getElementById('form-title').value.trim();
  if (!title) {
    showFormError("Vui lòng nhập tên phim để đồng bộ.");
    return;
  }
  
  const syncBtn = document.getElementById('sync-icon');
  syncBtn.classList.add('fa-spin');
  document.getElementById('form-error').classList.add('hidden');
  
  try {
    const res = await fetch(`${API_URL}/sync/?title=${encodeURIComponent(title)}`, {
      headers: getAuthHeader()
    });
    
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.detail || "Không thể đồng bộ thông tin phim.");
    }
    
    const data = await res.json();
    
    if (data.title) document.getElementById('form-title').value = data.title;
    if (data.genre) document.getElementById('form-genre').value = data.genre;
    if (data.duration) document.getElementById('form-duration').value = data.duration;
    if (data.director) document.getElementById('form-director').value = data.director;
    if (data.description) document.getElementById('form-description').value = data.description;
    if (data.imdb_rating) document.getElementById('form-rating').value = data.imdb_rating;
    if (data.language) document.getElementById('form-language').value = data.language;
    if (data.release_date) document.getElementById('form-release-date').value = data.release_date;
    
    if (data.poster_url) {
      document.getElementById('form-poster-url').value = data.poster_url;
      document.getElementById('poster-preview').src = data.poster_url;
      document.getElementById('poster-preview-container').classList.remove('hidden');
      document.getElementById('poster-upload-icon').classList.add('hidden');
    }
    
    if (data.backdrop_url) {
      document.getElementById('form-backdrop-url').value = data.backdrop_url;
      document.getElementById('backdrop-preview').src = data.backdrop_url;
      document.getElementById('backdrop-preview-container').classList.remove('hidden');
      document.getElementById('backdrop-upload-icon').classList.add('hidden');
    }
    
    showToast("Đã đồng bộ thông tin thành công!");
  } catch (err) {
    showFormError(err.message);
  } finally {
    syncBtn.classList.remove('fa-spin');
  }
}

async function saveMovie(e) {
  e.preventDefault();
  const id = document.getElementById('form-id').value;
  
  const moviePayload = {
    title: document.getElementById('form-title').value.trim(),
    genre: document.getElementById('form-genre').value.trim(),
    description: document.getElementById('form-description').value.trim(),
    director: document.getElementById('form-director').value.trim(),
    duration: parseInt(document.getElementById('form-duration').value),
    imdb_rating: parseFloat(document.getElementById('form-rating').value),
    status: document.getElementById('form-status').value,
    language: document.getElementById('form-language').value.trim(),
    release_date: document.getElementById('form-release-date').value,
    poster_url: document.getElementById('form-poster-url').value,
    backdrop_url: document.getElementById('form-backdrop-url').value
  };

  // Validation
  if (moviePayload.imdb_rating < 0 || moviePayload.imdb_rating > 10) {
    showFormError("Điểm đánh giá phải thuộc phạm vi 0.0 - 10.0.");
    return;
  }
  if (moviePayload.duration <= 0) {
    showFormError("Thời lượng phim phải lớn hơn 0 phút.");
    return;
  }
  if (!moviePayload.poster_url) {
    showFormError("Vui lòng tải lên ảnh Poster cho phim.");
    return;
  }
  if (!moviePayload.backdrop_url) {
    showFormError("Vui lòng tải lên ảnh Banner/Backdrop cho phim.");
    return;
  }

  document.getElementById('form-error').classList.add('hidden');
  const btn = document.getElementById('save-movie-btn');
  const oldHtml = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';

  try {
    let url = `${API_URL}/`;
    let method = 'POST';
    if (id) {
      url = `${API_URL}/${id}`;
      method = 'PUT';
    }

    const res = await fetch(url, {
      method: method,
      headers: {
        'Content-Type': 'application/json',
        ...getAuthHeader()
      },
      body: JSON.stringify(moviePayload)
    });

    if (!res.ok) {
      const errData = await res.json().catch(() => ({}));
      throw new Error(errData.detail || 'Failed to save movie');
    }

    showToast(id ? "Đã cập nhật thông tin phim thành công!" : "Đã thêm phim mới thành công!");
    closeModal();
    await loadMovies();
  } catch (err) {
    console.error(err);
    showFormError(err.message || 'Lỗi kết nối tới máy chủ.');
  } finally {
    btn.disabled = false;
    btn.innerHTML = oldHtml;
  }
}

// Delete Movie
function openDeleteModal(id) {
  deleteTargetId = id;
  document.getElementById('delete-modal').classList.remove('hidden');
}

function closeDeleteModal() {
  deleteTargetId = null;
  document.getElementById('delete-modal').classList.add('hidden');
}

async function confirmDelete() {
  if (!deleteTargetId) return;
  
  const btn = document.querySelector('#delete-modal button.bg-brand');
  const oldHtml = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xóa...';

  try {
    const res = await fetch(`${API_URL}/${deleteTargetId}`, {
      method: 'DELETE',
      headers: getAuthHeader()
    });

    if (!res.ok) {
      const errData = await res.json().catch(() => ({}));
      throw new Error(errData.detail || 'Failed to delete movie');
    }

    showToast("Đã xóa phim thành công!");
    closeDeleteModal();
    await loadMovies();
  } catch (err) {
    console.error(err);
    alert(err.message || 'Lỗi khi xóa phim');
  } finally {
    btn.disabled = false;
    btn.innerHTML = oldHtml;
  }
}

async function rebuildAIIndex() {
  const button = document.getElementById('rebuild-ai-button');
  const token = localStorage.getItem('access_token') || '';
  const originalContent = button.innerHTML;

  button.disabled = true;
  button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang cập nhật AI...';

  try {
    const response = await fetch('/api/ai/rebuild-index', {
      method: 'POST',
      headers: token ? { 'Authorization': `Bearer ${token}` } : {}
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) throw new Error(data.detail || 'Không thể cập nhật dữ liệu AI.');

    showToast(`AI đã lập chỉ mục ${data.documents_indexed ?? 0} phim trong ${data.time_taken_seconds ?? 0} giây.`);
  } catch (error) {
    showToast(error.message);
  } finally {
    button.disabled = false;
    button.innerHTML = originalContent;
  }
}

function showToast(text) {
  const toast = document.getElementById('toast');
  document.getElementById('toast-text').textContent = text;
  
  toast.classList.remove('opacity-0', 'translate-y-[-20px]', 'pointer-events-none');
  toast.classList.add('opacity-100', 'translate-y-0');
  
  setTimeout(() => {
    toast.classList.remove('opacity-100', 'translate-y-0');
    toast.classList.add('opacity-0', 'translate-y-[-20px]', 'pointer-events-none');
  }, 2500);
}
</script>
