      <!-- Ratings & Duration & Director -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Điểm đánh giá (IMDB) <span class="text-brand">*</span></label>
          <input id="form-rating" type="number" step="0.1" min="0" max="10" required placeholder="VD: 8.5"
            class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition">
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Thời lượng (phút) <span class="text-brand">*</span></label>
          <input id="form-duration" type="number" min="1" required placeholder="VD: 120"
            class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition">
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Đạo diễn <span class="text-brand">*</span></label>
          <input id="form-director" type="text" required placeholder="VD: Lý Hải"
            class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition font-medium">
        </div>
      </div>

      <!-- Trailer & Status -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Link Video Trailer <span class="text-brand">*</span></label>
          <input id="form-trailer" type="url" required placeholder="VD: https://www.youtube.com/watch?v=..."
            class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition">
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Trạng thái chiếu <span class="text-brand">*</span></label>
          <select id="form-status" required class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand transition appearance-none bg-white font-medium">
            <option value="now_showing">🎬 Đang chiếu (Now Showing)</option>
            <option value="coming_soon">📅 Sắp chiếu (Coming Soon)</option>
          </select>
        </div>
      </div>

      <!-- Cast -->
      <div>
        <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Diễn viên <span class="text-brand">*</span></label>
        <textarea id="form-cast" required rows="2" placeholder="Nhập danh sách diễn viên chính, cách nhau bằng dấu phẩy..."
          class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition resize-none"></textarea>
      </div>

      <!-- Description -->
      <div>
        <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Mô tả phim <span class="text-brand">*</span></label>
        <textarea id="form-description" required rows="4" placeholder="Nhập tóm tắt nội dung cốt truyện của bộ phim..."
          class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition resize-y"></textarea>
      </div>

      <!-- Files Upload Layout (Poster & Backdrop) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Poster Upload Zone -->
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Ảnh Poster Phim (Tỷ lệ 2:3) <span class="text-brand">*</span></label>
          <div id="poster-dropzone" class="border-2 border-dashed border-slate-200 rounded-xl p-4 text-center cursor-pointer hover:border-brand hover:bg-slate-50 transition flex flex-col items-center justify-center min-h-[140px]">
            <input type="file" id="poster-file" accept="image/*" class="hidden">
            <div id="poster-upload-icon" class="text-slate-400 flex flex-col items-center gap-1">
              <i class="fas fa-cloud-upload-alt text-3xl"></i>
              <span class="text-xs font-bold mt-1 text-slate-600">Kéo thả ảnh hoặc click để chọn</span>
              <span class="text-[10px] text-slate-400">Chỉ chấp nhận file ảnh (.png, .jpg, .webp)</span>
            </div>
            <div id="poster-preview-container" class="hidden relative w-24 h-36 rounded-lg overflow-hidden border border-slate-200 shadow-sm">
              <img id="poster-preview" src="" alt="Poster" class="w-full h-full object-cover">
              <button type="button" onclick="removePoster(event)" class="absolute top-1 right-1 w-5 h-5 bg-black/70 hover:bg-brand text-white rounded-full flex items-center justify-center text-[10px] transition"><i class="fas fa-times"></i></button>
            </div>
          </div>
          <input type="hidden" id="form-poster-url">
        </div>

        <!-- Backdrop Banner Upload Zone -->
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Ảnh Banner/Backdrop (Tỷ lệ 16:9) <span class="text-brand">*</span></label>
          <div id="backdrop-dropzone" class="border-2 border-dashed border-slate-200 rounded-xl p-4 text-center cursor-pointer hover:border-brand hover:bg-slate-50 transition flex flex-col items-center justify-center min-h-[140px]">
            <input type="file" id="backdrop-file" accept="image/*" class="hidden">
            <div id="backdrop-upload-icon" class="text-slate-400 flex flex-col items-center gap-1">
              <i class="fas fa-image text-3xl"></i>
              <span class="text-xs font-bold mt-1 text-slate-600">Kéo thả ảnh hoặc click để chọn</span>
              <span class="text-[10px] text-slate-400">Hình ảnh làm background mờ ở trang chi tiết</span>
            </div>
            <div id="backdrop-preview-container" class="hidden relative w-full h-24 rounded-lg overflow-hidden border border-slate-200 shadow-sm">
              <img id="backdrop-preview" src="" alt="Backdrop" class="w-full h-full object-cover">
              <button type="button" onclick="removeBackdrop(event)" class="absolute top-1 right-1 w-5 h-5 bg-black/70 hover:bg-brand text-white rounded-full flex items-center justify-center text-[10px] transition"><i class="fas fa-times"></i></button>
            </div>
          </div>
          <input type="hidden" id="form-backdrop-url">
        </div>
      </div>

      <!-- Form Error Alerts -->
      <div id="form-error" class="hidden bg-rose-50 border border-rose-200 text-rose-600 text-xs font-semibold px-4 py-3 rounded-xl flex items-center gap-2">
        <i class="fas fa-exclamation-circle text-sm flex-shrink-0"></i>
        <span id="form-error-msg"></span>
      </div>
    </form>

    <!-- Modal Footer -->
    <div class="px-6 py-4 border-t border-slate-100 flex justify-end gap-3 flex-shrink-0 bg-slate-50 rounded-b-2xl">
      <button type="button" onclick="closeModal()" class="px-5 py-2.5 rounded-xl text-sm font-bold text-slate-600 bg-white border border-slate-200 hover:bg-slate-100 transition">Hủy</button>
      <button type="button" id="save-movie-btn" onclick="document.getElementById('movie-form').requestSubmit()" class="px-6 py-2.5 rounded-xl text-sm font-bold text-white bg-brand hover:bg-brandHover transition shadow-md shadow-brand/20 flex items-center gap-2">
        <i class="fas fa-check text-xs"></i> Lưu phim
      </button>
