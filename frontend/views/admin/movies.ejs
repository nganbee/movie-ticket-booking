<!-- Movie Management Page -->
<div>
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h2 class="text-2xl font-extrabold text-slate-800">Quản lý Phim</h2>
      <p class="text-slate-400 text-sm mt-1">Thêm mới, cập nhật thông tin chi tiết của phim và hiển thị lên giao diện người dùng.</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <button id="rebuild-ai-button" onclick="rebuildAIIndex()" class="flex items-center gap-2 bg-blue-600 text-white px-5 py-2.5 rounded-xl font-bold hover:bg-blue-700 transition shadow-md shadow-blue-600/20">
        <i class="fas fa-brain"></i> Cập nhật dữ liệu AI
      </button>
      <button onclick="openAddModal()" class="flex items-center gap-2 bg-brand text-white px-5 py-2.5 rounded-xl font-bold hover:bg-brandHover transition shadow-md shadow-brand/20">
        <i class="fas fa-plus"></i> Thêm phim mới
      </button>
    </div>
  </div>

  <!-- Filter & Search Bar -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-4 mb-6 flex flex-col sm:flex-row gap-4 items-start sm:items-center">
    <div class="relative flex-1 w-full">
      <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i>
      <input id="movie-search" type="text" placeholder="Tìm kiếm tên phim, đạo diễn, thể loại..." oninput="renderMovies()"
        class="w-full border border-slate-200 bg-slate-50 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition">
    </div>
    <div class="flex items-center gap-3 w-full sm:w-auto">
      <label class="text-xs font-bold text-slate-500 uppercase whitespace-nowrap">Trạng thái:</label>
      <select id="status-filter" onchange="renderMovies()" class="border border-slate-200 bg-slate-50 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand transition">
        <option value="all">Tất cả</option>
        <option value="now_showing">🎬 Đang chiếu</option>
        <option value="coming_soon">📅 Sắp chiếu</option>
      </select>
    </div>
  </div>

  <!-- Movie Cards Table/Grid -->
  <div id="movie-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6"></div>

  <!-- Empty State -->
  <div id="movie-empty" class="hidden py-20 text-center bg-white rounded-2xl border border-slate-200">
    <i class="fas fa-film text-5xl text-slate-300 mb-4"></i>
    <p class="text-slate-400 font-medium">Không tìm thấy phim nào phù hợp</p>
  </div>

  <div class="mt-4">
    <p id="movie-count" class="text-xs text-slate-400 font-medium"></p>
  </div>
</div>

<!-- ===================================================================
     MODAL: THÊM / CHỈNH SỬA PHIM
=================================================================== -->
<div id="movie-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 overflow-y-auto">
  <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeModal()"></div>

  <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-3xl z-10 flex flex-col max-h-[92vh]">
    <!-- Modal Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 flex-shrink-0">
      <h3 id="modal-title" class="text-lg font-bold text-slate-800">Thêm Phim Mới</h3>
      <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600 transition text-xl w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-100">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <!-- Scrollable Form Body -->
    <form id="movie-form" onsubmit="saveMovie(event)" class="overflow-y-auto flex-1 p-6 space-y-6">
      <input type="hidden" id="form-id">

      <!-- Basic Info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Tên phim <span class="text-brand">*</span></label>
            <button type="button" onclick="syncMovieData()" class="text-xs bg-slate-100 hover:bg-slate-200 text-brand font-bold px-2 py-1 rounded flex items-center gap-1 transition">
              <i class="fas fa-sync-alt" id="sync-icon"></i> Đồng bộ từ TMDB
            </button>
          </div>
          <input id="form-title" type="text" required placeholder="VD: Lật Mặt 7: Một Điều Ước"
            class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition font-medium">
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Thể loại <span class="text-brand">*</span></label>
          <input id="form-genre" type="text" required placeholder="VD: Hành động, Kịch tính"
            class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition font-medium">
        </div>
      </div>

      <!-- Language & Release Date -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Ngôn ngữ <span class="text-brand">*</span></label>
          <input id="form-language" type="text" required placeholder="VD: EN, VI"
            class="form-input w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition font-medium">
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Ngày phát hành <span class="text-brand">*</span></label>
