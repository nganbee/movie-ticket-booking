<!-- ===================================================================
     JAVASCRIPT
=================================================================== -->
<script>
// ===== STATE =====
let NEWS_DATA = [];
let currentTypeFilter = 'all';
let deleteTargetId = null;
let deleteTargetType = null;
let currentViewId = null;
let currentViewType = null;

// ===== HELPERS =====
// ===== HELPERS =====
const typeColors = {
  'Khuyến Mãi': 'bg-green-50 text-green-600 border-green-200',
  'Thông Báo':  'bg-amber-50 text-amber-600 border-amber-200',
  'Tin Phim':   'bg-purple-50 text-purple-600 border-purple-200',
};
const typeIcons = { 'Khuyến Mãi': '🎁', 'Thông Báo': '📢', 'Tin Phim': '🎬' };

// Load movies from API
async function loadMoviesForSelect() {
  try {
    const res = await fetch('/api/movies');
    if (res.ok) {
      const data = await res.json();
      const movies = data.items || data;
      const select = document.getElementById('form-movie-id');
      select.innerHTML = '<option value="">-- Không đính kèm phim --</option>' + 
        movies.map(m => `<option value="${m.id}">${m.title}</option>`).join('');
    }
  } catch(e) { console.error('Failed to load movies:', e); }
}

async function loadNewsFromAPI() {
  const token = localStorage.getItem('admin_access_token') || '';
  try {
    const res = await fetch('/api/admin/news', {
      headers: { 'Authorization': `Bearer ${token}` }
    });
    if (res.ok) {
      NEWS_DATA = await res.json();
      renderNews();
    }
  } catch(e) {
    console.error('Failed to load news:', e);
  }
}

document.addEventListener('DOMContentLoaded', () => {
  loadMoviesForSelect();
  loadNewsFromAPI();
});

function toggleMovieSelect() {
  const type = document.getElementById('form-type').value;
  const container = document.getElementById('movie-select-container');
  if (type === 'Tin Phim') {
    container.classList.remove('hidden');
  } else {
    container.classList.add('hidden');
    document.getElementById('form-movie-id').value = '';
  }
}

function formatDate(d) {
  if (!d) return '—';
  return new Date(d + 'T00:00:00').toLocaleDateString('vi-VN');
}

function truncate(str, n) {
  if (!str) return '';
  return str.length > n ? str.slice(0, n) + '...' : str;
}

// ===== RENDER CARDS =====
function renderNews() {
  const search = document.getElementById('news-search').value.toLowerCase();
  let data = NEWS_DATA.filter(n => {
    if (search && !n.title.toLowerCase().includes(search) && !(n.content||'').toLowerCase().includes(search)) return false;
    if (currentTypeFilter !== 'all' && n.type !== currentTypeFilter) return false;
    return true;
  });

  const grid = document.getElementById('news-grid');
  const empty = document.getElementById('news-empty');
  document.getElementById('news-count').textContent = `${data.length} bài viết`;

  if (data.length === 0) {
    grid.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  grid.innerHTML = data.map(n => `
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow flex flex-col">
      <!-- Thumbnail -->
      ${n.thumbnail
        ? `<div class="relative h-40 overflow-hidden flex-shrink-0">
             <img src="${n.thumbnail}" alt="" class="w-full h-full object-cover">
             <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
             <span class="absolute top-3 left-3 text-xs font-bold px-2.5 py-1 rounded-full border ${typeColors[n.type] || ''} bg-white/90">${typeIcons[n.type]||''} ${n.type}</span>
           </div>`
        : `<div class="flex-shrink-0 px-5 pt-4">
             <span class="text-xs font-bold px-2.5 py-1 rounded-full border ${typeColors[n.type] || 'bg-slate-100 text-slate-600 border-slate-200'}">${typeIcons[n.type]||''} ${n.type}</span>
           </div>`
      }

      <!-- Content -->
      <div class="p-5 flex-1 flex flex-col">
        <!-- Author row -->
        <div class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-full bg-brand/10 flex items-center justify-center text-brand font-bold text-xs flex-shrink-0">A</div>
          <div>
            <p class="text-xs font-bold text-slate-700">Admin CineBook</p>
            <p class="text-[10px] text-slate-400">${formatDate(n.publishDate)} · ${n.status === 'Published' ? '<span class="text-green-500">🌐 Đã đăng</span>' : '<span class="text-slate-400">🔒 Bản nháp</span>'}</p>
          </div>
        </div>

        <h3 class="font-extrabold text-slate-800 text-sm mb-2 leading-snug line-clamp-2">${n.title}</h3>
        <p class="text-slate-500 text-xs leading-relaxed flex-1 line-clamp-3 whitespace-pre-line">${truncate(n.content, 150)}</p>

        <!-- Actions -->
        <div class="flex items-center justify-between mt-4 pt-3 border-t border-slate-100">
          <button onclick="openViewModal(${n.id}, '${n.type}')" class="text-xs font-semibold text-brand hover:text-red-700 transition flex items-center gap-1">
            <i class="fas fa-eye text-[10px]"></i> Xem toàn bộ
          </button>
          <div class="flex gap-1">
            <button onclick="openEditModal(${n.id}, '${n.type}')" class="p-2 text-slate-400 hover:text-blue-500 hover:bg-blue-50 rounded-lg transition" title="Chỉnh sửa">
              <i class="fas fa-edit text-xs"></i>
            </button>
            <button onclick="openDeleteModal(${n.id}, '${n.type}')" class="p-2 text-slate-400 hover:text-brand hover:bg-red-50 rounded-lg transition" title="Xóa">
              <i class="fas fa-trash-alt text-xs"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  `).join('');
}

// ===== FILTER =====
function setTypeFilter(type, btn) {
  currentTypeFilter = type;
  document.querySelectorAll('.type-filter-btn').forEach(b => {
    b.className = 'type-filter-btn text-xs font-bold px-3 py-2 rounded-xl border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition';
  });
  btn.className = 'type-filter-btn active text-xs font-bold px-3 py-2 rounded-xl border border-brand bg-brand text-white transition';
  renderNews();
}

// ===== MODAL ADD/EDIT =====
function openAddModal() {
  document.getElementById('modal-title').textContent = '✏️ Viết bài viết mới';
  document.getElementById('form-id').value = '';
  document.getElementById('news-form').reset();
  document.getElementById('form-date').value = new Date().toISOString().split('T')[0];
  document.getElementById('form-error').classList.add('hidden');
  document.getElementById('thumbnail-preview').classList.add('hidden');
  document.getElementById('form-movie-id').value = '';
  toggleMovieSelect();
  updateCharCount();
  document.getElementById('news-modal').classList.remove('hidden');
  setTimeout(() => document.getElementById('form-title').focus(), 100);
}

function openEditModal(id, type) {
  const n = NEWS_DATA.find(x => x.id === id && x.type === type);
  if (!n) return;
  document.getElementById('modal-title').textContent = '✏️ Chỉnh sửa bài viết';
  document.getElementById('form-id').value = n.id;
  document.getElementById('form-title').value = n.title;
  document.getElementById('form-content').value = n.content || '';
  document.getElementById('form-type').value = n.type;
  document.getElementById('form-status').value = n.status;
  document.getElementById('form-date').value = n.publishDate;
  document.getElementById('form-thumbnail').value = n.thumbnail || '';
  document.getElementById('form-movie-id').value = n.movieId || '';
  toggleMovieSelect();
  document.getElementById('form-error').classList.add('hidden');
  updateCharCount();
  updateThumbnailPreview();
  document.getElementById('news-modal').classList.remove('hidden');
}

function closeModal() { document.getElementById('news-modal').classList.add('hidden'); }

async function saveNews(e) {
  e.preventDefault();
  const id = document.getElementById('form-id').value;
  const title = document.getElementById('form-title').value.trim();
  const content = document.getElementById('form-content').value.trim();
  const type = document.getElementById('form-type').value;
  const status = document.getElementById('form-status').value;
  const publishDate = document.getElementById('form-date').value;
  const thumbnail = document.getElementById('form-thumbnail').value.trim();
  const movieId = type === 'Tin Phim' ? document.getElementById('form-movie-id').value : null;

  const errEl = document.getElementById('form-error');
  const errMsg = document.getElementById('form-error-msg');

  if (!title) { errMsg.textContent = 'Vui lòng nhập tiêu đề bài viết.'; errEl.classList.remove('hidden'); return; }
  if (!content) { errMsg.textContent = 'Vui lòng nhập nội dung bài viết.'; errEl.classList.remove('hidden'); return; }
  if (!type) { errMsg.textContent = 'Vui lòng chọn loại bài viết.'; errEl.classList.remove('hidden'); return; }
  errEl.classList.add('hidden');

  const payload = {
    title, content, type, status, publishDate, thumbnail,
    movieId: movieId ? parseInt(movieId) : null
  };

  const token = localStorage.getItem('admin_access_token') || '';
  const btn = document.querySelector('#news-form button[type="submit"]') || e.submitter;
  const oldText = btn ? btn.innerHTML : '';
  if (btn) btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';

  try {
    const url = id ? `/api/admin/news/${id}` : '/api/admin/news';
    const method = id ? 'PUT' : 'POST';
    
    const res = await fetch(url, {
      method,
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
      },
      body: JSON.stringify(payload)
    });

    if (!res.ok) throw new Error('Không thể lưu bài viết');
    
    closeModal();
    loadNewsFromAPI(); // Reload list
  } catch (err) {
    errMsg.textContent = err.message || 'Có lỗi xảy ra khi lưu.';
    errEl.classList.remove('hidden');
  } finally {
    if (btn) btn.innerHTML = oldText;
  }
}

// ===== PREVIEW =====
function previewPost() {
  const title = document.getElementById('form-title').value || '(Chưa có tiêu đề)';
  const content = document.getElementById('form-content').value || '(Chưa có nội dung)';
  const thumb = document.getElementById('form-thumbnail').value;
  const date = document.getElementById('form-date').value;

  document.getElementById('preview-title').textContent = title;
  document.getElementById('preview-content').textContent = content;
  document.getElementById('preview-date').innerHTML = `<i class="fas fa-globe-asia"></i> ${date ? formatDate(date) : 'Hôm nay'}`;

  const thumbWrap = document.getElementById('preview-thumb-wrap');
  if (thumb) {
    document.getElementById('preview-thumb').src = thumb;
    thumbWrap.classList.remove('hidden');
  } else {
    thumbWrap.classList.add('hidden');
  }
  document.getElementById('preview-modal').classList.remove('hidden');
}
function closePreview() { document.getElementById('preview-modal').classList.add('hidden'); }

// ===== VIEW MODAL =====
function openViewModal(id, type) {
  const n = NEWS_DATA.find(x => x.id === id && x.type === type);
  if (!n) return;
  currentViewId = id;
  currentViewType = type;
  document.getElementById('view-title').textContent = n.title;
  document.getElementById('view-content').textContent = n.content || '(Không có nội dung)';
  document.getElementById('view-date').innerHTML = `<i class="fas fa-globe-asia"></i> ${formatDate(n.publishDate)}`;
  const badge = document.getElementById('view-type-badge');
  badge.textContent = (typeIcons[n.type]||'') + ' ' + n.type;
  badge.className = `text-xs font-bold px-2.5 py-1 rounded-full border ${typeColors[n.type]||''}`;
  const thumbWrap = document.getElementById('view-thumb-wrap');
  if (n.thumbnail) { document.getElementById('view-thumb').src = n.thumbnail; thumbWrap.classList.remove('hidden'); }
  else { thumbWrap.classList.add('hidden'); }
  document.getElementById('view-modal').classList.remove('hidden');
}
function closeViewModal() { document.getElementById('view-modal').classList.add('hidden'); }

// ===== DELETE =====
function openDeleteModal(id, type) { 
  deleteTargetId = id; 
  deleteTargetType = type;
  document.getElementById('delete-modal').classList.remove('hidden'); 
}
function closeDeleteModal() { 
  deleteTargetId = null; 
  deleteTargetType = null;
  document.getElementById('delete-modal').classList.add('hidden'); 
}
async function confirmDelete() { 
  if (!deleteTargetId || !deleteTargetType) return;
  const token = localStorage.getItem('admin_access_token') || '';
  
  try {
    const res = await fetch(`/api/admin/news/${deleteTargetId}?type=${encodeURIComponent(deleteTargetType)}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${token}` }
    });
    
    if (res.ok || res.status === 204) {
      closeDeleteModal(); 
      loadNewsFromAPI();
    } else {
      alert('Không thể xóa bài viết này.');
    }
  } catch (e) {
    console.error(e);
    alert('Lỗi kết nối khi xóa bài viết.');
  }
}

// ===== HELPERS =====
function updateCharCount() {
  const len = (document.getElementById('form-content').value || '').length;
  const el = document.getElementById('char-count');
  el.textContent = len.toLocaleString() + ' ký tự';
  el.className = len > 5000 ? 'text-xs text-amber-500 font-semibold' : 'text-xs text-slate-400';
}

function updateThumbnailPreview() {
  const url = document.getElementById('form-thumbnail').value.trim();
  const wrap = document.getElementById('thumbnail-preview');
  if (url) { document.getElementById('thumb-img').src = url; wrap.classList.remove('hidden'); }
  else { wrap.classList.add('hidden'); }
}

function insertEmoji(emoji) {
  const ta = document.getElementById('form-content');
  const start = ta.selectionStart, end = ta.selectionEnd;
  ta.value = ta.value.slice(0, start) + emoji + ta.value.slice(end);
  ta.selectionStart = ta.selectionEnd = start + emoji.length;
  ta.focus();
  updateCharCount();
}

function insertSeparator() {
  const ta = document.getElementById('form-content');
  const sep = '\n-----------------------------\n';
  const start = ta.selectionStart;
  ta.value = ta.value.slice(0, start) + sep + ta.value.slice(start);
  ta.selectionStart = ta.selectionEnd = start + sep.length;
  ta.focus();
  updateCharCount();
}

// Init
// renderNews() now called from loadNewsFromAPI()
</script>
