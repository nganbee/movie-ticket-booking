<!-- News Management -->
<div>
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h2 class="text-2xl font-extrabold text-slate-800">Tin Tức & Khuyến Mãi</h2>
      <p class="text-slate-400 text-sm mt-1">Đăng bản tin, sự kiện và chương trình khuyến mãi.</p>
    </div>
    <button onclick="openAddModal()" class="flex items-center gap-2 bg-brand text-white px-5 py-2.5 rounded-xl font-bold hover:bg-red-700 transition shadow-md shadow-brand/20">
      <i class="fas fa-pen"></i> Viết bài viết mới
    </button>
  </div>

  <!-- Filter & Search Bar -->
  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-4 mb-6 flex flex-col sm:flex-row gap-3 items-start sm:items-center">
    <div class="relative flex-1 w-full">
      <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i>
      <input id="news-search" type="text" placeholder="Tìm kiếm tiêu đề bài viết..." oninput="renderNews()"
        class="w-full border border-slate-200 bg-slate-50 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition">
    </div>
    <div class="flex flex-wrap gap-2">
      <button onclick="setTypeFilter('all', this)" class="type-filter-btn active text-xs font-bold px-3 py-2 rounded-xl border border-brand bg-brand text-white transition">Tất cả</button>
      <button onclick="setTypeFilter('Khuyến Mãi', this)" class="type-filter-btn text-xs font-bold px-3 py-2 rounded-xl border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">🎁 Khuyến Mãi</button>
      <button onclick="setTypeFilter('Sự Kiện', this)" class="type-filter-btn text-xs font-bold px-3 py-2 rounded-xl border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">🎉 Sự Kiện</button>
      <button onclick="setTypeFilter('Thông Báo', this)" class="type-filter-btn text-xs font-bold px-3 py-2 rounded-xl border border-slate-200 text-slate-600 hover:border-brand hover:text-brand transition">📢 Thông Báo</button>
    </div>
  </div>

  <!-- News Cards Grid -->
  <div id="news-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5"></div>

  <!-- Empty State -->
  <div id="news-empty" class="hidden py-20 text-center bg-white rounded-2xl border border-slate-100">
    <i class="fas fa-newspaper text-5xl text-slate-200 mb-4"></i>
    <p class="text-slate-400 font-medium">Không tìm thấy bài viết nào</p>
  </div>

  <div class="mt-4">
    <p id="news-count" class="text-xs text-slate-400"></p>
  </div>
</div>

<!-- ===================================================================
     MODAL: THÊM / CHỈNH SỬA BÀI VIẾT  (Facebook-style composer)
=================================================================== -->
<div id="news-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeModal()"></div>

  <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-2xl z-10 flex flex-col max-h-[92vh]">
    <!-- Modal Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 flex-shrink-0">
      <h3 id="modal-title" class="text-lg font-bold text-slate-800"></h3>
      <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600 transition text-xl w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-100">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <!-- Scrollable Form Body -->
    <form id="news-form" onsubmit="saveNews(event)" class="overflow-y-auto flex-1">
      <input type="hidden" id="form-id">

      <!-- Author row (decorative, mimic Facebook) -->
      <div class="px-6 pt-5 pb-3 flex items-center gap-3 border-b border-slate-100">
        <div class="w-10 h-10 rounded-full bg-brand/10 flex items-center justify-center text-brand font-bold text-sm flex-shrink-0">A</div>
        <div class="flex-1">
          <p class="font-bold text-slate-800 text-sm">Admin CineBook</p>
          <div class="flex items-center gap-2 mt-1">
            <select id="form-status" class="text-xs border border-slate-200 rounded-md px-2 py-1 focus:outline-none focus:border-brand appearance-none bg-slate-50 text-slate-600 font-medium">
              <option value="Draft">🔒 Chỉ mình tôi (Bản nháp)</option>
              <option value="Published">🌐 Công khai (Đã đăng)</option>
            </select>
          </div>
        </div>
      </div>

      <div class="px-6 py-5 space-y-4">
        <!-- Tiêu đề bài viết -->
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">
            Tiêu đề bài viết <span class="text-brand">*</span>
          </label>
          <input id="form-title" type="text" required
            placeholder="VD: [CineBook] THÔNG BÁO LỊCH CHIẾU ĐẶC BIỆT DỊP LỄ 2/9..."
            class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-800 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition">
        </div>

        <!-- NỘI DUNG CHÍNH — Facebook-style textarea -->
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">
            Nội dung bài viết <span class="text-brand">*</span>
          </label>
          <div class="relative">
            <textarea id="form-content" required rows="12"
              oninput="updateCharCount()"
              placeholder="Nhập nội dung bài viết...

Ví dụ:
🎊 CineBook xin thông báo...

📌 CHI TIẾT CHƯƠNG TRÌNH
- Thời gian: ...
- Địa điểm: ...

Hãy đến với chúng tôi để trải nghiệm điện ảnh đỉnh cao! 🎬"
              class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition resize-y leading-relaxed min-h-[200px]"
            ></textarea>
            <div class="absolute bottom-3 right-3 flex gap-2">
              <button type="button" onclick="insertEmoji('🎊')" class="text-lg hover:scale-125 transition-transform" title="Chèn emoji">🎊</button>
              <button type="button" onclick="insertEmoji('📌')" class="text-lg hover:scale-125 transition-transform">📌</button>
              <button type="button" onclick="insertEmoji('🎬')" class="text-lg hover:scale-125 transition-transform">🎬</button>
              <button type="button" onclick="insertEmoji('💥')" class="text-lg hover:scale-125 transition-transform">💥</button>
              <button type="button" onclick="insertEmoji('✨')" class="text-lg hover:scale-125 transition-transform">✨</button>
              <button type="button" onclick="insertEmoji('🏆')" class="text-lg hover:scale-125 transition-transform">🏆</button>
              <button type="button" onclick="insertSeparator()" class="text-xs text-slate-400 hover:text-brand font-bold transition px-1" title="Chèn dấu ngăn cách">—————</button>
            </div>
          </div>
          <div class="flex justify-between mt-1">
            <p class="text-xs text-slate-400">Hỗ trợ emoji, xuống dòng, dấu phân cách</p>
            <p id="char-count" class="text-xs text-slate-400">0 ký tự</p>
          </div>
        </div>

        <!-- Row: Loại + Ngày đăng -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Loại <span class="text-brand">*</span></label>
            <select id="form-type" required class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand transition appearance-none bg-white">
              <option value="">-- Chọn loại --</option>
              <option value="Khuyến Mãi">🎁 Khuyến Mãi</option>
              <option value="Sự Kiện">🎉 Sự Kiện</option>
              <option value="Thông Báo">📢 Thông Báo</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Ngày đăng</label>
            <input id="form-date" type="date" class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-brand transition">
          </div>
        </div>

        <!-- Thumbnail -->
        <div>
          <label class="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wider">Ảnh đại diện (URL)</label>
          <div class="flex gap-2">
            <div class="relative flex-1">
              <i class="fas fa-image absolute left-3 top-1/2 -translate-y-1/2 text-slate-300 text-sm"></i>
              <input id="form-thumbnail" type="url" placeholder="https://..."
                oninput="updateThumbnailPreview()"
                class="w-full border border-slate-200 rounded-xl pl-9 pr-4 py-2.5 text-sm focus:outline-none focus:border-brand transition">
            </div>
          </div>
          <div id="thumbnail-preview" class="hidden mt-2">
            <img id="thumb-img" src="" alt="preview" class="h-20 rounded-xl object-cover border border-slate-200">
          </div>
        </div>

        <!-- Error -->
        <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-600 text-xs font-medium px-4 py-2.5 rounded-xl">
          <i class="fas fa-exclamation-circle mr-1"></i><span id="form-error-msg"></span>
        </div>
      </div>
    </form>

    <!-- Modal Footer -->
    <div class="px-6 py-4 border-t border-slate-100 flex justify-between items-center flex-shrink-0 bg-slate-50 rounded-b-2xl">
      <button type="button" onclick="previewPost()" class="flex items-center gap-2 text-slate-500 hover:text-brand text-sm font-semibold transition">
        <i class="fas fa-eye text-xs"></i> Xem trước
      </button>
      <div class="flex gap-3">
        <button type="button" onclick="closeModal()" class="px-5 py-2.5 rounded-xl text-sm font-bold text-slate-600 bg-white border border-slate-200 hover:bg-slate-100 transition">Hủy</button>
        <button type="button" onclick="document.getElementById('news-form').requestSubmit()" class="px-6 py-2.5 rounded-xl text-sm font-bold text-white bg-brand hover:bg-red-700 transition shadow-md shadow-brand/20 flex items-center gap-2">
          <i class="fas fa-paper-plane text-xs"></i> Đăng bài
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ===================================================================
     MODAL: XEM TRƯỚC BÀI VIẾT (Facebook-style preview)
=================================================================== -->
<div id="preview-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-slate-900/70 backdrop-blur-sm" onclick="closePreview()"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg z-10 max-h-[90vh] flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100 flex-shrink-0">
      <h3 class="font-bold text-slate-800 flex items-center gap-2"><i class="fas fa-eye text-brand text-sm"></i> Xem trước bài đăng</h3>
      <button onclick="closePreview()" class="text-slate-400 hover:text-slate-600 w-8 h-8 flex items-center justify-center rounded-lg hover:bg-slate-100 transition"><i class="fas fa-times text-sm"></i></button>
    </div>
    <div class="overflow-y-auto flex-1 p-5">
      <!-- FB-style post card -->
      <div class="border border-slate-200 rounded-xl bg-white shadow-sm">
        <div class="p-4 border-b border-slate-100">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-brand/10 flex items-center justify-center text-brand font-bold text-sm">A</div>
            <div>
              <p class="font-bold text-slate-800 text-sm">Admin CineBook</p>
              <p id="preview-date" class="text-xs text-slate-400 flex items-center gap-1"><i class="fas fa-globe-asia"></i> Hôm nay</p>
            </div>
          </div>
          <p id="preview-title" class="font-extrabold text-slate-800 text-base leading-snug mb-2"></p>
        </div>
        <div id="preview-thumb-wrap" class="hidden">
          <img id="preview-thumb" src="" alt="" class="w-full max-h-56 object-cover">
        </div>
        <div class="p-4">
          <pre id="preview-content" class="text-sm text-slate-700 whitespace-pre-wrap leading-relaxed font-sans"></pre>
        </div>
        <div class="px-4 py-3 border-t border-slate-100 flex items-center gap-4 text-slate-400 text-xs">
          <span><i class="fas fa-thumbs-up mr-1 text-blue-500"></i> 0 thích</span>
          <span><i class="fas fa-comment mr-1"></i> 0 bình luận</span>
          <span><i class="fas fa-share mr-1"></i> Chia sẻ</span>
        </div>
      </div>
    </div>
    <div class="px-5 py-3 border-t border-slate-100 flex-shrink-0">
      <button onclick="closePreview()" class="w-full py-2.5 rounded-xl text-sm font-bold text-white bg-brand hover:bg-red-700 transition">Đóng xem trước</button>
    </div>
  </div>
</div>

<!-- ===================================================================
     MODAL: XEM CHI TIẾT BÀI ĐÃ ĐĂNG
