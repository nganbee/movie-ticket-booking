<div class="cinebot" data-chat-api="/api/ai/chat">
  <section id="cinebot-panel" class="cinebot__panel" aria-label="Trợ lý AI CineBot" aria-hidden="true">
    <header class="cinebot__header">
      <span class="cinebot__avatar" aria-hidden="true"><i class="fa-solid fa-robot"></i></span>
      <div class="cinebot__heading">
        <strong>CineBot - AI Assistant</strong>
        <span id="cinebot-status"><i class="fa-solid fa-circle"></i> Đang kiểm tra dịch vụ AI...</span>
      </div>
      <button id="cinebot-history-button" class="cinebot__icon-button" type="button" aria-label="Xem lịch sử trò chuyện" title="Lịch sử">
        <i class="fa-solid fa-clock-rotate-left"></i>
      </button>
      <button id="cinebot-reset" class="cinebot__icon-button" type="button" aria-label="Tạo cuộc trò chuyện mới" title="Làm mới">
        <i class="fa-solid fa-rotate-right"></i>
      </button>
      <button id="cinebot-close" class="cinebot__icon-button" type="button" aria-label="Đóng chatbot">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </header>

    <div id="cinebot-messages" class="cinebot__messages" aria-live="polite">
      <div id="cinebot-welcome" class="cinebot__welcome">
        <span class="cinebot__welcome-icon" aria-hidden="true"><i class="fa-solid fa-clapperboard"></i></span>
        <p class="cinebot__eyebrow">TRỢ LÝ PHIM ẢNH CỦA BẠN</p>
        <h2>Hôm nay bạn muốn xem gì?</h2>
        <p>Tôi có thể gợi ý phim và suất chiếu phù hợp từ dữ liệu của CineBook.</p>
        <div class="cinebot__suggestions">
          <button type="button" data-prompt="Gợi ý phim hành động đang chiếu">
            <i class="fa-solid fa-bolt"></i>
            <span><strong>Phim hành động</strong><small>Kịch tính, mãn nhãn</small></span>
          </button>
          <button type="button" data-prompt="Có phim gia đình nào phù hợp cuối tuần?">
            <i class="fa-solid fa-people-roof"></i>
            <span><strong>Đi cùng gia đình</strong><small>Nhẹ nhàng, vui vẻ</small></span>
          </button>
          <button type="button" data-prompt="Tìm phim có suất chiếu tối nay">
            <i class="fa-regular fa-moon"></i>
            <span><strong>Suất chiếu tối nay</strong><small>Tìm theo thời gian</small></span>
          </button>
        </div>
      </div>
    </div>

    <aside id="cinebot-history" class="cinebot__history" aria-hidden="true">
      <div class="cinebot__history-header">
        <div>
          <strong>Lịch sử trò chuyện</strong>
          <small id="cinebot-history-caption">Đăng nhập để đồng bộ các phiên chat</small>
        </div>
        <button id="cinebot-history-close" type="button" aria-label="Đóng lịch sử">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <div id="cinebot-history-list" class="cinebot__history-list"></div>
    </aside>

    <div id="cinebot-typing" class="cinebot__typing" hidden>
      <span class="cinebot__mini-avatar"><i class="fa-solid fa-robot"></i></span>
      <span class="cinebot__dots"><i></i><i></i><i></i></span>
      <small>CineBot đang tìm phim phù hợp...</small>
    </div>

    <form id="cinebot-form" class="cinebot__composer">
      <label class="sr-only" for="cinebot-input">Nhập câu hỏi cho CineBot</label>
      <input id="cinebot-input" type="text" maxlength="500" autocomplete="off" placeholder="Nhập tin nhắn..." required>
      <button id="cinebot-send" type="submit" aria-label="Gửi tin nhắn">
        <i class="fa-regular fa-paper-plane"></i>
      </button>
    </form>
  </section>

  <button id="cinebot-trigger" class="cinebot__trigger" type="button" aria-label="Mở trợ lý AI CineBot" aria-expanded="false">
    <span class="cinebot__pulse"></span>
    <i class="fa-solid fa-robot cinebot__trigger-robot"></i>
    <i class="fa-solid fa-xmark cinebot__trigger-close"></i>
  </button>
</div>

<style>
  .cinebot {
    --cinebot-blue: #1d5cff;
    --cinebot-blue-dark: #1748ce;
    --cinebot-ink: #14213d;
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 9999;
    font-family: Inter, sans-serif;
  }

  .cinebot button,
  .cinebot input {
    font: inherit;
  }

  .cinebot__trigger {
    position: relative;
    display: grid;
    width: 58px;
    height: 58px;
    margin-left: auto;
    place-items: center;
    overflow: visible;
    border: 0;
    border-radius: 50%;
    color: #fff;
    background: var(--cinebot-blue);
    box-shadow: 0 14px 30px rgba(29, 92, 255, .32);
    transition: transform .2s ease, background .2s ease;
  }

  .cinebot__trigger:hover {
    background: var(--cinebot-blue-dark);
    transform: translateY(-2px);
  }

  .cinebot__trigger:focus-visible,
  .cinebot__icon-button:focus-visible,
  .cinebot__composer button:focus-visible,
  .cinebot__suggestions button:focus-visible {
    outline: 3px solid rgba(29, 92, 255, .28);
    outline-offset: 3px;
  }

  .cinebot__trigger > i {
    position: relative;
    z-index: 1;
    font-size: 22px;
  }

  .cinebot__trigger-close {
    display: none;
  }

  .cinebot--open .cinebot__trigger-robot {
    display: none;
  }

  .cinebot--open .cinebot__trigger-close {
    display: inline-block;
  }

  .cinebot__pulse {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--cinebot-blue);
    animation: cinebot-pulse 2.2s infinite;
  }

  .cinebot--open .cinebot__pulse {
    display: none;
  }

  .cinebot__panel {
    position: absolute;
    right: 0;
    bottom: 74px;
    display: flex;
    width: min(410px, calc(100vw - 32px));
    height: min(610px, calc(100vh - 120px));
    min-height: 470px;
    flex-direction: column;
    overflow: hidden;
    visibility: hidden;
    border: 1px solid #d8e4ff;
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 24px 65px rgba(15, 23, 42, .24);
    opacity: 0;
    transform: translateY(14px) scale(.96);
    transform-origin: bottom right;
    transition: opacity .22s ease, transform .22s ease, visibility .22s;
  }

  .cinebot--open .cinebot__panel {
    visibility: visible;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .cinebot__header {
    display: flex;
    min-height: 92px;
    align-items: center;
    gap: 12px;
    padding: 18px 16px 18px 20px;
    color: #fff;
    background: linear-gradient(135deg, #2464ff 0%, #164dde 100%);
  }

  .cinebot__avatar,
  .cinebot__mini-avatar {
    display: grid;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 50%;
    color: #fff;
    background: rgba(255, 255, 255, .17);
  }

  .cinebot__avatar {
    width: 48px;
    height: 48px;
    font-size: 21px;
  }

  .cinebot__heading {
    display: flex;
    min-width: 0;
    flex: 1;
    flex-direction: column;
  }

  .cinebot__heading strong {
    overflow: hidden;
    font-size: 17px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cinebot__heading span {
    margin-top: 3px;
    font-size: 11px;
    color: #dbe7ff;
  }

  .cinebot__heading .fa-circle {
    margin-right: 4px;
    font-size: 6px;
    color: #7dffb3;
    vertical-align: middle;
  }

  .cinebot__heading span[data-status="offline"] .fa-circle {
    color: #ffd166;
  }

  .cinebot__icon-button {
    display: grid;
    width: 32px;
    height: 32px;
    flex: 0 0 auto;
    place-items: center;
    border: 0;
    border-radius: 50%;
    color: #fff;
    background: transparent;
  }

  .cinebot__icon-button:hover {
    background: rgba(255, 255, 255, .14);
  }

  .cinebot__messages {
    flex: 1;
    overflow-x: hidden;
    overflow-y: auto;
    padding: 22px 18px;
    background:
      radial-gradient(circle at 100% 0, rgba(141, 244, 255, .2), transparent 34%),
      linear-gradient(145deg, #eef6ff 0%, #edffff 100%);
    scroll-behavior: smooth;
  }

  .cinebot__history {
    position: absolute;
    inset: 92px 0 66px;
    z-index: 5;
    display: flex;
    flex-direction: column;
    visibility: hidden;
    background: #f8fbff;
    opacity: 0;
    transform: translateX(100%);
    transition: opacity .2s ease, transform .2s ease, visibility .2s;
  }

  .cinebot__history--open {
    visibility: visible;
    opacity: 1;
    transform: translateX(0);
  }

  .cinebot__history-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 18px;
    border-bottom: 1px solid #dce6f7;
    background: #fff;
  }

  .cinebot__history-header > div {
    display: flex;
    flex-direction: column;
  }

  .cinebot__history-header strong {
    color: var(--cinebot-ink);
    font-size: 14px;
  }

  .cinebot__history-header small {
    margin-top: 3px;
    color: #7d899f;
    font-size: 10px;
  }

  .cinebot__history-header button {
    display: grid;
    width: 30px;
    height: 30px;
    place-items: center;
    border: 0;
    border-radius: 50%;
    color: #66758f;
    background: #edf2fa;
  }

  .cinebot__history-list {
    display: grid;
    gap: 9px;
    overflow-y: auto;
    padding: 14px;
  }

  .cinebot__history-empty {
    padding: 45px 20px;
    color: #7d899f;
    font-size: 12px;
    line-height: 1.6;
    text-align: center;
  }

  .cinebot__history-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 6px;
    padding: 12px;
    border: 1px solid #dbe6f8;
    border-radius: 12px;
    background: #fff;
  }

  .cinebot__history-open {
    min-width: 0;
    border: 0;
    color: #263550;
    background: transparent;
    text-align: left;
  }

  .cinebot__history-open strong,
  .cinebot__history-open small {
    display: block;
  }

  .cinebot__history-open strong {
    overflow: hidden;
    font-size: 11px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cinebot__history-open small {
    margin-top: 5px;
    color: #8793a8;
    font-size: 9px;
  }

  .cinebot__history-delete {
    width: 30px;
    border: 0;
    border-radius: 9px;
    color: #d93636;
    background: #fff0f0;
  }

  .cinebot__messages::-webkit-scrollbar {
    width: 5px;
  }

  .cinebot__messages::-webkit-scrollbar-thumb {
    border-radius: 99px;
    background: #a9b9d6;
  }

  .cinebot__welcome {
    padding: 8px 2px 4px;
    text-align: center;
    color: #65718a;
  }

  .cinebot__welcome-icon {
    display: grid;
    width: 64px;
    height: 64px;
    margin: 0 auto 14px;
    place-items: center;
    border-radius: 20px;
    color: var(--cinebot-blue);
    background: #fff;
    box-shadow: 0 12px 30px rgba(29, 92, 255, .12);
    font-size: 27px;
  }

  .cinebot__eyebrow {
    margin: 0 0 6px;
    color: var(--cinebot-blue);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: .14em;
  }

  .cinebot__welcome h2 {
    margin: 0;
    color: var(--cinebot-ink);
    font-size: 22px;
    font-weight: 800;
  }

  .cinebot__welcome > p:not(.cinebot__eyebrow) {
    max-width: 310px;
    margin: 8px auto 19px;
    font-size: 13px;
    line-height: 1.55;
  }

  .cinebot__suggestions {
    display: grid;
    gap: 9px;
    text-align: left;
  }

  .cinebot__suggestions button {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 13px;
    border: 1px solid #dbe6f8;
    border-radius: 13px;
    color: #25324d;
    background: rgba(255, 255, 255, .88);
    box-shadow: 0 5px 16px rgba(35, 75, 130, .05);
    transition: border-color .18s ease, transform .18s ease, box-shadow .18s ease;
  }

  .cinebot__suggestions button:hover {
    border-color: #8dadff;
    box-shadow: 0 8px 22px rgba(29, 92, 255, .1);
    transform: translateY(-1px);
  }

  .cinebot__suggestions button > i {
    width: 35px;
    color: var(--cinebot-blue);
    font-size: 18px;
    text-align: center;
  }

  .cinebot__suggestions span {
    display: flex;
    flex-direction: column;
  }

  .cinebot__suggestions strong {
    font-size: 12px;
  }

  .cinebot__suggestions small {
    margin-top: 2px;
    color: #7d899f;
    font-size: 10px;
  }

  .cinebot__message-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 16px;
  }

  .cinebot__row {
    display: flex;
    align-items: flex-end;
    gap: 9px;
  }

  .cinebot__row--user {
    justify-content: flex-end;
  }

  .cinebot__mini-avatar {
    width: 34px;
    height: 34px;
    background: var(--cinebot-blue);
    font-size: 14px;
  }

  .cinebot__bubble {
    max-width: 82%;
    margin: 0;
    padding: 12px 14px;
    border-radius: 5px 17px 17px 17px;
    color: #fff;
    background: var(--cinebot-blue);
    box-shadow: 0 7px 17px rgba(29, 92, 255, .17);
    font-size: 13px;
    line-height: 1.55;
    white-space: pre-line;
  }

  .cinebot__row--user .cinebot__bubble {
    border-radius: 17px 5px 17px 17px;
    color: #3f2b16;
    background: #ffba6a;
    box-shadow: 0 7px 17px rgba(180, 108, 30, .15);
  }

  .cinebot__link {
    color: #ffd23f;
    text-decoration: underline;
    font-weight: 700;
    transition: color 0.2s;
  }
  
  .cinebot__link:hover {
    color: #fff;
  }

  .cinebot__row--user .cinebot__link {
    color: #1748ce;
  }

  .cinebot__row--user .cinebot__link:hover {
    color: #0f2e82;
  }

  .cinebot__cards {
    display: grid;
    gap: 10px;
    margin-left: 43px;
  }

  .cinebot__follow-ups {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-left: 43px;
  }

  .cinebot__follow-ups button {
    padding: 7px 10px;
    border: 1px solid #a9c0ff;
    border-radius: 999px;
    color: #1748ce;
    background: rgba(255, 255, 255, .92);
    font-size: 10px;
    font-weight: 700;
    transition: background .18s ease, color .18s ease, transform .18s ease;
  }

  .cinebot__follow-ups button:hover {
    color: #fff;
    background: var(--cinebot-blue);
    transform: translateY(-1px);
  }

  .cinebot__card {
    overflow: hidden;
    border-radius: 14px;
    color: #fff;
    background: #14213d;
    box-shadow: 0 9px 20px rgba(20, 33, 61, .2);
  }

  .cinebot__card-main {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: 12px;
    padding: 12px;
  }

  .cinebot__poster {
    display: grid;
    min-height: 105px;
    place-items: center;
    overflow: hidden;
    border-radius: 7px;
    color: #99a8c2;
    background: #354866;
    font-size: 25px;
  }

  .cinebot__poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cinebot__card h3 {
    margin: 2px 0 7px;
    font-size: 13px;
    font-weight: 800;
  }

  .cinebot__card p {
    margin: 5px 0;
    color: #dce5f5;
    font-size: 10px;
  }

  .cinebot__showtimes {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 12px 12px;
  }

  .cinebot__showtime {
    padding: 7px 9px;
    border: 1px solid #526684;
    border-radius: 8px;
    color: #fff;
    background: #263a5a;
    font-size: 9px;
    font-weight: 700;
    text-decoration: none;
  }

  .cinebot__showtime:hover {
    border-color: #8eb0ff;
    background: #34527f;
  }

  .cinebot__showtime-empty {
    padding: 0 12px 12px;
    color: #aab8ce;
    font-size: 9px;
  }

  .cinebot__rating {
    color: #ffd23f !important;
    font-weight: 700;
  }

  .cinebot__book {
    display: block;
    padding: 11px;
    color: #fff;
    background: linear-gradient(90deg, #ff7a00, #f10b0b);
    font-size: 12px;
    font-weight: 800;
    text-align: center;
    text-decoration: none;
  }

  .cinebot__book:hover {
    filter: brightness(1.05);
  }

  .cinebot__notice {
    margin: 18px 12px;
    padding: 20px 16px;
    border: 1px solid #f0b000;
    border-radius: 16px;
    color: #99420e;
    background: #fff9e8;
    text-align: center;
  }

  .cinebot__notice i {
    font-size: 25px;
    color: #ed8500;
  }

  .cinebot__notice h3 {
    margin: 10px 0 8px;
    font-size: 16px;
    font-weight: 800;
  }

  .cinebot__notice p {
    margin: 0;
    font-size: 12px;
    line-height: 1.55;
  }

  .cinebot__notice button,
  .cinebot__notice a {
    display: block;
    width: 100%;
    margin-top: 12px;
    padding: 10px;
    border: 1px solid var(--cinebot-blue);
    border-radius: 10px;
    color: #fff;
    background: var(--cinebot-blue);
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
  }

  .cinebot__notice a {
    margin-top: 7px;
    color: #99420e;
    border-color: #f0a000;
    background: #fff;
  }

  .cinebot__typing {
    display: flex;
    min-height: 46px;
    align-items: center;
    gap: 8px;
    padding: 7px 18px;
    color: #71809a;
    background: #eefaff;
  }

  .cinebot__typing[hidden] {
    display: none;
  }

  .cinebot__typing .cinebot__mini-avatar {
    width: 28px;
    height: 28px;
    font-size: 11px;
  }

  .cinebot__dots {
    display: flex;
    gap: 3px;
  }

  .cinebot__dots i {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--cinebot-blue);
    animation: cinebot-dot 1s infinite ease-in-out;
  }

  .cinebot__dots i:nth-child(2) {
    animation-delay: .12s;
  }

  .cinebot__dots i:nth-child(3) {
    animation-delay: .24s;
  }

  .cinebot__typing small {
    font-size: 10px;
  }

  .cinebot__composer {
    display: flex;
    gap: 9px;
    padding: 13px 14px;
    border-top: 1px solid #dce6f7;
    background: #fff;
  }

  .cinebot__composer input {
    min-width: 0;
    flex: 1;
    padding: 11px 14px;
    border: 1px solid transparent;
    border-radius: 12px;
    outline: none;
    color: #24324b;
    background: #f2f4f8;
    font-size: 13px;
  }

  .cinebot__composer input:focus {
    border-color: #8dadff;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(29, 92, 255, .1);
  }

  .cinebot__composer button {
    display: grid;
    width: 43px;
    flex: 0 0 auto;
    place-items: center;
    border: 0;
    border-radius: 11px;
    color: #fff;
    background: var(--cinebot-blue);
    font-size: 16px;
  }

  .cinebot__composer button:disabled {
    cursor: not-allowed;
    opacity: .5;
  }

  @keyframes cinebot-pulse {
    0% { opacity: .45; transform: scale(1); }
    75%, 100% { opacity: 0; transform: scale(1.45); }
  }

  @keyframes cinebot-dot {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  @media (max-width: 520px) {
    .cinebot {
      right: 14px;
      bottom: 14px;
    }

    .cinebot__panel {
      position: fixed;
      inset: 10px 10px 82px;
      width: auto;
      height: auto;
      min-height: 0;
      border-radius: 16px;
      transform-origin: bottom right;
    }

    .cinebot__header {
      min-height: 76px;
      padding: 14px;
    }

    .cinebot__history {
      inset: 76px 0 66px;
    }

    .cinebot__avatar {
      width: 42px;
      height: 42px;
    }

    .cinebot__heading strong {
      font-size: 15px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cinebot *,
    .cinebot *::before,
    .cinebot *::after {
      scroll-behavior: auto !important;
      animation-duration: .01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: .01ms !important;
    }
  }
</style>

<script>
  (() => {
    const root = document.querySelector('.cinebot');
    if (!root) return;

    const panel = document.getElementById('cinebot-panel');
    const trigger = document.getElementById('cinebot-trigger');
    const closeButton = document.getElementById('cinebot-close');
    const resetButton = document.getElementById('cinebot-reset');
    const form = document.getElementById('cinebot-form');
    const input = document.getElementById('cinebot-input');
    const sendButton = document.getElementById('cinebot-send');
    const messages = document.getElementById('cinebot-messages');
    const welcome = document.getElementById('cinebot-welcome');
    const typing = document.getElementById('cinebot-typing');
    const statusText = document.getElementById('cinebot-status');
    const historyButton = document.getElementById('cinebot-history-button');
    const historyPanel = document.getElementById('cinebot-history');
    const historyClose = document.getElementById('cinebot-history-close');
    const historyList = document.getElementById('cinebot-history-list');
    const historyCaption = document.getElementById('cinebot-history-caption');
    const chatApi = root.dataset.chatApi;
    const storageKey = 'cinebot-conversation-v3';
    let busy = false;
    let history = [];
    let transcript = [];
    let conversationId = null;
    let aiOnline = false;

    function setOpen(open) {
      root.classList.toggle('cinebot--open', open);
      panel.setAttribute('aria-hidden', String(!open));
      trigger.setAttribute('aria-expanded', String(open));
      trigger.setAttribute('aria-label', open ? 'Đóng trợ lý AI CineBot' : 'Mở trợ lý AI CineBot');
      if (open) window.setTimeout(() => input.focus(), 220);
    }

    function scrollToBottom() {
      messages.scrollTop = messages.scrollHeight;
    }

    function saveConversation() {
      try {
        sessionStorage.setItem(storageKey, JSON.stringify({ history, transcript, conversationId }));
      } catch (error) {
        console.warn('[CineBot] Không thể lưu hội thoại:', error);
      }
    }

    function getToken() {
      return localStorage.getItem('access_token') || '';
    }

    function authHeaders() {
      const token = getToken();
      return token ? { Authorization: `Bearer ${token}` } : {};
    }

    function formatDateTime(value) {
      if (!value) return '';
      return new Intl.DateTimeFormat('vi-VN', {
        hour: '2-digit',
        minute: '2-digit',
        day: '2-digit',
        month: '2-digit'
      }).format(new Date(value));
    }

    function createMessage(text, role, shouldStore = true) {
      const group = document.createElement('div');
      group.className = `cinebot__message-group${role === 'user' ? ' cinebot__message-group--user' : ''}`;

      const row = document.createElement('div');
      row.className = `cinebot__row${role === 'user' ? ' cinebot__row--user' : ''}`;

      if (role !== 'user') {
        const avatar = document.createElement('span');
        avatar.className = 'cinebot__mini-avatar';
        avatar.innerHTML = '<i class="fa-solid fa-robot"></i>';
        row.appendChild(avatar);
      }

      const bubble = document.createElement('p');
      bubble.className = 'cinebot__bubble';
      
      let safeText = text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
        
      safeText = safeText.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="cinebot__link">$1</a>');
      bubble.innerHTML = safeText;
      
      row.appendChild(bubble);
      group.appendChild(row);
      messages.appendChild(group);

      if (shouldStore) transcript.push({ type: 'message', role, text });
      scrollToBottom();
    }

    async function fetchMovieShowtimes(movieId) {
      try {
        const response = await fetch(`/api/showtimes?movie_id=${encodeURIComponent(movieId)}`);
        if (!response.ok) return [];
        const showtimes = await response.json();
        return Array.isArray(showtimes)
          ? showtimes
              .filter((item) => new Date(item.start_time) > new Date())
              .sort((a, b) => new Date(a.start_time) - new Date(b.start_time))
              .slice(0, 4)
          : [];
      } catch {
        return [];
      }
    }

    async function createMovieCards(movieList, shouldStore = true) {
      if (!Array.isArray(movieList) || movieList.length === 0) return;

      const cards = document.createElement('div');
      cards.className = 'cinebot__cards';

      for (const movie of movieList.slice(0, 3)) {
        const movieId = movie.movie_id ?? movie.id;
        const card = document.createElement('article');
        card.className = 'cinebot__card';

        const main = document.createElement('div');
        main.className = 'cinebot__card-main';

        const poster = document.createElement('div');
        poster.className = 'cinebot__poster';
        const posterUrl = movie.poster_url ?? movie.poster;
        if (posterUrl) {
          const image = document.createElement('img');
          image.src = posterUrl;
          image.alt = `Poster ${movie.title}`;
          image.onerror = () => {
            poster.innerHTML = '<i class="fa-solid fa-ticket"></i>';
          };
          poster.appendChild(image);
        } else {
          poster.innerHTML = '<i class="fa-solid fa-ticket"></i>';
        }

        const info = document.createElement('div');
        const title = document.createElement('h3');
        title.textContent = movie.title || 'Phim CineBook';
        const genre = document.createElement('p');
        genre.textContent = movie.genre || 'Đang cập nhật thể loại';
        info.append(title, genre);
        main.append(poster, info);

        const link = document.createElement('a');
        link.className = 'cinebot__book';
        link.href = movieId ? `/movie/${movieId}` : '/movies';
        link.textContent = 'Xem chi tiết phim';

        card.appendChild(main);

        const showtimeList = await fetchMovieShowtimes(movieId);
        if (showtimeList.length > 0) {
          const showtimes = document.createElement('div');
          showtimes.className = 'cinebot__showtimes';
          showtimeList.forEach((showtime) => {
            const showtimeLink = document.createElement('a');
            showtimeLink.className = 'cinebot__showtime';
            showtimeLink.href = `/booking/${showtime.showtime_id}`;
            const theaterName = showtime.room?.theater?.name || showtime.room?.name || 'CineBook';
            showtimeLink.textContent = `${formatDateTime(showtime.start_time)} · ${theaterName}`;
            showtimes.appendChild(showtimeLink);
          });
          card.appendChild(showtimes);
        } else {
          const emptyShowtimes = document.createElement('p');
          emptyShowtimes.className = 'cinebot__showtime-empty';
          emptyShowtimes.textContent = 'Chưa có suất chiếu sắp tới.';
          card.appendChild(emptyShowtimes);
        }

        card.appendChild(link);
        cards.appendChild(card);
      }

      const lastGroup = messages.lastElementChild;
      if (lastGroup && lastGroup.classList.contains('cinebot__message-group')) {
        lastGroup.appendChild(cards);
      } else {
        messages.appendChild(cards);
      }
      
      if (shouldStore) transcript.push({ type: 'movies', movies: movieList.slice(0, 3) });
      scrollToBottom();
    }

    function createFollowUps(items, shouldStore = true) {
      if (!Array.isArray(items) || items.length === 0) return;

      const followUps = document.createElement('div');
      followUps.className = 'cinebot__follow-ups';

      items.forEach((item) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.dataset.prompt = item.prompt || item.label;
        button.textContent = item.label;
        followUps.appendChild(button);
      });

      const lastGroup = messages.lastElementChild;
      if (lastGroup && lastGroup.classList.contains('cinebot__message-group')) {
        lastGroup.appendChild(followUps);
      } else {
        messages.appendChild(followUps);
      }

      if (shouldStore) transcript.push({ type: 'followUps', items });
      scrollToBottom();
    }

    function createMaintenanceNotice() {
      const notice = document.createElement('div');
      notice.className = 'cinebot__notice';
      notice.innerHTML = `
        <i class="fa-solid fa-triangle-exclamation"></i>
        <h3>Hệ thống đang bận</h3>
        <p>Trợ lý CineBot đang được bảo trì để nâng cấp dữ liệu. Vui lòng thử lại sau ít phút.</p>
        <button type="button" data-retry><i class="fa-solid fa-rotate-right"></i> Làm mới</button>
        <a href="mailto:support@cinebook.vn"><i class="fa-solid fa-headset"></i> Liên hệ nhân viên hỗ trợ</a>
      `;
      notice.querySelector('[data-retry]').addEventListener('click', resetChat);
      messages.appendChild(notice);
      scrollToBottom();
    }

    async function checkAIStatus() {
      try {
        const response = await fetch('/api/ai/status');
        const data = await response.json().catch(() => ({}));
        aiOnline = response.ok && data.status === 'online';
        statusText.dataset.status = aiOnline ? 'online' : 'offline';
        statusText.innerHTML = aiOnline
          ? `<i class="fa-solid fa-circle"></i> AI online · ${data.index_size ?? 0} phim đã lập chỉ mục`
          : '<i class="fa-solid fa-circle"></i> AI đang bảo trì';
      } catch {
        aiOnline = false;
        statusText.dataset.status = 'offline';
        statusText.innerHTML = '<i class="fa-solid fa-circle"></i> AI đang bảo trì';
      }
    }

    function renderHistoryEmpty(message) {
      historyList.innerHTML = '';
      const empty = document.createElement('p');
      empty.className = 'cinebot__history-empty';
      empty.textContent = message;
      historyList.appendChild(empty);
    }

    async function loadConversationList() {
      if (!getToken()) {
        historyCaption.textContent = 'Đăng nhập để đồng bộ các phiên chat';
        renderHistoryEmpty('Khách vẫn có thể trò chuyện, nhưng lịch sử chỉ được lưu trong phiên trình duyệt hiện tại.');
        return;
      }

      historyCaption.textContent = 'Các phiên chat được lưu trên tài khoản';
      renderHistoryEmpty('Đang tải lịch sử...');

      try {
        const response = await fetch('/api/ai/conversations', { headers: authHeaders() });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(data.detail || 'Không thể tải lịch sử.');

        const conversations = data.conversations || [];
        historyList.innerHTML = '';
        if (conversations.length === 0) {
          renderHistoryEmpty('Bạn chưa có phiên trò chuyện nào.');
          return;
        }

        conversations.forEach((conversation) => {
          const item = document.createElement('article');
          item.className = 'cinebot__history-item';

          const open = document.createElement('button');
          open.type = 'button';
          open.className = 'cinebot__history-open';
          open.dataset.conversationId = conversation.conversation_id;
          open.innerHTML = `
            <strong></strong>
            <small>${formatDateTime(conversation.started_at)} · ${conversation.message_count} tin nhắn</small>
          `;
          open.querySelector('strong').textContent = conversation.preview || 'Cuộc trò chuyện CineBot';

          const remove = document.createElement('button');
          remove.type = 'button';
          remove.className = 'cinebot__history-delete';
          remove.dataset.deleteConversation = conversation.conversation_id;
          remove.setAttribute('aria-label', 'Xóa phiên trò chuyện');
          remove.innerHTML = '<i class="fa-solid fa-trash"></i>';

          item.append(open, remove);
          historyList.appendChild(item);
        });
      } catch (error) {
        renderHistoryEmpty(error.message);
      }
    }

    async function openConversation(id) {
      const response = await fetch(`/api/ai/conversations/${id}/messages`, {
        headers: authHeaders()
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.detail || 'Không thể mở phiên chat.');

      history = [];
      transcript = [];
      conversationId = data.conversation_id;
      [...messages.children].forEach((child) => {
        if (child !== welcome) child.remove();
      });
      welcome.hidden = true;

      (data.messages || []).forEach((message) => {
        const role = message.sender_type === 'user' ? 'user' : 'assistant';
        createMessage(message.content, role);
        history.push({ role, content: message.content });
      });

      saveConversation();
      historyPanel.classList.remove('cinebot__history--open');
      historyPanel.setAttribute('aria-hidden', 'true');
    }

    async function deleteConversation(id) {
      const response = await fetch(`/api/ai/conversations/${id}`, {
        method: 'DELETE',
        headers: authHeaders()
      });
      if (!response.ok && response.status !== 204) {
        const data = await response.json().catch(() => ({}));
        throw new Error(data.detail || 'Không thể xóa phiên chat.');
      }
      if (Number(id) === Number(conversationId)) resetChat();
      await loadConversationList();
    }

    async function requestResponse(message) {
      const response = await fetch(chatApi, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...authHeaders()
        },
        body: JSON.stringify({
          message,
          history: history.slice(-12),
          conversation_id: getToken() ? conversationId : null
        })
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        const error = new Error(data.detail || 'AI service hiện không khả dụng.');
        error.status = response.status;
        throw error;
      }
      return data;
    }

    async function sendMessage(rawMessage) {
      const message = rawMessage.trim();
      if (!message || busy) return;

      busy = true;
      sendButton.disabled = true;
      input.disabled = true;
      welcome.hidden = true;
      createMessage(message, 'user');
      history.push({ role: 'user', content: message });
      typing.hidden = false;
      scrollToBottom();

      try {
        const data = await requestResponse(message);
        typing.hidden = true;

        if (data.maintenance) {
          createMaintenanceNotice();
          return;
        }

        const reply = data.reply || 'Tôi chưa tìm thấy thông tin phù hợp. Bạn thử mô tả thể loại hoặc thời gian muốn xem nhé.';
        createMessage(reply, 'assistant');
        await createMovieCards(data.suggested_movies || []);
        createFollowUps([
          { label: 'Suất chiếu tối nay', prompt: 'Có suất chiếu nào tối nay không?' },
          { label: 'Đổi thể loại', prompt: 'Gợi ý cho tôi một thể loại phim khác' },
          { label: 'Phim khác', prompt: 'Cho tôi thêm lựa chọn phim khác' }
        ]);
        history.push({ role: 'assistant', content: reply });
        conversationId = data.conversation_id ?? conversationId;
        saveConversation();
      } catch (error) {
        typing.hidden = true;
        if (error.status === 422) {
          createMessage(error.message, 'assistant');
        } else {
          createMaintenanceNotice();
        }
        console.warn('[CineBot]', error.message);
      } finally {
        busy = false;
        sendButton.disabled = false;
        input.disabled = false;
        input.focus();
      }
    }

    function resetChat() {
      history = [];
      transcript = [];
      conversationId = null;
      busy = false;
      typing.hidden = true;
      sendButton.disabled = false;
      input.disabled = false;
      input.value = '';
      [...messages.children].forEach((child) => {
        if (child !== welcome) child.remove();
      });
      welcome.hidden = false;
      messages.scrollTop = 0;
      sessionStorage.removeItem(storageKey);
      input.focus();
    }

    function restoreConversation() {
      try {
        const saved = JSON.parse(sessionStorage.getItem(storageKey));
        if (!saved || !Array.isArray(saved.transcript) || saved.transcript.length === 0) return;

        history = Array.isArray(saved.history) ? saved.history : [];
        transcript = saved.transcript;
        conversationId = saved.conversationId ?? null;
        welcome.hidden = true;

        transcript.forEach((item) => {
          if (item.type === 'message') createMessage(item.text, item.role, false);
          if (item.type === 'movies') void createMovieCards(item.movies, false);
          if (item.type === 'followUps') createFollowUps(item.items, false);
        });
      } catch (error) {
        sessionStorage.removeItem(storageKey);
      }
    }

    trigger.addEventListener('click', () => setOpen(!root.classList.contains('cinebot--open')));
    closeButton.addEventListener('click', () => setOpen(false));
    resetButton.addEventListener('click', resetChat);
    historyButton.addEventListener('click', async () => {
      historyPanel.classList.add('cinebot__history--open');
      historyPanel.setAttribute('aria-hidden', 'false');
      await loadConversationList();
    });
    historyClose.addEventListener('click', () => {
      historyPanel.classList.remove('cinebot__history--open');
      historyPanel.setAttribute('aria-hidden', 'true');
    });

    historyList.addEventListener('click', async (event) => {
      const openButton = event.target.closest('[data-conversation-id]');
      const deleteButton = event.target.closest('[data-delete-conversation]');

      try {
        if (openButton) await openConversation(openButton.dataset.conversationId);
        if (deleteButton && window.confirm('Bạn có chắc muốn xóa phiên trò chuyện này?')) {
          await deleteConversation(deleteButton.dataset.deleteConversation);
        }
      } catch (error) {
        renderHistoryEmpty(error.message);
      }
    });

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const message = input.value;
      input.value = '';
      sendMessage(message);
    });

    messages.addEventListener('click', (event) => {
      const promptButton = event.target.closest('[data-prompt]');
      if (promptButton) sendMessage(promptButton.dataset.prompt);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && root.classList.contains('cinebot--open')) setOpen(false);
    });

    restoreConversation();
    checkAIStatus();
  })();
</script>
