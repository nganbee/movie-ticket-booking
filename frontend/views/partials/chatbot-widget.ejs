<!-- Chatbot Widget -->
<div id="chatbot-wrapper" class="fixed bottom-6 right-6 z-50 font-sans">
  <!-- Chat Button Trigger -->
  <button id="chatbot-trigger" class="w-14 h-14 bg-emerald-500 hover:bg-emerald-600 text-white rounded-full flex items-center justify-center shadow-lg hover:shadow-xl active:scale-95 transition-all duration-300 relative group">
    <!-- Pulse animation rings -->
    <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-20 animate-ping group-hover:hidden"></span>
    
    <!-- Custom Chat Icon -->
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7" id="chatbot-icon-chat">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.625.625 0 1 1-1.25 0 .625.625 0 0 1 1.25 0Zm0 0H8.625m2.5 0a.625.625 0 1 1-1.25 0 .625.625 0 0 1 1.25 0Zm0 0H11.25m2.5 0a.625.625 0 1 1-1.25 0 .625.625 0 0 1 1.25 0Zm0 0H13.75M21 12c0 1.268-.63 2.39-1.617 3.062a7.5 7.5 0 0 1-3.21 4.791c-.88.583-1.898.821-2.91.821a9.079 9.079 0 0 1-5.187-1.606m13.063-7.068a9.08 9.08 0 0 0-2.316-5.834C15.008 2.25 13.003 1.5 11.25 1.5a8.25 8.25 0 0 0-8.25 8.25c0 1.637.472 3.167 1.288 4.467l-1.04 3.32a.75.75 0 0 0 .961.96l3.333-1.012A9 9 0 0 0 11.25 18a8.25 8.25 0 0 0 8.25-8.25Z" />
    </svg>
    <!-- Close icon (hidden by default) -->
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 hidden" id="chatbot-icon-close">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
    </svg>

    <!-- Unread badge -->
    <span id="chatbot-badge" class="absolute -top-1 -right-1 w-5 h-5 bg-rose-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center border border-white">1</span>
  </button>

  <!-- Chat Dialog Window (Hidden by default) -->
  <div id="chatbot-window" class="hidden fixed bottom-[90px] right-6 w-80 sm:w-96 h-[50vh] min-h-[360px] max-h-[580px] bg-white rounded-2xl shadow-2xl border border-slate-100 flex flex-col overflow-hidden transition-all duration-300 transform scale-95 opacity-0 origin-bottom-right z-[9999]">
    
    <!-- Chat Header -->
    <div class="bg-gradient-to-r from-emerald-500 to-teal-600 text-white px-4 py-3 flex items-center gap-3">
      <div class="relative">
        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center font-bold text-lg border border-white/30">
          🤖
        </div>
        <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-400 rounded-full border-2 border-emerald-500"></span>
      </div>
      <div>
        <h4 class="font-bold text-sm tracking-wide">CineBook Assistant</h4>
        <p class="text-[11px] text-emerald-100">Hỗ trợ đặt vé trực tuyến 24/7</p>
      </div>
      <button id="chatbot-close-btn" class="ml-auto text-emerald-100 hover:text-white transition">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Chat Messages Area -->
    <div id="chatbot-messages" class="flex-1 overflow-y-auto p-4 space-y-3 bg-slate-55 flex flex-col">
      <!-- Welcome Message -->
      <div class="flex items-start gap-2 max-w-[85%] self-start">
        <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-sm flex-shrink-0">🤖</div>
        <div class="bg-slate-100 text-slate-800 text-sm px-3.5 py-2 rounded-2xl rounded-tl-none leading-relaxed">
          Xin chào! Tôi là trợ lý ảo CineBook. Bạn cần tôi giúp gì hôm nay?
        </div>
      </div>

      <!-- Quick Replies -->
      <div id="chatbot-quick-replies" class="flex flex-wrap gap-2 pt-2 ml-10">
        <button class="quick-reply-btn text-xs text-emerald-600 bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 px-3 py-1.5 rounded-full transition-all">
          🎬 Cách đặt vé xem phim?
        </button>
        <button class="quick-reply-btn text-xs text-emerald-600 bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 px-3 py-1.5 rounded-full transition-all">
          💳 Chính sách hoàn tiền vé?
        </button>
        <button class="quick-reply-btn text-xs text-emerald-600 bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 px-3 py-1.5 rounded-full transition-all">
          📍 Địa chỉ các rạp chiếu ở đâu?
        </button>
        <button class="quick-reply-btn text-xs text-emerald-600 bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 px-3 py-1.5 rounded-full transition-all">
          🎫 Đăng ký thành viên CineBook
        </button>
      </div>
    </div>

    <!-- Typing Indicator (hidden by default) -->
    <div id="chatbot-typing" class="hidden px-4 py-2 bg-white flex items-center gap-2 text-slate-400 text-xs ml-10">
      <div class="flex items-center gap-1">
        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
      </div>
      <span>CineBook đang trả lời...</span>
    </div>

    <!-- Chat Input Area -->
    <form id="chatbot-form" class="border-t border-slate-100 p-3 bg-white flex gap-2 items-center">
      <input type="text" id="chatbot-input" placeholder="Nhập câu hỏi của bạn..." autocomplete="off" class="flex-1 text-sm bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 focus:outline-none focus:border-emerald-500 focus:bg-white transition-colors" />
      <button type="submit" class="w-10 h-10 bg-emerald-500 hover:bg-emerald-600 active:scale-95 text-white rounded-xl flex items-center justify-center shadow-md transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 transform rotate-45 -translate-x-[1px] translate-y-[1px]">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
      </button>
    </form>
  </div>
</div>

<script>
(function() {
  const trigger = document.getElementById('chatbot-trigger');
  const chatWindow = document.getElementById('chatbot-window');
  const closeBtn = document.getElementById('chatbot-close-btn');
  const chatIconChat = document.getElementById('chatbot-icon-chat');
  const chatIconClose = document.getElementById('chatbot-icon-close');
  const badge = document.getElementById('chatbot-badge');
  const form = document.getElementById('chatbot-form');
  const input = document.getElementById('chatbot-input');
  const messagesArea = document.getElementById('chatbot-messages');
  const typingIndicator = document.getElementById('chatbot-typing');
  const quickReplyContainer = document.getElementById('chatbot-quick-replies');

  // QA mapping in Vietnamese
  const qaDatabase = [
    {
      keywords: ['đặt vé', 'mua vé', 'cach dat ve', 'huong dan'],
      reply: 'Để đặt vé xem phim, bạn thực hiện theo các bước sau:\n1. Chọn phim muốn xem tại Trang chủ.\n2. Bấm nút **"Mua Vé"** hoặc chi tiết phim để xem Lịch chiếu.\n3. Chọn rạp, suất chiếu mong muốn.\n4. Chọn vị trí ghế ngồi (ghế Thường hoặc ghế VIP).\n5. Xác nhận thông tin đơn hàng và thanh toán qua **VNPAY**.\n6. Sau khi thanh toán thành công, bạn sẽ nhận được một vé điện tử chứa mã QR để check-in tại quầy vé.'
    },
    {
      keywords: ['hoàn tiền', 'huỷ vé', 'hủy vé', 'hoan tien', 'doi ve', 'đổi vé'],
      reply: 'Chính sách hủy vé & hoàn tiền của CineBook như sau:\n- Quý khách có thể hủy vé và nhận hoàn tiền tự động 100% nếu thực hiện hủy trước giờ chiếu **ít nhất 60 phút**.\n- Việc hủy vé có thể thực hiện trực tiếp trong trang **Hồ sơ cá nhân / Lịch sử đặt vé** của bạn bằng cách nhấn vào nút "Hủy vé" cạnh đơn hàng.\n- Tiền sẽ được hoàn trả lại tài khoản VNPAY/Ngân hàng của bạn trong vòng 3-5 ngày làm việc.'
    },
    {
      keywords: ['địa chỉ', 'dia chi', 'rạp', 'rap', 'nguyễn du', 'landmark'],
      reply: 'CineBook hiện có 2 cụm rạp chính hiện đại phục vụ quý khách:\n1. **CineBook Nguyễn Du**: 116 Nguyễn Du, Phường Bến Thành, Quận 1, TP. Hồ Chí Minh.\n2. **CineBook Landmark 81**: Tầng B1, Tòa nhà Landmark 81, Vinhomes Central Park, Bình Thạnh, TP. Hồ Chí Minh.\nCả hai rạp đều trang bị phòng chiếu IMAX, âm thanh Dolby Atmos chuẩn quốc tế!'
    },
    {
      keywords: ['thành viên', 'dang ky', 'đăng ký', 'member', 'tai khoan'],
      reply: 'Để đăng ký tài khoản thành viên CineBook:\n1. Nhấp vào nút **"Đăng nhập/Đăng ký"** trên thanh Menu ở góc trên bên phải.\n2. Chọn tab **"Đăng ký"** trên biểu mẫu hiện ra.\n3. Nhập đầy đủ thông tin (Họ tên, Email, Mật khẩu) và nhấn Xác nhận.\nThành viên mới sẽ được tặng ngay voucher giảm giá 20% cho lần đặt vé đầu tiên và tích luỹ điểm thưởng đổi bắp nước!'
    },
    {
      keywords: ['giá vé', 'gia ve', 'tiền vé', 'bao nhiêu'],
      reply: 'Bảng giá vé cơ bản tại hệ thống rạp CineBook:\n- **Ghế thường**: 80.000đ - 95.000đ (tùy khung giờ và ngày lễ).\n- **Ghế VIP**: 100.000đ - 120.000đ.\n- Suất chiếu **IMAX / 3D**: Phụ thu thêm 30.000đ - 50.000đ/vé.\nHọc sinh, sinh viên khi mua trực tiếp tại quầy sẽ được giảm giá đồng giá 60.000đ/vé thường.'
    }
  ];

  // Helper to reply logically
  function getResponse(userMessage) {
    const text = userMessage.toLowerCase().trim();
    
    // Check keyword matching
    for (const item of qaDatabase) {
      for (const kw of item.keywords) {
        if (text.includes(kw)) {
          return item.reply;
        }
      }
    }
    
    // Default reply
    return 'Cảm ơn bạn đã nhắn tin! Câu hỏi của bạn chưa có sẵn câu trả lời tự động. \n\nBạn có thể tham khảo nhanh các chủ đề:\n- Hướng dẫn đặt vé xem phim\n- Chính sách hủy & hoàn tiền vé\n- Giá vé và địa chỉ các rạp chiếu\n\nHoặc vui lòng để lại thông tin liên lạc, đội ngũ chăm sóc khách hàng sẽ phản hồi qua email của bạn sớm nhất!';
  }

  // Toggling chatbot window
  function toggleChatbot() {
    const isOpen = !chatWindow.classList.contains('hidden');
    if (isOpen) {
      // Close window
      chatWindow.classList.add('scale-95', 'opacity-0');
      setTimeout(() => {
        chatWindow.classList.add('hidden');
      }, 300);
      chatIconChat.classList.remove('hidden');
      chatIconClose.classList.add('hidden');
    } else {
      // Open window
      chatWindow.classList.remove('hidden');
      setTimeout(() => {
        chatWindow.classList.remove('scale-95', 'opacity-0');
      }, 10);
      chatIconChat.classList.add('hidden');
      chatIconClose.classList.remove('hidden');
      badge.classList.add('hidden'); // Clear badge when opened
      scrollToBottom();
    }
  }

  trigger.addEventListener('click', toggleChatbot);
  closeBtn.addEventListener('click', toggleChatbot);

  // Add Message to DOM
  function appendMessage(text, sender = 'user') {
    const msgContainer = document.createElement('div');
    msgContainer.className = `flex items-start gap-2 max-w-[85%] ${sender === 'user' ? 'self-end flex-row-reverse' : 'self-start'}`;
    
    const avatar = document.createElement('div');
    avatar.className = `w-8 h-8 rounded-full flex items-center justify-center text-sm flex-shrink-0 ${sender === 'user' ? 'bg-emerald-500 text-white' : 'bg-emerald-100'}`;
    avatar.textContent = sender === 'user' ? 'U' : '🤖';

    const textBubble = document.createElement('div');
    textBubble.className = `text-sm px-3.5 py-2 rounded-2xl leading-relaxed whitespace-pre-line ${
      sender === 'user' 
        ? 'bg-emerald-500 text-white rounded-tr-none' 
        : 'bg-slate-100 text-slate-800 rounded-tl-none'
    }`;
    textBubble.innerHTML = formatMarkdownText(text);

    msgContainer.appendChild(avatar);
    msgContainer.appendChild(textBubble);
    
    // Add to messages area
    messagesArea.appendChild(msgContainer);
    scrollToBottom();
  }

  // Basic formatter for bold markup
  function formatMarkdownText(txt) {
    return txt.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
  }

  function scrollToBottom() {
    messagesArea.scrollTop = messagesArea.scrollHeight;
  }

  // Handle Form Submit
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    const message = input.value.trim();
    if (!message) return;

    appendMessage(message, 'user');
    input.value = '';

    // Trigger bot typing indicator
    typingIndicator.classList.remove('hidden');
    scrollToBottom();

    setTimeout(() => {
      typingIndicator.classList.add('hidden');
      const response = getResponse(message);
      appendMessage(response, 'bot');
    }, 1200);
  });

  // Handle Quick Replies click
  messagesArea.addEventListener('click', function(e) {
    if (e.target && e.target.classList.contains('quick-reply-btn')) {
      const qText = e.target.textContent.trim().replace(/^[🎬💳📍🎫]\s*/, '');
      appendMessage(qText, 'user');
      
      // Hide quick replies after selection
      quickReplyContainer.classList.add('hidden');

      typingIndicator.classList.remove('hidden');
      scrollToBottom();

      setTimeout(() => {
        typingIndicator.classList.add('hidden');
        const response = getResponse(qText);
        appendMessage(response, 'bot');
      }, 1000);
    }
  });

  // Simulate pulse notification badge after 5 seconds if chat is unopened
  setTimeout(() => {
    if (chatWindow.classList.contains('hidden')) {
      badge.classList.remove('hidden');
      badge.classList.add('animate-bounce');
    }
  }, 5000);
})();
</script>
